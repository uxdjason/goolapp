---
import BaseLayout from './BaseLayout.astro';
import AdUnit from '../components/AdUnit.astro';

interface Props {
  title: string;
  description: string;
  shortDescription: string;
  category?: string;
  keywords?: string[];
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  publishedAt?: Date;
  updatedAt?: Date;
}
const {
  title,
  description,
  shortDescription,
  category,
  keywords = [],
  ogImage,
  ogTitle,
  ogDescription,
  canonicalUrl,
  publishedAt,
  updatedAt,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  calculator: '각종 계산기',
  datetime:   '날짜와 시간',
  tool:       '편리한 도구들',
  quiz:       '학습 및 퀴즈',
  fun:        '심심풀이 Fun',
  finance:    '금융 재테크',
};
const catLabel = category ? (categoryLabels[category] ?? category) : '';

// Ensure slug is always available even for explicitly created pages (not dynamic [slug].astro)
const currentSlug = Astro.url.pathname.replace(/^\/|\/$/g, '').split('/').pop();

// SoftwareApplication JSON-LD (Google Rich Results 지원)
const appCategory = category ? (categoryLabels[category] ?? category) : '유틸리티';
const canonicalHref = canonicalUrl || `https://goolapp.com/${currentSlug}/`;
const appJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  description: description,
  applicationCategory: 'WebApplication',
  operatingSystem: 'Any',
  url: canonicalHref,
  inLanguage: 'ko-KR',
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'KRW',
  },
  publisher: {
    '@type': 'Organization',
    name: 'GoolAPP',
    url: 'https://goolapp.com',
  },
  ...(publishedAt && { datePublished: publishedAt.toISOString() }),
  ...(updatedAt && { dateModified: updatedAt.toISOString() }),
});
---
<BaseLayout
  title={`${title} | GoolAPP`}
  description={description}
  ogType="article"
  ogImage={ogImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  canonicalUrl={canonicalUrl || `https://goolapp.com/${currentSlug}/`}
  keywords={keywords}
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  jsonLd={appJsonLd}
>
  <article class="app-page">
    <div class="container">

      <!-- ── App Hero Header (from goolapp-app-260508.md) ── -->
      <header class="app-header">
        <div class="chip-row">
          {catLabel && (
            <span class="cat-chip chip-primary label-caps">
              {catLabel}
            </span>
          )}
          {keywords.map(kw => (
            <span class="tag-chip chip-secondary label-caps">{kw}</span>
          ))}
        </div>

        <div class="app-title-row">
          <h1 class="app-title">{title}</h1>
          <button class="fav-btn" data-app-slug={currentSlug} aria-label="즐겨찾기" title="즐겨찾기">
            <img src="/img/star-btn-0.png" class="fav-icon" alt="즐겨찾기" width="32" height="32" />
          </button>
        </div>

        <p class="app-description">{shortDescription}</p>
      </header>

      <!-- ── Ad: top (앱 헤더 바로 아래) ── -->
      <AdUnit position="top" />

      <!-- ── App UI area ── -->
      <section class="app-ui-section glass-surface" aria-label="앱 실행 영역">
        <slot name="app" />
      </section>

      <!-- ── Ad: middle (앱 UI 아래, 롱폼 위) ── -->
      <AdUnit position="middle" />

      <!-- ── Long-form content ── -->
      <section class="longform-section" aria-label="상세 설명">
        <slot name="longform" />
      </section>

      <!-- ── Ad: bottom (페이지 맨 아래) ── -->
      <AdUnit position="bottom" />

    </div>
  </article>
</BaseLayout>

<style>
  .app-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  /* ── App header (from goolapp-app-260508.md) ── */
  .app-header {
    margin-bottom: var(--space-8);
  }
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }
  .cat-chip, .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 16px;
    border-radius: var(--radius-full);
    font-family: var(--font-family-gothic);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .chip-dot { font-size: 8px; line-height: 1; }

  .app-title-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: 16px 0 8px;
  }
  .app-title {
    /* from design: 48px, letter-spacing -0.96px */
    font-size: var(--font-size-3xl);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-on-surface);
    margin: 0;
  }
  .fav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    transition: transform var(--transition-fast);
  }
  .fav-btn:hover { transform: scale(1.1); }
  .fav-icon {
    width: 100%;
    height: auto;
  }

  .app-description {
    /* from design: 18px, color #53433D */
    font-size: var(--font-size-lg);
    color: var(--color-on-surface-variant);
    width: 100%;
    margin: 8px 0 0;
  }

  /* ── App UI glass panel ── */
  .app-ui-section {
    /* from goolapp-app-mobile-260508.md: padding 24px, border-radius 24px, glass */
    padding: var(--space-8);
    margin: var(--space-6) 0 var(--space-12);
    border-radius: var(--radius-2xl);
    background: rgba(251, 249, 245, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.1);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    min-height: 200px;
    clear: both;
  }

  .longform-section {
    max-width: 768px;
    margin: 0 auto;
    font-size: var(--font-size-base);
    line-height: var(--line-height-base);
  }
  .longform-section :global(h2) { margin-top: var(--space-8); margin-bottom: var(--space-4); }
  .longform-section :global(h3) { margin-top: var(--space-6); margin-bottom: var(--space-3); }
  .longform-section :global(p)  { margin-bottom: var(--space-4); }
  .longform-section :global(ul), .longform-section :global(ol) { margin-bottom: var(--space-4); padding-left: var(--space-6); }
  .longform-section :global(li) { margin-bottom: var(--space-2); }

  /* Mobile */
  @media (max-width: 768px) {
    .app-title { font-size: 2rem; }
    .app-ui-section { padding: var(--space-6); border-radius: var(--radius-2xl); }
    .app-description { font-size: var(--font-size-base); }
  }
</style>
