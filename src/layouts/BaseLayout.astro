---
import '../styles/reset.css';
import '../styles/design-system.css';
import '../styles/app-ui.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  ogTitle?: string;
  ogDescription?: string;
  canonicalUrl?: string;
  keywords?: string[];
  publishedAt?: Date;
  updatedAt?: Date;
  /** 페이지별 추가 JSON-LD (직렬화된 JSON 문자열) */
  jsonLd?: string;
}
const {
  title,
  description,
  ogImage,
  ogType,
  ogTitle,
  ogDescription,
  canonicalUrl,
  keywords,
  publishedAt,
  updatedAt,
  jsonLd,
} = Astro.props;

// WebSite JSON-LD (모든 페이지 공통)
const websiteJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'GoolAPP',
  url: 'https://goolapp.com',
  description: 'GoolAPP — 계산기, 날짜/시간 도구, 퀴즈 등 일상에서 바로 꺼내 쓸 수 있는 무료 웹앱 컬렉션',
  inLanguage: 'ko-KR',
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://goolapp.com/?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
});

// AdSense는 (1) 환경변수 enable 플래그가 켜져 있고 (2) client ID가 있을 때만 출력.
// 도메인 이전 전까지는 PUBLIC_ADSENSE_ENABLED=false 로 두어 ad request 자체를 회피한다.
const adsenseClient  = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
const adsenseEnabled = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const showAdsense    = adsenseEnabled && Boolean(adsenseClient);

// 색인 정책: production hostname이 정식 도메인이 아닐 경우 noindex로 강제.
// (PUBLIC_ADSENSE_ENABLED와 동일한 환경 신호로 판단해도 무방)
const isLiveDomain = adsenseEnabled; // production에서만 true 주입되므로 동일 신호 활용
const robotsContent = isLiveDomain ? 'index,follow' : 'noindex,nofollow';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robotsContent} />
    {/* 브라우저 UI 색상 (Chrome Android, Safari) */}
    <meta name="theme-color" content="#8B4F32" />
    {/* 파비콘 & 홈 화면 아이콘 */}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <Seo
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      canonicalUrl={canonicalUrl}
      keywords={keywords}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      jsonLd={jsonLd ?? websiteJsonLd}
    />
    {showAdsense && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} crossorigin="anonymous"></script>
    )}
  </head>
  <body class="global-layout">
    <Header />
    <main class="global-main"><slot /></main>
    <Footer />
    <script>
      const FAV_KEY = 'goolapp_favorites';
      let currentDisplayLimit = 9;
      
      function getFavorites() {
        try {
          return JSON.parse(localStorage.getItem(FAV_KEY) || '[]');
        } catch {
          return [];
        }
      }
      
      function setFavorites(favs: string[]) {
        localStorage.setItem(FAV_KEY, JSON.stringify(favs));
      }
      
      function updateFavIcons() {
        const favs = getFavorites();
        document.querySelectorAll('.fav-btn').forEach(btn => {
          const slug = btn.getAttribute('data-app-slug');
          const isFav = slug && favs.includes(slug);
          const img = btn.querySelector('img');
          if (img) {
            img.src = isFav ? '/img/star-btn-1.png' : '/img/star-btn-0.png';
          }
        });
      }
      
      function applyFilter() {
        const isFavoritesFilter = window.location.hash === '#favorites';
        const isSearchPage = window.location.pathname === '/search';
        const urlParams = new URLSearchParams(window.location.search);
        const searchQuery = (urlParams.get('q') || '').toLowerCase();
        
        const queryDisplay = document.getElementById('search-query-display');
        if (queryDisplay && isSearchPage) {
           queryDisplay.textContent = '검색어: ' + (urlParams.get('q') || '');
        }

        const favs = getFavorites();
        
        // Update nav links active state
        document.querySelectorAll('.cat-btn').forEach(btn => {
          const href = btn.getAttribute('href');
          if (href === '/#favorites') {
            if (isFavoritesFilter) btn.classList.add('active');
            else btn.classList.remove('active');
          } else if (href === '/') {
            if (isFavoritesFilter) btn.classList.remove('active');
            else if (window.location.pathname === '/') btn.classList.add('active');
          }
        });
        
        let visibleCount = 0;
        let matchedCount = 0;

        document.querySelectorAll('.app-card').forEach((el) => {
          const card = el as HTMLElement;
          const slug = card.getAttribute('data-slug');
          const title = card.getAttribute('data-title') || '';
          const desc = card.getAttribute('data-desc') || '';
          
          let isMatch = false;
          if (isSearchPage) {
            if (searchQuery && (title.toLowerCase().includes(searchQuery) || desc.toLowerCase().includes(searchQuery))) {
              isMatch = true;
            }
          } else if (isFavoritesFilter) {
            if (slug && favs.includes(slug)) {
              isMatch = true;
            }
          } else {
            isMatch = true;
          }

          if (isMatch) {
            matchedCount++;
            if (matchedCount <= currentDisplayLimit) {
              card.style.display = '';
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          } else {
            card.style.display = 'none';
          }
        });
        
        const favEmptyState = document.getElementById('favorites-empty-state');
        const searchEmptyState = document.getElementById('search-empty-state');
        const loadMore = document.querySelector('.load-more-wrap') as HTMLElement;
        
        if (favEmptyState) {
          if (isFavoritesFilter && visibleCount === 0) {
            favEmptyState.style.display = 'block';
          } else {
            favEmptyState.style.display = 'none';
          }
        }

        if (searchEmptyState) {
          if (isSearchPage && visibleCount === 0) {
            searchEmptyState.style.display = 'block';
          } else {
            searchEmptyState.style.display = 'none';
          }
        }
        
        if (loadMore) {
          if (matchedCount > currentDisplayLimit) {
             loadMore.style.display = '';
          } else {
             loadMore.style.display = 'none';
          }
        }
      }

      function handleLoadMore() {
        currentDisplayLimit += 9;
        applyFilter();
      }
      
      function handleFavClick(e: Event) {
        const target = e.target as HTMLElement;
        const btn = target.closest('.fav-btn');
        if (!btn) return;
        
        e.preventDefault();
        
        const slug = btn.getAttribute('data-app-slug');
        if (!slug) return;
        
        let favs = getFavorites();
        if (favs.includes(slug)) {
          favs = favs.filter((f: string) => f !== slug);
        } else {
          favs.push(slug);
        }
        
        setFavorites(favs);
        updateFavIcons();
        if (window.location.hash === '#favorites') {
          applyFilter();
        }
      }
      
      document.addEventListener('DOMContentLoaded', () => {
        updateFavIcons();
        applyFilter();
        document.body.addEventListener('click', handleFavClick);
        const loadMoreBtn = document.querySelector('.load-more-btn');
        if (loadMoreBtn) {
          loadMoreBtn.addEventListener('click', handleLoadMore);
        }
      });
      
      window.addEventListener('hashchange', () => {
        currentDisplayLimit = 9;
        applyFilter();
      });
    </script>
  </body>
</html>
