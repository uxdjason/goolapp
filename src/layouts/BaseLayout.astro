---
import '../styles/reset.css';
import '../styles/design-system.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Seo from '../components/Seo.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
}
const { title, description, ogImage, canonicalUrl } = Astro.props;

// AdSense는 (1) 환경변수 enable 플래그가 켜져 있고 (2) client ID가 있을 때만 출력.
// 도메인 이전 전까지는 PUBLIC_ADSENSE_ENABLED=false 로 두어 ad request 자체를 회피한다.
const adsenseClient  = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
const adsenseEnabled = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const showAdsense    = adsenseEnabled && Boolean(adsenseClient);

// 색인 정책: production hostname이 정식 도메인이 아닐 경우 noindex로 강제.
// (PUBLIC_ADSENSE_ENABLED와 동일한 환경 신호로 판단해도 무방)
const isLiveDomain = adsenseEnabled; // production에서만 true 주입되므로 동일 신호 활용
const robotsContent = isLiveDomain ? 'index,follow' : 'noindex,nofollow';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content={robotsContent} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <Seo title={title} description={description} ogImage={ogImage} canonicalUrl={canonicalUrl} />
    {showAdsense && (
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`} crossorigin="anonymous"></script>
    )}
  </head>
  <body class="global-layout">
    <Header />
    <main class="global-main"><slot /></main>
    <Footer />
    <script>
      const FAV_KEY = 'goolapp_favorites';
      
      function getFavorites() {
        try {
          return JSON.parse(localStorage.getItem(FAV_KEY) || '[]');
        } catch {
          return [];
        }
      }
      
      function setFavorites(favs: string[]) {
        localStorage.setItem(FAV_KEY, JSON.stringify(favs));
      }
      
      function updateFavIcons() {
        const favs = getFavorites();
        document.querySelectorAll('.fav-btn').forEach(btn => {
          const slug = btn.getAttribute('data-app-slug');
          const isFav = slug && favs.includes(slug);
          const img = btn.querySelector('img');
          if (img) {
            img.src = isFav ? '/img/star-btn-1.png' : '/img/star-btn-0.png';
          }
        });
      }
      
      function applyFilter() {
        const isFavoritesFilter = window.location.hash === '#favorites';
        const favs = getFavorites();
        
        // Update nav links active state
        document.querySelectorAll('.cat-btn').forEach(btn => {
          const href = btn.getAttribute('href');
          if (href === '/#favorites') {
            if (isFavoritesFilter) btn.classList.add('active');
            else btn.classList.remove('active');
          } else if (href === '/') {
            if (isFavoritesFilter) btn.classList.remove('active');
            else if (window.location.pathname === '/') btn.classList.add('active');
          }
        });
        
        let visibleCount = 0;
        document.querySelectorAll('.app-card').forEach((el) => {
          const card = el as HTMLElement;
          const slug = card.getAttribute('data-slug');
          if (isFavoritesFilter) {
            if (slug && favs.includes(slug)) {
              card.style.display = '';
              visibleCount++;
            } else {
              card.style.display = 'none';
            }
          } else {
            card.style.display = '';
            visibleCount++;
          }
        });
        
        const emptyState = document.getElementById('favorites-empty-state');
        const loadMore = document.querySelector('.load-more-wrap') as HTMLElement;
        
        if (emptyState) {
          if (isFavoritesFilter && visibleCount === 0) {
            emptyState.style.display = 'block';
          } else {
            emptyState.style.display = 'none';
          }
        }
        
        if (loadMore) {
          if (isFavoritesFilter) {
             loadMore.style.display = 'none';
          } else {
             loadMore.style.display = '';
          }
        }
      }
      
      function handleFavClick(e: Event) {
        const target = e.target as HTMLElement;
        const btn = target.closest('.fav-btn');
        if (!btn) return;
        
        e.preventDefault();
        
        const slug = btn.getAttribute('data-app-slug');
        if (!slug) return;
        
        let favs = getFavorites();
        if (favs.includes(slug)) {
          favs = favs.filter((f: string) => f !== slug);
        } else {
          favs.push(slug);
        }
        
        setFavorites(favs);
        updateFavIcons();
        if (window.location.hash === '#favorites') {
          applyFilter();
        }
      }
      
      document.addEventListener('DOMContentLoaded', () => {
        updateFavIcons();
        applyFilter();
        document.body.addEventListener('click', handleFavClick);
      });
      
      window.addEventListener('hashchange', applyFilter);
    </script>
  </body>
</html>
