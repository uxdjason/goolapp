---
import { getEntry, render, getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

const entry = await getEntry('apps', 'count-characters-words');
if (!entry) throw new Error('count-characters-words entry not found');
const { Content } = await render(entry);

const allApps = await getCollection('apps');
let related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
if (related.length === 0) {
  related = allApps
    .filter(app => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="app-wrapper">
      <div class="input-section">
        <label for="textInput" class="input-label">텍스트 입력</label>
        <textarea
          id="textInput"
          placeholder="여기에 텍스트를 입력하거나 붙여넣기 하세요."
          rows="10"
        ></textarea>

        <div class="live-stats" id="liveStats">
          <div class="stat-item">
            <span class="stat-label">실시간 글자 수</span>
            <span class="stat-value" id="liveCharCount">0</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">실시간 단어 수</span>
            <span class="stat-value" id="liveWordCount">0</span>
          </div>
        </div>

        <p class="error-message" id="errorMessage" hidden>텍스트를 입력해주세요.</p>

        <div class="button-group">
          <button type="button" class="app-btn app-btn-primary" id="analyzeBtn">
            글자 및 단어 수 세기
          </button>
          <button type="button" class="app-btn app-btn-outline" id="clearBtn">
            지우기
          </button>
        </div>
      </div>

      <div class="result-section" id="resultSection" hidden>
        <h2 class="result-title">분석 결과</h2>
        <div class="result-grid">
          <div class="result-card">
            <span class="result-label">공백 포함 글자 수</span>
            <span class="result-value" id="charWithSpaces">0</span>
            <span class="result-unit">자</span>
          </div>
          <div class="result-card">
            <span class="result-label">공백 제외 글자 수</span>
            <span class="result-value" id="charWithoutSpaces">0</span>
            <span class="result-unit">자</span>
          </div>
          <div class="result-card">
            <span class="result-label">단어 수</span>
            <span class="result-value" id="wordCount">0</span>
            <span class="result-unit">개</span>
          </div>
          <div class="result-card">
            <span class="result-label">줄 수</span>
            <span class="result-value" id="lineCount">0</span>
            <span class="result-unit">줄</span>
          </div>
        </div>

      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .app-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-section,
  .result-section {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .input-label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  textarea#textInput {
    width: 100%;
    min-height: 200px;
    padding: 0.875rem;
    font-size: 1rem;
    line-height: 1.6;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-background);
    color: var(--color-text);
    resize: vertical;
    font-family: inherit;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  textarea#textInput:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .live-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem;
    background: var(--color-background);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .stat-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .error-message {
    color: #dc2626;
    font-size: 0.9rem;
    margin-top: 0.75rem;
    padding: 0.5rem 0.75rem;
    background: #fef2f2;
    border-radius: var(--radius-sm);
    border-left: 3px solid #dc2626;
  }

  .error-message[hidden] {
    display: none;
  }

  .button-group {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .button-group .app-btn:first-child {
    flex: 3;
  }

  .button-group .app-btn:last-child {
    flex: 1;
  }

  .result-section[hidden] {
    display: none;
  }

  .result-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    color: var(--color-text);
  }

  .result-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .result-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 0.75rem;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-align: center;
  }

  .result-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .result-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.2;
  }

  .result-unit {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  @media (max-width: 480px) {
    .button-group {
      flex-direction: column;
    }

    .result-value {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  const textInput = document.getElementById('textInput') as HTMLTextAreaElement | null;
  const liveCharCount = document.getElementById('liveCharCount');
  const liveWordCount = document.getElementById('liveWordCount');
  const errorMessage = document.getElementById('errorMessage');
  const analyzeBtn = document.getElementById('analyzeBtn');
  const clearBtn = document.getElementById('clearBtn');
  const resultSection = document.getElementById('resultSection');

  const charWithSpaces = document.getElementById('charWithSpaces');
  const charWithoutSpaces = document.getElementById('charWithoutSpaces');
  const wordCountEl = document.getElementById('wordCount');
  const lineCountEl = document.getElementById('lineCount');

  function countWords(text: string): number {
    const trimmed = text.trim();
    if (!trimmed) return 0;
    return trimmed.split(/\s+/).filter(Boolean).length;
  }

  function countLines(text: string): number {
    if (!text) return 0;
    return text.split(/\r\n|\r|\n/).length;
  }

  function updateLiveStats() {
    if (!textInput) return;
    const text = textInput.value;
    if (liveCharCount) liveCharCount.textContent = String(text.length);
    if (liveWordCount) liveWordCount.textContent = String(countWords(text));
    if (errorMessage && text.trim().length > 0) {
      errorMessage.hidden = true;
    }
    if (resultSection && !resultSection.hidden) {
      resultSection.hidden = true;
    }
  }

  function analyzeText() {
    if (!textInput) return;
    const text = textInput.value;

    if (!text.trim()) {
      if (errorMessage) errorMessage.hidden = false;
      if (resultSection) resultSection.hidden = true;
      textInput.focus();
      return;
    }

    if (errorMessage) errorMessage.hidden = true;

    const withSpaces = text.length;
    const withoutSpaces = text.replace(/\s/g, '').length;
    const words = countWords(text);
    const lines = countLines(text);

    if (charWithSpaces) charWithSpaces.textContent = withSpaces.toLocaleString('ko-KR');
    if (charWithoutSpaces) charWithoutSpaces.textContent = withoutSpaces.toLocaleString('ko-KR');
    if (wordCountEl) wordCountEl.textContent = words.toLocaleString('ko-KR');
    if (lineCountEl) lineCountEl.textContent = lines.toLocaleString('ko-KR');

    if (resultSection) {
      resultSection.hidden = false;
    }
  }

  function clearText() {
    if (!textInput) return;
    textInput.value = '';
    updateLiveStats();
    if (resultSection) resultSection.hidden = true;
    if (errorMessage) errorMessage.hidden = true;
    textInput.focus();
  }

  textInput?.addEventListener('input', updateLiveStats);
  analyzeBtn?.addEventListener('click', analyzeText);
  clearBtn?.addEventListener('click', clearText);

  updateLiveStats();
</script>