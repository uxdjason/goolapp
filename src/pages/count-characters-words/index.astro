---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "count-characters-words");
if (!entry) throw new Error("count-characters-words entry not found");
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));
if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="app-calc-layout">
      <div class="app-form-group">
        <label for="textInput" class="app-label">텍스트 입력</label>
        <textarea
          id="textInput"
          class="app-textarea"
          placeholder="여기에 텍스트를 입력하거나 붙여넣기 하세요."
          rows="10"></textarea>

        <div class="stats-container">
          <div class="live-stats">
            <div class="stat-item">
              <span class="stat-label">글자 수 (공백 포함)</span>
              <span class="stat-value"
                ><span id="charWithSpaces">0</span><span class="stat-unit"
                  >자</span
                ></span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">글자 수 (공백 제외)</span>
              <span class="stat-value"
                ><span id="charWithoutSpaces">0</span><span class="stat-unit"
                  >자</span
                ></span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">단어 수</span>
              <span class="stat-value"
                ><span id="wordCount">0</span><span class="stat-unit">개</span
                ></span
              >
            </div>
            <div class="stat-item">
              <span class="stat-label">문장 수</span>
              <span class="stat-value"
                ><span id="sentenceCount">0</span><span class="stat-unit"
                  >개</span
                ></span
              >
            </div>
          </div>
          <button
            type="button"
            class="app-btn app-btn-secondary clear-btn"
            id="clearBtn"
          >
            지우기
          </button>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  /* count-characters-words 특화 스타일 */
  .stats-container {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    align-items: stretch;
  }

  .live-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    flex: 1;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 0.5rem;
    background: var(--color-surface-container-low);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-outline-variant);
    text-align: center;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.4rem;
    font-family: var(--font-family-gothic);
  }

  .stat-value {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--color-primary);
    display: flex;
    align-items: baseline;
    gap: 0.15rem;
    font-family: var(--font-family-gothic);
  }

  .stat-unit {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-on-surface-variant);
  }

  .clear-btn {
    width: 80px;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 640px) {
    .stats-container {
      flex-direction: column;
    }
    .live-stats {
      grid-template-columns: repeat(2, 1fr);
    }
    .clear-btn {
      width: 100%;
      padding: 0.875rem;
    }
  }
</style>

<script>
  const textInput = document.getElementById(
    "textInput",
  ) as HTMLTextAreaElement | null;
  const clearBtn = document.getElementById("clearBtn");

  const charWithSpaces = document.getElementById("charWithSpaces");
  const charWithoutSpaces = document.getElementById("charWithoutSpaces");
  const wordCountEl = document.getElementById("wordCount");
  const sentenceCountEl = document.getElementById("sentenceCount");

  function countWords(text: string): number {
    const trimmed = text.trim();
    if (!trimmed) return 0;
    return trimmed.split(/\s+/).filter(Boolean).length;
  }

  function countSentences(text: string): number {
    if (!text) return 0;
    // 마침표(.), 물음표(?), 느낌표(!) 등 문장 종결 부호를 기준으로 문장 수 세기 (연속된 기호는 하나로 취급)
    const matches = text.match(/[.!?]+/g);
    return matches ? matches.length : 0;
  }

  function updateLiveStats() {
    if (!textInput) return;
    const text = textInput.value;

    const withSpaces = text.length;
    const withoutSpaces = text.replace(/\s/g, "").length;
    const words = countWords(text);
    const sentences = countSentences(text);

    if (charWithSpaces)
      charWithSpaces.textContent = withSpaces.toLocaleString("ko-KR");
    if (charWithoutSpaces)
      charWithoutSpaces.textContent = withoutSpaces.toLocaleString("ko-KR");
    if (wordCountEl) wordCountEl.textContent = words.toLocaleString("ko-KR");
    if (sentenceCountEl)
      sentenceCountEl.textContent = sentences.toLocaleString("ko-KR");
  }

  function clearText() {
    if (!textInput) return;
    textInput.value = "";
    updateLiveStats();
    textInput.focus();
  }

  textInput?.addEventListener("input", updateLiveStats);
  clearBtn?.addEventListener("click", clearText);

  updateLiveStats();
</script>
