---
import { getEntry, render, getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

const entry = await getEntry('apps', 'middle-school-english-synonyms-quiz');
if (!entry) throw new Error('middle-school-english-synonyms-quiz entry not found');
const { Content } = await render(entry);

const allApps = await getCollection('apps');
let related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
if (related.length === 0) {
  related = allApps
    .filter(app => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    {/*
      외부 리소스 안내:
      이 앱은 퀴즈 데이터를 로컬 경로(/data/english_synonym_middle_quiz_data.json)에서 불러온다.
      원본: https://goolapp.com/wp-content/json/english_synonym_middle_quiz_data.json
      이 파일을 다운로드하여 프로젝트의 public/data/ 디렉토리에 배치해야 한다.
    */}
    <div class="quiz-app">
      {/* 시작 화면 */}
      <section class="screen start-screen" id="start-screen">
        <h2 class="screen-title">중학교 영단어 동의어 퀴즈</h2>
        <p class="screen-desc">
          제시된 영단어와 같은 의미를 가진 단어를 4개의 선택지에서 골라보세요.
          중학교 수준의 영단어로 구성된 퀴즈입니다.
        </p>
        <button class="app-btn app-btn-primary" id="start-btn">시작하기</button>
      </section>

      {/* 로딩 화면 */}
      <section class="screen loading-screen" id="loading-screen" hidden>
        <div class="loading-spinner"></div>
        <p>문제를 불러오는 중...</p>
      </section>

      {/* 퀴즈 화면 */}
      <section class="screen quiz-screen" id="quiz-screen" hidden>
        <div class="progress-bar-wrap">
          <div class="progress-info">
            <span id="progress-text">문제 1 / 10</span>
            <span id="score-text">정답 0</span>
          </div>
          <div class="progress-bar">
            <div class="progress-bar-fill" id="progress-fill"></div>
          </div>
        </div>

        <div class="question-card">
          <p class="question-label">다음 단어의 동의어는?</p>
          <h3 class="question-text" id="question-text">—</h3>
        </div>

        <div class="choices" id="choices"></div>

        <p class="app-feedback" id="feedback"></p>

        <div class="quiz-actions">
          <button class="app-btn app-btn-primary" id="next-btn" hidden>다음 문제</button>
          <button class="app-btn app-btn-text" id="quit-btn">그만 하기</button>
        </div>
      </section>

      <section class="screen result-screen" id="result-screen" hidden>
        <h2 class="screen-title">퀴즈 결과</h2>
        <div class="result-score">
          <div class="score-circle">
            <span id="result-percent">0</span><small>점</small>
          </div>
        </div>
        <p class="result-detail">
          총 <strong id="result-total">0</strong>문제 중
          <strong id="result-correct">0</strong>문제 정답
        </p>
        <button class="app-btn app-btn-primary" id="restart-btn">처음으로</button>
      </section>

      <!-- 공통 경고 모달 -->
      <div id="app-alert-modal" class="app-modal-overlay" hidden>
        <div class="app-modal">
          <div class="app-modal-icon">⚠️</div>
          <p class="app-modal-title" id="app-alert-title">알림</p>
          <p class="app-modal-body" id="app-alert-message"></p>
          <div class="app-modal-actions">
            <button id="app-alert-confirm-btn" class="app-btn app-btn-primary">확인</button>
          </div>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .quiz-app {
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }

  .screen {
    background: var(--color-surface, #ffffff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
  }
  .screen[hidden] {
    display: none;
  }

  .start-screen,
  .loading-screen,
  .result-screen {
    text-align: center;
    align-items: center;
  }

  .screen-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text, #1f2937);
    margin: 0;
  }

  .screen-desc {
    color: var(--color-text-muted, #6b7280);
    line-height: 1.6;
    margin: 0;
  }

  /* 진행률 바 */
  .progress-bar-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .progress-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
    font-weight: 600;
  }
  .progress-bar {
    width: 100%;
    height: 8px;
    background: var(--color-border, #e5e7eb);
    border-radius: 999px;
    overflow: hidden;
  }
  .progress-bar-fill {
    height: 100%;
    background: var(--color-primary, #3b82f6);
    border-radius: 999px;
    width: 0%;
    transition: width 0.3s ease;
  }

  /* 문제 카드 */
  .question-card {
    background: var(--color-bg-soft, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    padding: 1.5rem 1rem;
    text-align: center;
  }
  .question-label {
    margin: 0 0 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted, #6b7280);
  }
  .question-text {
    font-size: 2rem;
    font-weight: 800;
    margin: 0;
    color: var(--color-primary, #3b82f6);
    letter-spacing: 0.05em;
  }

  /* 선택지 */
  .choices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  @media (max-width: 480px) {
    .choices {
      grid-template-columns: 1fr;
    }
  }

  .choices :global(.choice-btn) {
    width: 100%;
    padding: 1rem;
    background: var(--color-surface, #ffffff);
    border: 2px solid #d1d5db;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text, #1f2937);
    cursor: pointer;
    transition: all 0.15s ease;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    text-align: center;
  }
  .choices :global(.choice-btn:hover:not(:disabled)) {
    transform: translateY(-2px);
    border-color: var(--color-primary, #3b82f6);
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
  }
  .choices :global(.choice-btn:disabled) {
    cursor: not-allowed;
    opacity: 0.85;
  }
  .choices :global(.choice-btn.correct) {
    background: #d1fae5;
    border-color: #10b981;
    color: #065f46;
  }
  .choices :global(.choice-btn.wrong) {
    background: #fee2e2;
    border-color: #ef4444;
    color: #991b1b;
  }

  /* 피드백 */
  .feedback {
    text-align: center;
    font-weight: 700;
    font-size: 1rem;
    min-height: 1.5rem;
    margin: 0;
  }
  .feedback.correct {
    color: #10b981;
  }
  .feedback.wrong {
    color: #ef4444;
  }

  /* 액션 버튼 */
  .quiz-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .btn {
    display: inline-block;
    width: 100%;
    padding: 0.875rem 1.25rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: all 0.15s ease;
    font-family: inherit;
  }
  .btn[hidden] {
    display: none;
  }
  .btn-primary {
    background: var(--color-primary, #3b82f6);
    color: #ffffff;
  }
  .btn-primary:hover {
    filter: brightness(1.05);
    transform: translateY(-1px);
  }
  .btn-text {
    background: transparent;
    color: var(--color-text-muted, #6b7280);
    border: none;
    font-weight: 500;
    text-decoration: underline;
    padding: 0.5rem;
  }
  .btn-text:hover {
    color: var(--color-text, #1f2937);
  }

  /* 결과 화면 */
  .result-score {
    display: flex;
    justify-content: center;
    margin: 1rem 0;
  }
  .score-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: var(--color-primary, #3b82f6);
    color: #ffffff;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25rem;
    font-size: 2.75rem;
    font-weight: 800;
    box-shadow: 0 8px 24px rgba(59, 130, 246, 0.25);
  }
  .score-circle small {
    font-size: 1rem;
    font-weight: 600;
  }
  .result-detail {
    color: var(--color-text, #1f2937);
    font-size: 1rem;
    margin: 0;
  }
  .result-detail strong {
    color: var(--color-primary, #3b82f6);
    font-size: 1.125rem;
  }

  /* 로딩 스피너 */
  .loading-spinner {
    width: 40px;
    height: 40px;
    border: 4px solid var(--color-border, #e5e7eb);
    border-top-color: var(--color-primary, #3b82f6);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  // 외부 리소스 안내:
  // public/data/english_synonym_middle_quiz_data.json 파일이 필요하다.
  // 원본: https://goolapp.com/wp-content/json/english_synonym_middle_quiz_data.json
  const JSON_URL = '/data/english_synonym_middle_quiz_data.json';

  type QuizItem = { quiz: string; selection: string[]; answer: number };

  let quizData: QuizItem[] = [];
  let questionOrder: number[] = [];
  let currentIndex = 0;
  let correctCount = 0;
  let answered = false;

  const appAlertModal = document.getElementById('app-alert-modal') as HTMLElement;
  const appAlertMessage = document.getElementById('app-alert-message') as HTMLElement;
  const appAlertConfirmBtn = document.getElementById('app-alert-confirm-btn') as HTMLButtonElement;

  function showAlert(msg: string) {
    appAlertMessage.textContent = msg;
    appAlertModal.removeAttribute('hidden');
  }

  function hideAlert() {
    appAlertModal.setAttribute('hidden', '');
  }

  appAlertConfirmBtn?.addEventListener('click', hideAlert);
  appAlertModal?.addEventListener('click', (e) => {
    if (e.target === appAlertModal) hideAlert();
  });

  const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
    document.getElementById(id) as T | null;

  const startScreen = $('start-screen')!;
  const loadingScreen = $('loading-screen')!;
  const quizScreen = $('quiz-screen')!;
  const resultScreen = $('result-screen')!;

  const startBtn = $<HTMLButtonElement>('start-btn')!;
  const nextBtn = $<HTMLButtonElement>('next-btn')!;
  const quitBtn = $<HTMLButtonElement>('quit-btn')!;
  const restartBtn = $<HTMLButtonElement>('restart-btn')!;

  const questionText = $('question-text')!;
  const choicesEl = $('choices')!;
  const feedbackEl = $('feedback')!;
  const progressText = $('progress-text')!;
  const scoreText = $('score-text')!;
  const progressFill = $('progress-fill')!;

  const resultPercent = $('result-percent')!;
  const resultTotal = $('result-total')!;
  const resultCorrect = $('result-correct')!;

  function showScreen(screen: HTMLElement) {
    [startScreen, loadingScreen, quizScreen, resultScreen].forEach(s => {
      if (s === screen) s.removeAttribute('hidden');
      else s.setAttribute('hidden', '');
    });
  }

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  async function startQuiz() {
    showScreen(loadingScreen);
    try {
      if (quizData.length === 0) {
        const res = await fetch(JSON_URL);
        if (!res.ok) throw new Error('데이터를 불러올 수 없습니다.');
        quizData = await res.json();
      }
      questionOrder = shuffle(Array.from({ length: quizData.length }, (_, i) => i));
      currentIndex = 0;
      correctCount = 0;
      answered = false;
      showScreen(quizScreen);
      loadQuestion();
    } catch (err) {
      console.error(err);
      showAlert('문제를 불러오는 데 실패했습니다. 잠시 후 다시 시도해주세요.');
      showScreen(startScreen);
    }
  }

  function loadQuestion() {
    answered = false;
    feedbackEl.textContent = '';
    feedbackEl.className = 'app-feedback';
    nextBtn.setAttribute('hidden', '');

    const q = quizData[questionOrder[currentIndex]];
    questionText.textContent = q.quiz.toUpperCase();

    const total = questionOrder.length;
    progressText.textContent = `문제 ${currentIndex + 1} / ${total}`;
    scoreText.textContent = `정답 ${correctCount}`;
    progressFill.style.width = `${((currentIndex) / total) * 100}%`;

    choicesEl.innerHTML = '';
    q.selection.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = 'app-choice-btn';
      btn.type = 'button';
      btn.textContent = opt;
      btn.addEventListener('click', () => checkAnswer(i + 1, q.answer, btn));
      choicesEl.appendChild(btn);
    });
  }

  function checkAnswer(selected: number, correct: number, btn: HTMLButtonElement) {
    if (answered) return;
    answered = true;

    const buttons = Array.from(
      choicesEl.querySelectorAll('button')
    ) as HTMLButtonElement[];
    buttons.forEach(b => (b.disabled = true));

    const correctBtn = buttons[correct - 1];

    if (selected === correct) {
      btn.classList.add('correct');
      feedbackEl.textContent = '정답입니다! 🎉';
      feedbackEl.className = 'app-feedback correct';
      correctCount++;
    } else {
      btn.classList.add('wrong');
      if (correctBtn) correctBtn.classList.add('correct');
      feedbackEl.textContent = `오답입니다. 정답: ${correctBtn?.textContent ?? ''}`;
      feedbackEl.className = 'app-feedback wrong';
    }

    scoreText.textContent = `정답 ${correctCount}`;
    const total = questionOrder.length;
    progressFill.style.width = `${((currentIndex + 1) / total) * 100}%`;

    if (currentIndex >= questionOrder.length - 1) {
      setTimeout(showResult, 1500);
    } else {
      nextBtn.removeAttribute('hidden');
    }
  }

  function nextQuestion() {
    if (!answered) return;
    currentIndex++;
    if (currentIndex >= questionOrder.length) {
      showResult();
    } else {
      loadQuestion();
    }
  }

  function showResult() {
    const totalAttempted = answered ? currentIndex + 1 : currentIndex;
    const safeTotal = Math.max(totalAttempted, 1);
    const score = Math.round((correctCount / safeTotal) * 100);

    resultPercent.textContent = String(score);
    resultTotal.textContent = String(totalAttempted);
    resultCorrect.textContent = String(correctCount);

    showScreen(resultScreen);
  }

  function restartQuiz() {
    showScreen(startScreen);
  }

  startBtn.addEventListener('click', startQuiz);
  nextBtn.addEventListener('click', nextQuestion);
  quitBtn.addEventListener('click', showResult);
  restartBtn.addEventListener('click', restartQuiz);
</script>