---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "blood-type-compatibility");
if (!entry) throw new Error("blood-type-compatibility entry not found");
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));
if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="app-container">
      <section class="input-section">
        <div class="blood-picker">
          <h3 class="picker-title">나의 혈액형</h3>
          <div class="blood-options" data-target="type1">
            <button type="button" class="blood-btn" data-value="A">A형</button>
            <button type="button" class="blood-btn" data-value="B">B형</button>
            <button type="button" class="blood-btn" data-value="O">O형</button>
            <button type="button" class="blood-btn" data-value="AB">AB형</button
            >
          </div>
        </div>

        <div class="vs-divider">
          <span>💕</span>
        </div>

        <div class="blood-picker">
          <h3 class="picker-title">상대방의 혈액형</h3>
          <div class="blood-options" data-target="type2">
            <button type="button" class="blood-btn" data-value="A">A형</button>
            <button type="button" class="blood-btn" data-value="B">B형</button>
            <button type="button" class="blood-btn" data-value="O">O형</button>
            <button type="button" class="blood-btn" data-value="AB">AB형</button
            >
          </div>
        </div>

        <button type="button" id="calcBtn" class="calc-btn" disabled>
          궁합 보기
        </button>
      </section>

      <section class="result-section" id="resultSection" hidden>
        <div class="result-header">
          <div class="pair-display">
            <span class="pair-blood" id="pairType1">-</span>
            <span class="pair-heart">❤</span>
            <span class="pair-blood" id="pairType2">-</span>
          </div>
          <div class="grade-badge" id="gradeBadge">-</div>
          <div class="total-score">
            <span class="score-label">종합 연애 궁합</span>
            <span class="score-number" id="totalScore">0</span>
            <span class="score-unit">점</span>
          </div>
          <p class="summary-text" id="summaryText">-</p>
        </div>

        <div class="detail-cards">
          <div class="detail-card comm">
            <div class="detail-icon">💬</div>
            <div class="detail-title">대화 및 소통</div>
            <div class="detail-score" id="commScore">0점</div>
            <div class="detail-bar">
              <div class="detail-bar-fill" id="commBar"></div>
            </div>
            <p class="detail-comment" id="commComment">-</p>
          </div>

          <div class="detail-card friend">
            <div class="detail-icon">🤝</div>
            <div class="detail-title">우정 및 편안함</div>
            <div class="detail-score" id="friendScore">0점</div>
            <div class="detail-bar">
              <div class="detail-bar-fill" id="friendBar"></div>
            </div>
            <p class="detail-comment" id="friendComment">-</p>
          </div>

          <div class="detail-card work">
            <div class="detail-icon">💼</div>
            <div class="detail-title">업무 및 책임감</div>
            <div class="detail-score" id="workScore">0점</div>
            <div class="detail-bar">
              <div class="detail-bar-fill" id="workBar"></div>
            </div>
            <p class="detail-comment" id="workComment">-</p>
          </div>

          <div class="detail-card life">
            <div class="detail-icon">🌱</div>
            <div class="detail-title">라이프스타일</div>
            <div class="detail-score" id="lifeScore">0점</div>
            <div class="detail-bar">
              <div class="detail-bar-fill" id="lifeBar"></div>
            </div>
            <p class="detail-comment" id="lifeComment">-</p>
          </div>
        </div>

        <button type="button" id="resetBtn" class="reset-btn">
          다시 해보기
        </button>
      </section>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .app-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .blood-picker {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .picker-title {
    margin: 0;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text, #111827);
  }

  .blood-options {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }

  .blood-btn {
    padding: 0.85rem 0.5rem;
    background: #fff;
    border: 2px solid #d1d5db;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    cursor: pointer;
    transition: all 0.15s ease;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .blood-btn:hover {
    transform: translateY(-2px);
    border-color: var(--color-primary, #6366f1);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
  }

  .blood-btn.active {
    background: var(--color-primary, #6366f1);
    color: #fff;
    border-color: var(--color-primary, #6366f1);
    box-shadow: 0 4px 10px rgba(99, 102, 241, 0.25);
  }

  .vs-divider {
    text-align: center;
    font-size: 1.5rem;
    color: var(--color-text-muted, #6b7280);
  }

  .calc-btn {
    padding: 1rem;
    background: var(--color-primary, #6366f1);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .calc-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 6px 14px rgba(99, 102, 241, 0.3);
  }

  .calc-btn:disabled {
    background: #d1d5db;
    color: #6b7280;
    cursor: not-allowed;
  }

  .result-section {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    animation: fadeIn 0.3s ease;
  }

  .result-section[hidden] {
    display: none;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .result-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .pair-display {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
  }

  .pair-blood {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    height: 3rem;
    padding: 0 0.75rem;
    background: var(--color-primary, #6366f1);
    color: #fff;
    border-radius: 50%;
    font-size: 1.1rem;
  }

  .pair-heart {
    font-size: 1.5rem;
    color: #ef4444;
  }

  .grade-badge {
    display: inline-block;
    align-self: center;
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    background: #fef3c7;
    color: #92400e;
  }

  .grade-badge.grade-best {
    background: #fce7f3;
    color: #be185d;
  }
  .grade-badge.grade-good {
    background: #dcfce7;
    color: #166534;
  }
  .grade-badge.grade-normal {
    background: #fef3c7;
    color: #92400e;
  }
  .grade-badge.grade-warn {
    background: #fee2e2;
    color: #991b1b;
  }

  .total-score {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .score-label {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-muted, #6b7280);
  }

  .score-number {
    font-size: 4rem;
    font-weight: 800;
    color: var(--color-primary, #6366f1);
    line-height: 1;
  }

  .score-unit {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-muted, #6b7280);
    display: inline-block;
    transform: translateY(-0.5rem);
  }

  .summary-text {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text, #111827);
    line-height: 1.6;
    padding: 0 0.5rem;
  }

  .detail-cards {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .detail-card {
    background: #f9fafb;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 10px;
    padding: 1rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto auto;
    gap: 0.4rem 0.85rem;
    align-items: center;
  }

  .detail-icon {
    grid-row: 1 / 3;
    font-size: 1.75rem;
  }

  .detail-title {
    font-weight: 700;
    color: var(--color-text, #111827);
  }

  .detail-score {
    font-weight: 700;
    color: var(--color-primary, #6366f1);
  }

  .detail-bar {
    grid-column: 2 / 4;
    grid-row: 2;
    height: 8px;
    background: #e5e7eb;
    border-radius: 999px;
    overflow: hidden;
  }

  .detail-bar-fill {
    height: 100%;
    width: 0%;
    background: var(--color-primary, #6366f1);
    border-radius: 999px;
    transition: width 0.6s ease;
  }

  .detail-card.comm .detail-bar-fill {
    background: #f59e0b;
  }
  .detail-card.friend .detail-bar-fill {
    background: #10b981;
  }
  .detail-card.work .detail-bar-fill {
    background: #3b82f6;
  }
  .detail-card.life .detail-bar-fill {
    background: #8b5cf6;
  }

  .detail-comment {
    grid-column: 1 / 4;
    grid-row: 3;
    margin: 0.3rem 0 0;
    font-size: 0.9rem;
    color: var(--color-text-muted, #4b5563);
    line-height: 1.5;
  }

  .reset-btn {
    padding: 0.85rem;
    background: #fff;
    border: 2px solid var(--color-border, #e5e7eb);
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .reset-btn:hover {
    background: #f9fafb;
    border-color: #9ca3af;
  }

  @media (max-width: 480px) {
    .score-number {
      font-size: 3rem;
    }
    .pair-blood {
      min-width: 2.5rem;
      height: 2.5rem;
      font-size: 1rem;
    }
  }
</style>

<script>
  const compatibilityTable: Record<
    string,
    { comm: number; friend: number; work: number; life: number }
  > = {
