    "A-B": { comm: 55, friend: 60, work: 50, life: 60 },
    "A-O": { comm: 90, friend: 85, work: 80, life: 85 },
    "A-AB": { comm: 75, friend: 75, work: 75, life: 65 },
    "B-B": { comm: 65, friend: 70, work: 60, life: 75 },
    "B-O": { comm: 65, friend: 65, work: 55, life: 60 },
    "B-AB": { comm: 80, friend: 80, work: 75, life: 85 },
    "O-O": { comm: 90, friend: 90, work: 85, life: 90 },
