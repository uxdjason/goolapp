    "B-AB": {
      comm: "독특한 생각과 아이디어를 나누는 흥미로운 대화가 이어져요.",
      friend: "창의적이고 톡톡 튀는 우정을 나눌 수 있어요.",
      work: "틀을 깨는 독창적인 결과물을 만들어낼 수 있어요.",
      life: "서로의 독특한 취향을 가장 잘 이해해주는 관계예요.",
      summary: "개성 넘치는 두 사람이 만나 특별한 케미를 만들어요.",
    },
    "O-O": {
      comm: "서로 너무 솔직해서 가끔은 불꽃 튀는 토론이 벌어지기도 해요.",
      friend: "의리와 신뢰로 뭉친 뜨겁고 든든한 우정이에요.",
      work: "추진력 최고! 목표를 향해 함께 달려가요.",
      life: "스케일이 크고 적극적으로 삶을 즐기는 멋진 파트너예요.",
      summary: "뜨겁고 강렬한 에너지가 오가는 최고의 조합이에요.",
    },
    "O-AB": {
      comm: "감성적인 O형과 이성적인 AB형, 대화의 접근 방식이 달라요.",
      friend: "서로 자신에게 없는 매력을 보며 배울 점이 많은 관계예요.",
      work: "실행력(O)과 전략(AB)이 잘 어우러지는 팀이에요.",
      life: "라이프스타일의 차이를 대화로 잘 조율해야 해요.",
      summary: "서로 다른 매력이 잘 어울리는 조합이에요.",
    },
    "AB-AB": {
      comm: "말하지 않아도 서로의 생각을 잘 읽는 텔레파시가 통하곤 해요.",
      friend: "지적인 교류가 즐거운 친구 관계예요.",
      work: "전략적 사고가 뛰어나고 감정에 치우치지 않는 파트너예요.",
      life: "프라이버시를 완벽히 존중하는 쿨하고 세련된 라이프를 즐겨요.",
      summary: "서로를 잘 이해하는 지적인 조합이에요.",
    },
  };

  const orderMap: Record<string, number> = { A: 1, B: 2, O: 3, AB: 4 };
  function getKey(t1: string, t2: string): string {
    const sorted = [t1, t2].sort((a, b) => orderMap[a] - orderMap[b]);
    return sorted[0] + "-" + sorted[1];
  }

  function getGrade(total: number): { text: string; className: string } {
    if (total >= 85) return { text: "💖 최고의 궁합", className: "grade-best" };
    if (total >= 70) return { text: "😊 좋은 궁합", className: "grade-good" };
    if (total >= 55)
      return { text: "🙂 보통의 궁합", className: "grade-normal" };
    return { text: "⚠ 주의가 필요한 궁합", className: "grade-warn" };
  }

  const state: { type1: string | null; type2: string | null } = {
    type1: null,
    type2: null,
  };

  const groups = document.querySelectorAll<HTMLElement>(".blood-options");
  const calcBtn = document.getElementById("calcBtn") as HTMLButtonElement;
  const resultSection = document.getElementById("resultSection") as HTMLElement;
  const resetBtn = document.getElementById("resetBtn") as HTMLButtonElement;

  groups.forEach((group) => {
    const target = group.dataset.target as "type1" | "type2";
    group.querySelectorAll<HTMLButtonElement>(".blood-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        group
          .querySelectorAll(".blood-btn")
          .forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        state[target] = btn.dataset.value || null;
        updateCalcBtn();
        // 사용자가 선택을 변경하면 이전 결과를 숨깁니다
        resultSection.hidden = true;
      });
    });
  });

  function updateCalcBtn() {
    calcBtn.disabled = !(state.type1 && state.type2);
  }

  calcBtn.addEventListener("click", () => {
    if (!state.type1 || !state.type2) return;
    const key = getKey(state.type1, state.type2);
    const scores = compatibilityTable[key];
    const comments = commentMap[key];
    if (!scores || !comments) return;

    const total = Math.round(
      (scores.comm + scores.friend + scores.work + scores.life) / 4,
    );
    const grade = getGrade(total);

    (document.getElementById("pairType1") as HTMLElement).textContent =
      state.type1 + "형";
    (document.getElementById("pairType2") as HTMLElement).textContent =
      state.type2 + "형";
    (document.getElementById("totalScore") as HTMLElement).textContent =
      String(total);

    const gradeBadge = document.getElementById("gradeBadge") as HTMLElement;
    gradeBadge.textContent = grade.text;
    gradeBadge.className = "grade-badge " + grade.className;

    (document.getElementById("summaryText") as HTMLElement).textContent =
      comments.summary;

    (document.getElementById("commScore") as HTMLElement).textContent =
      scores.comm + "점";
    (document.getElementById("friendScore") as HTMLElement).textContent =
      scores.friend + "점";
    (document.getElementById("workScore") as HTMLElement).textContent =
      scores.work + "점";
    (document.getElementById("lifeScore") as HTMLElement).textContent =
      scores.life + "점";

    (document.getElementById("commComment") as HTMLElement).textContent =
      comments.comm;
    (document.getElementById("friendComment") as HTMLElement).textContent =
      comments.friend;
    (document.getElementById("workComment") as HTMLElement).textContent =
      comments.work;
    (document.getElementById("lifeComment") as HTMLElement).textContent =
      comments.life;

    resultSection.hidden = false;

    requestAnimationFrame(() => {
      (document.getElementById("commBar") as HTMLElement).style.width =
        scores.comm + "%";
      (document.getElementById("friendBar") as HTMLElement).style.width =
        scores.friend + "%";
      (document.getElementById("workBar") as HTMLElement).style.width =
        scores.work + "%";
      (document.getElementById("lifeBar") as HTMLElement).style.width =
        scores.life + "%";
    });

    resultSection.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  resetBtn.addEventListener("click", () => {
    state.type1 = null;
    state.type2 = null;
    document
      .querySelectorAll(".blood-btn")
      .forEach((b) => b.classList.remove("active"));
    updateCalcBtn();
    resultSection.hidden = true;
    ["commBar", "friendBar", "workBar", "lifeBar"].forEach((id) => {
      (document.getElementById(id) as HTMLElement).style.width = "0%";
    });
    window.scrollTo({ top: 0, behavior: "smooth" });
  });
</script>
