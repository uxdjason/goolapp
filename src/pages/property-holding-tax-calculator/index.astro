---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "property-holding-tax-calculator");
if (!entry) throw new Error("property-holding-tax-calculator entry not found");
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));
if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="calc-wrapper">
      <div class="calc-card">
        <div class="form-group">
          <label for="market-price">주택 실거래가 (만원)</label>
          <input
            type="number"
            id="market-price"
            placeholder="예: 100000"
            min="0"
          />
          <div class="price-hint" id="market-hint"></div>
        </div>

        <div class="form-group">
          <label for="declared-price">공시가격 (만원, 선택 입력)</label>
          <input
            type="number"
            id="declared-price"
            placeholder="비워두면 실거래가의 72%로 추정"
            min="0"
          />
          <div class="price-hint" id="declared-hint">숫자를 입력하면 한국어로 표시됩니다.</div>
        </div>

        <div class="form-group">
          <label for="house-type">주택 유형</label>
          <select id="house-type">
            <option value="apartment">아파트</option>
            <option value="detached">단독주택</option>
            <option value="etc">기타</option>
          </select>
        </div>

        <div class="form-group">
          <label>보유 주택 수</label>
          <div class="radio-row">
            <label class="radio-pill"
              ><input type="radio" name="house-count" value="1" checked /><span
                >1주택</span
              ></label
            >
            <label class="radio-pill"
              ><input type="radio" name="house-count" value="2" /><span
                >2주택</span
              ></label
            >
            <label class="radio-pill"
              ><input type="radio" name="house-count" value="3" /><span
                >3주택 이상</span
              ></label
            >
          </div>
        </div>

        <div class="form-group">
          <label>주택 소재지 (조정대상지역 여부)</label>
          <div class="radio-row">
            <label class="radio-pill"
              ><input type="radio" name="regulated" value="no" checked /><span
                >일반지역</span
              ></label
            >
            <label class="radio-pill"
              ><input type="radio" name="regulated" value="yes" /><span
                >조정대상지역</span
              ></label
            >
          </div>
        </div>

        <div id="err-msg" class="error-msg" hidden></div>

        <div class="btn-row">
          <button type="button" id="calc-btn" class="btn-primary"
            >보유세 계산하기</button
          >
        </div>
      </div>

      <div id="result-section" class="result-section" hidden>
        <h2 class="result-title">📊 예상 보유세 계산 결과</h2>

        <div class="result-total">
          <span class="total-label">연간 보유세 합계</span>
          <span class="total-value" id="total-tax">-</span>
        </div>

        <div class="result-grid">
          <div class="result-group">
            <h3>공시가격 기준</h3>
            <div class="result-row">
              <span>추정 공시가격</span><b id="est-declared">-</b>
            </div>
          </div>

          <div class="result-group">
            <h3>재산세</h3>
            <div class="result-row">
              <span>과세표준</span><b id="prop-base">-</b>
            </div>
            <div class="result-row">
              <span>재산세 본세</span><b id="prop-tax">-</b>
            </div>
            <div class="result-row">
              <span>지방교육세</span><b id="edu-tax">-</b>
            </div>
          </div>

          <div class="result-group">
            <h3>종합부동산세</h3>
            <div class="result-row">
              <span>과세표준</span><b id="comp-base">-</b>
            </div>
            <div class="result-row">
              <span>종부세 본세</span><b id="comp-tax">-</b>
            </div>
            <div class="result-row">
              <span>농어촌특별세</span><b id="rural-tax">-</b>
            </div>
          </div>
        </div>

        <p class="disclaimer">
          ※ 본 계산 결과는 개략적인 추정치이며, 실제 부과되는 세액은 지자체 및
          국세청의 확정 공시가격, 세부 감면 요건, 세부담 상한 등에 따라 달라질
          수 있습니다.
        </p>

        <button type="button" id="reset-btn" class="btn-reset">↩ 다시 하기</button>
      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .calc-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .calc-card {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .form-group small {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .form-group input[type="number"],
  .form-group select {
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-size: 1rem;
    background: var(--color-background);
    color: var(--color-text);
    width: 100%;
    box-sizing: border-box;
  }

  .form-group input[type="number"]:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
  }

  .radio-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .radio-pill {
    position: relative;
    cursor: pointer;
    flex: 1 1 auto;
    min-width: 90px;
  }

  .radio-pill input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .radio-pill span {
    display: block;
    text-align: center;
    padding: 0.6rem 0.8rem;
    border: 2px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-background);
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.15s ease;
  }

  .radio-pill input[type="radio"]:checked + span {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }

  .error-msg {
    background: #fef2f2;
    color: #b91c1c;
    padding: 0.7rem 0.9rem;
    border-radius: 8px;
    font-size: 0.9rem;
    border: 1px solid #fecaca;
  }

  .error-msg[hidden] {
    display: none;
  }

  .btn-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .btn-primary {
    width: 100%;
    padding: 0.9rem 1rem;
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      transform 0.15s ease,
      opacity 0.15s ease;
  }

  .btn-primary:hover {
    transform: translateY(-1px);
    opacity: 0.95;
  }

  .btn-text {
    width: 100%;
    padding: 0.7rem 1rem;
    background: transparent;
    color: var(--color-text-muted);
    border: none;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .btn-text:hover {
    color: var(--color-text);
  }

  .result-section {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .result-section[hidden] {
    display: none;
  }

  .result-title {
    margin: 0;
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .result-total {
    background: var(--color-primary);
    color: #fff;
    border-radius: 10px;
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: center;
  }

  .total-label {
    font-size: 0.9rem;
    opacity: 0.9;
  }

  .total-value {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .result-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .result-group {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1rem;
    background: var(--color-background);
  }

  .result-group h3 {
    margin: 0 0 0.7rem 0;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .result-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0;
    font-size: 0.95rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .result-row:last-child {
    border-bottom: none;
  }

  .result-row b {
    color: var(--color-text);
    font-weight: 600;
  }

  .disclaimer {
    margin: 0;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    padding: 0.7rem;
    background: var(--color-background);
    border-radius: 6px;
  }

  .price-hint {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    min-height: 1.2em;
  }

  .btn-reset {
    padding: 0.75rem 1.2rem;
    background: transparent;
    color: var(--color-text-muted);
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    align-self: center;
    transition:
      background 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .btn-reset:hover {
    background: var(--color-background);
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  @media (min-width: 640px) {
    .result-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
    .result-group:first-child {
      grid-column: 1 / -1;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const marketEl = document.getElementById(
      "market-price",
    ) as HTMLInputElement | null;
    const declaredEl = document.getElementById(
      "declared-price",
    ) as HTMLInputElement | null;
    const typeEl = document.getElementById(
      "house-type",
    ) as HTMLSelectElement | null;
    const calcBtn = document.getElementById("calc-btn");
    const resetBtn = document.getElementById("reset-btn");
    const errMsg = document.getElementById("err-msg");
    const resultSection = document.getElementById("result-section");
    const marketHint = document.getElementById("market-hint") as HTMLElement | null;
    const declaredHint = document.getElementById("declared-hint") as HTMLElement | null;

    const estDeclared = document.getElementById("est-declared");
    const propBase = document.getElementById("prop-base");
    const propTax = document.getElementById("prop-tax");
    const eduTax = document.getElementById("edu-tax");
    const compBase = document.getElementById("comp-base");
    const compTax = document.getElementById("comp-tax");
    const ruralTax = document.getElementById("rural-tax");
    const totalTax = document.getElementById("total-tax");

    // 만원 입력 → 한국어 표시
    function formatManwonHint(manwon: number): string {
      if (!manwon || manwon <= 0) return "";
      const won = Math.round(manwon * 10000);
      const eok = Math.floor(won / 100000000);
      const man = Math.floor((won % 100000000) / 10000);
      const parts: string[] = [];
      if (eok > 0) parts.push(eok.toLocaleString("ko-KR") + "억");
      if (man > 0) parts.push(man.toLocaleString("ko-KR") + "만");
      if (parts.length === 0) parts.push(won.toLocaleString("ko-KR"));
      return parts.join(" ") + "원";
    }

    function updateHints() {
      if (marketHint) marketHint.textContent = formatManwonHint(parseFloat(marketEl?.value || ""));
      if (declaredHint) declaredHint.textContent = formatManwonHint(parseFloat(declaredEl?.value || ""));
    }

    function formatWon(manwon: number): string {
      // manwon 단위 → 원 단위 변환 후 표시
      const won = Math.round(manwon * 10000);
      if (won >= 100000000) {
        const eok = won / 100000000;
        return (
          eok.toLocaleString("ko-KR", { maximumFractionDigits: 2 }) + "억원"
        );
      }
      if (won >= 10000) {
        return Math.round(won / 10000).toLocaleString("ko-KR") + "만원";
      }
      return won.toLocaleString("ko-KR") + "원";
    }

    function showError(msg: string) {
      if (!errMsg) return;
      errMsg.textContent = msg;
      errMsg.hidden = false;
    }

    function hideError() {
      if (!errMsg) return;
      errMsg.hidden = true;
    }

    function hideResult() {
      if (resultSection) resultSection.hidden = true;
    }

    // 재산세 누진세율 (과세표준 기준, 만원 단위)
    // 6천만 이하: 0.1%
    // 6천~1억5천: 6만 + 6천 초과 × 0.15%
    // 1억5천~3억: 19.5만 + 1억5천 초과 × 0.25%
    // 3억 초과: 57만 + 3억 초과 × 0.4%
    function calcPropertyTax(baseManwon: number): number {
      // baseManwon: 만원 단위 과세표준
      if (baseManwon <= 6000) return baseManwon * 0.001;
      if (baseManwon <= 15000) return 6 + (baseManwon - 6000) * 0.0015;
      if (baseManwon <= 30000) return 19.5 + (baseManwon - 15000) * 0.0025;
      return 57 + (baseManwon - 30000) * 0.004;
    }

    // 종부세 세율표 (과세표준 기준, 만원 단위)
    // 일반(1주택 또는 2주택 비조정):
    //  3억 이하 0.5%, 6억 이하 0.7%, 12억 이하 1.0%, 25억 이하 1.3%, 50억 이하 1.5%, 94억 이하 2.0%, 초과 2.7%
    // 다주택(3주택 이상 or 조정대상 2주택):
    //  3억 이하 0.5%, 6억 이하 0.7%, 12억 이하 1.0%, 25억 이하 2.0%, 50억 이하 3.0%, 94억 이하 4.0%, 초과 5.0%
    function calcCompTax(baseManwon: number, multi: boolean): number {
      if (baseManwon <= 0) return 0;
      const brackets = multi
        ? [
            { limit: 30000, rate: 0.005, acc: 0 },
            { limit: 60000, rate: 0.007, acc: 150 },
            { limit: 120000, rate: 0.01, acc: 360 },
            { limit: 250000, rate: 0.02, acc: 960 },
            { limit: 500000, rate: 0.03, acc: 3560 },
            { limit: 940000, rate: 0.04, acc: 11060 },
            { limit: Infinity, rate: 0.05, acc: 28660 },
          ]
        : [
            { limit: 30000, rate: 0.005, acc: 0 },
            { limit: 60000, rate: 0.007, acc: 150 },
            { limit: 120000, rate: 0.01, acc: 360 },
            { limit: 250000, rate: 0.013, acc: 960 },
            { limit: 500000, rate: 0.015, acc: 4335 },
            { limit: 940000, rate: 0.02, acc: 8085 },
            { limit: Infinity, rate: 0.027, acc: 16885 },
          ];

      let prevLimit = 0;
      for (const b of brackets) {
        if (baseManwon <= b.limit) {
          return b.acc + (baseManwon - prevLimit) * b.rate;
        }
        prevLimit = b.limit;
      }
      return 0;
    }

    function calculate() {
      hideError();

      if (!marketEl) return;
      const market = parseFloat(marketEl.value);
      if (!market || market <= 0) {
        showError("주택 실거래가를 올바르게 입력해주세요.");
        if (resultSection) resultSection.hidden = true;
        return;
      }

      // 공시가격 (만원)
      let declared =
        declaredEl && declaredEl.value ? parseFloat(declaredEl.value) : 0;
      if (!declared || declared <= 0) {
        declared = market * 0.72;
      }

      // 주택 수, 조정지역
      const countInput = document.querySelector<HTMLInputElement>(
        'input[name="house-count"]:checked',
      );
      const regInput = document.querySelector<HTMLInputElement>(
        'input[name="regulated"]:checked',
      );
      const count = countInput ? countInput.value : "1";
      const regulated = regInput ? regInput.value === "yes" : false;

      // 다주택 판정 (종부세 중과)
      const isMulti = count === "3" || (count === "2" && regulated);

      // 재산세 과세표준 = 공시가 × 60%
      const propBaseManwon = declared * 0.6;
      const propertyTaxManwon = calcPropertyTax(propBaseManwon);
      // 지방교육세 = 재산세 × 20%
      const eduTaxManwon = propertyTaxManwon * 0.2;

      // 종부세 공제액 (만원 단위)
      // 1주택: 12억 (120,000만원)
      // 다주택: 9억 (90,000만원)
      const deduction = count === "1" ? 120000 : 90000;
      const compBaseRaw = Math.max(0, declared - deduction) * 0.6;
      const compTaxManwon = calcCompTax(compBaseRaw, isMulti);
      // 농어촌특별세 = 종부세 × 20%
      const ruralTaxManwon = compTaxManwon * 0.2;

      const totalManwon =
        propertyTaxManwon + eduTaxManwon + compTaxManwon + ruralTaxManwon;

      // 출력
      if (estDeclared) estDeclared.textContent = formatWon(declared);
      if (propBase) propBase.textContent = formatWon(propBaseManwon);
      if (propTax) propTax.textContent = formatWon(propertyTaxManwon);
      if (eduTax) eduTax.textContent = formatWon(eduTaxManwon);
      if (compBase) compBase.textContent = formatWon(compBaseRaw);
      if (compTax) compTax.textContent = formatWon(compTaxManwon);
      if (ruralTax) ruralTax.textContent = formatWon(ruralTaxManwon);
      if (totalTax) totalTax.textContent = formatWon(totalManwon);

      if (resultSection) {
        resultSection.hidden = false;
        resultSection.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    }

    function reset() {
      // 1) 스크롤 먼저 — 레이아웃 변경 전 위치 계산
      window.scrollTo({ top: 250, behavior: "smooth" });
      // 2) 400ms 후 입력값 초기화 & 결과 숨김
      setTimeout(function () {
        hideError();
        if (marketEl) marketEl.value = "";
        if (declaredEl) declaredEl.value = "";
        if (typeEl) typeEl.value = "apartment";
        const firstCount = document.querySelector<HTMLInputElement>(
          'input[name="house-count"][value="1"]',
        );
        if (firstCount) firstCount.checked = true;
        const firstReg = document.querySelector<HTMLInputElement>(
          'input[name="regulated"][value="no"]',
        );
        if (firstReg) firstReg.checked = true;
        // hint 리셋
        if (marketHint) marketHint.textContent = formatManwonHint(parseFloat(marketEl?.value || ""));
        if (declaredHint) declaredHint.textContent = formatManwonHint(parseFloat(declaredEl?.value || ""));
        hideResult();
      }, 400);
    }

    // 입력값 변경 시 결과 자동 숨김
    [marketEl, declaredEl].forEach((el) => {
      if (!el) return;
      el.addEventListener("input", function () {
        hideResult();
        updateHints();
      });
    });
    if (typeEl) typeEl.addEventListener("change", hideResult);
    document.querySelectorAll('input[name="house-count"], input[name="regulated"]').forEach((el) => {
      el.addEventListener("change", hideResult);
    });

    // 포커스 시 값 초기화 방해 방지 — placeholder만 사용하고 기본값 없음
    [marketEl, declaredEl].forEach((el) => {
      if (!el) return;
      el.addEventListener("focus", function () {
        if (el.value === "0") el.value = "";
      });
    });

    if (calcBtn) calcBtn.addEventListener("click", calculate);
    if (resetBtn) resetBtn.addEventListener("click", reset);
  });
</script>
