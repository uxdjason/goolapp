---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCard from '../../components/AppCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import SearchBar from '../../components/SearchBar.astro';

export async function getStaticPaths() {
  const categories = ['calculator', 'datetime', 'tool', 'quiz', 'fun', 'finance'];
  return categories.map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;
const allApps = await getCollection('apps', ({ data }) =>
  !data.draft && data.category.includes(category as any)
);
const sortedApps = allApps.sort((a, b) =>
  b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// Match Top Nav menu names exactly
const categoryLabels: Record<string, string> = {
  calculator: '각종 계산기',
  datetime:   '날짜와 시간',
  tool:       '편리한 도구들',
  quiz:       '학습 및 퀴즈',
  fun:        '심심풀이 Fun',
  finance:    '금융 재테크',
};
const label = categoryLabels[category ?? ''] ?? category;

---

<BaseLayout
  title={`${label} | GoolAPP`}
  description={`${label} 카테고리의 모든 유용한 앱들을 만나보세요.`}
>
  <!-- ── Hero: Centered and simplified per design ── -->
  <section class="hero-section">
    <div class="hero-container">
      <h1 class="hero-title">{label}</h1>
      
      <!-- Search bar -->
      <SearchBar placeholder={`${label} 내에서 검색`} />
    </div>
  </section>

  <section class="apps-section">
    <div class="container">
      <CategoryNav activeCategory={category} />
      
      <div class="app-grid">
        {sortedApps.length > 0 ? (
          sortedApps.map(app => (
            <AppCard
              title={app.data.title}
              shortDescription={app.data.shortDescription}
              slug={app.data.slug}
              category={app.data.category}
            />
          ))
        ) : (
          <div class="empty-state glass-surface">
            <p>아직 이 카테고리에 등록된 앱이 없습니다.</p>
          </div>
        )}
      </div>

      <div id="favorites-empty-state" class="empty-state glass-surface" style="display: none;">
        <p>등록된 즐겨찾는 앱이 없습니다.</p>
      </div>

      <div class="load-more-wrap" style="display: none;">
        <button class="load-more-btn">더 꺼내기</button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section: Centered layout matching index.astro */
  .hero-section {
    text-align: center;
    padding: 80px 0 64px;
  }
  .hero-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-title {
    font-family: var(--font-family-base);
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1b1c1a;
    margin-bottom: 32px;
  }



  /* App grid and load more */
  .apps-section { padding-bottom: var(--space-16); }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }
  .empty-state {
    grid-column: 1 / -1;
    padding: var(--space-16);
    text-align: center;
    color: var(--color-on-surface-variant);
  }
  .load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 8px;
  }
  .load-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 52px;
    background: rgba(251, 249, 245, 0.6);
    border: 1px solid var(--color-primary);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 9999px;
    font-family: var(--font-family-gothic);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-primary);
    cursor: pointer;
    box-shadow: 0px 0px 15px rgba(139, 79, 50, 0.15);
  }

  @media (max-width: 1024px) { .app-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px)  {
    .hero-title { font-size: 1.75rem; }
    .app-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
