---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCard from '../../components/AppCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';

export async function getStaticPaths() {
  const categories = ['calculator', 'datetime', 'tool', 'quiz', 'fun', 'finance'];
  return categories.map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;
const allApps = await getCollection('apps', ({ data }) =>
  !data.draft && data.category === category
);
const sortedApps = allApps.sort((a, b) =>
  b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// Match Top Nav menu names exactly
const categoryLabels: Record<string, string> = {
  calculator: '각종 계산기',
  datetime:   '날짜와 시간',
  tool:       '편리한 도구들',
  quiz:       '학습 및 퀴즈',
  fun:        '심심풀이 Fun',
  finance:    '금융 재테크',
};
const label = categoryLabels[category ?? ''] ?? category;

// Logic for "Load More" button
const initialLimit = 9;
const showLoadMore = sortedApps.length > initialLimit;
---

<BaseLayout
  title={`${label} | GoolAPP`}
  description={`${label} 카테고리의 모든 유용한 앱들을 만나보세요.`}
>
  <!-- ── Hero: Centered and simplified per design ── -->
  <section class="hero-section">
    <div class="hero-container">
      <h1 class="hero-title">{label}</h1>
      
      <!-- Search bar added to category page -->
      <div class="search-bar" role="search">
        <div class="search-icon-wrap" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8B4F32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <input
          type="search"
          class="search-input"
          placeholder={`${label} 내에서 검색`}
          aria-label="앱 검색"
          disabled
        />
        <button class="search-btn" disabled>찾기</button>
      </div>
    </div>
  </section>

  <section class="apps-section">
    <div class="container">
      <CategoryNav activeCategory={category} />
      
      <div class="app-grid">
        {sortedApps.length > 0 ? (
          sortedApps.map(app => (
            <AppCard
              title={app.data.title}
              shortDescription={app.data.shortDescription}
              slug={app.data.slug}
              category={app.data.category}
            />
          ))
        ) : (
          <div class="empty-state glass-surface">
            <p>아직 이 카테고리에 등록된 앱이 없습니다.</p>
          </div>
        )}
      </div>

      {showLoadMore && (
        <div class="load-more-wrap">
          <button class="load-more-btn">더 꺼내기</button>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section: Centered layout matching index.astro */
  .hero-section {
    text-align: center;
    padding: 80px 0 64px;
  }
  .hero-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero-title {
    font-family: var(--font-family-base);
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #1b1c1a;
    margin-bottom: 32px;
  }

  /* Search bar styles (reused from index.astro for consistency) */
  .search-bar {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 672px;
    height: 72px;
    padding: 8px;
    background: rgba(245, 243, 239, 0.5);
    border: 1px solid rgba(216, 194, 185, 0.5);
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-radius: 9999px;
    box-sizing: border-box;
  }
  .search-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }
  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-family-gothic);
    font-size: 18px;
    font-weight: 400;
    color: rgba(83, 67, 61, 0.8);
    padding: 0 12px;
    min-width: 0;
  }
  .search-btn {
    flex-shrink: 0;
    padding: 12px 24px;
    height: 48px;
    background: var(--color-primary);
    color: #ffffff;
    border: none;
    border-radius: 9999px;
    font-family: var(--font-family-gothic);
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
  }

  /* App grid and load more */
  .apps-section { padding-bottom: var(--space-16); }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }
  .empty-state {
    grid-column: 1 / -1;
    padding: var(--space-16);
    text-align: center;
    color: var(--color-on-surface-variant);
  }
  .load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 8px;
  }
  .load-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 52px;
    background: rgba(251, 249, 245, 0.6);
    border: 1px solid var(--color-primary);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 9999px;
    font-family: var(--font-family-gothic);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-primary);
    cursor: pointer;
    box-shadow: 0px 0px 15px rgba(139, 79, 50, 0.15);
  }

  @media (max-width: 1024px) { .app-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px)  {
    .hero-title { font-size: 2rem; }
    .search-bar { height: auto; }
    .app-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
