---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCard from '../../components/AppCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';

export async function getStaticPaths() {
  const categories = ['calculator', 'quiz', 'converter', 'tool', 'misc'];
  return categories.map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;
const allApps = await getCollection('apps', ({ data }) =>
  !data.draft && data.category === category
);
const sortedApps = allApps.sort((a, b) =>
  b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const categoryLabels: Record<string, string> = {
  calculator: '계산기', quiz: '퀴즈', converter: '변환기', tool: '유틸리티', misc: '기타',
};
const label = categoryLabels[category ?? ''] ?? category;
---

<BaseLayout
  title={`${label} 앱 모음 | GoolAPP`}
  description={`${label} 카테고리의 무료 유틸리티 앱들을 한 곳에서 편리하게 사용해 보세요.`}
>
  <section class="cat-header">
    <div class="container">
      <h1>{label}</h1>
      <p class="cat-subtitle">{label} 카테고리의 모든 앱 목록입니다.</p>
    </div>
  </section>

  <section class="apps-section">
    <div class="container">
      <CategoryNav activeCategory={category} />
      <div class="app-grid">
        {sortedApps.length > 0 ? (
          sortedApps.map(app => (
            <AppCard
              title={app.data.title}
              shortDescription={app.data.shortDescription}
              slug={app.data.slug}
              category={app.data.category}
            />
          ))
        ) : (
          <div class="empty-state glass-surface">
            <p>아직 이 카테고리에 등록된 앱이 없습니다.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cat-header { padding: var(--space-12) 0 var(--space-6); }
  .cat-subtitle { color: var(--color-on-surface-variant); margin: 0; }

  .apps-section { padding-bottom: var(--space-20); }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }
  .empty-state {
    grid-column: 1 / -1;
    padding: var(--space-16);
    text-align: center;
    color: var(--color-on-surface-variant);
  }

  @media (max-width: 1024px) { .app-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px)  { .app-grid { grid-template-columns: 1fr; } }
</style>
