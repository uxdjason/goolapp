---
import { getEntry, render, getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

const entry = await getEntry('apps', 'timer-app');
if (!entry) {
  throw new Error("timer-app app entry not found");
}
const { Content } = await render(entry);

const allApps = await getCollection('apps');
let related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({
    title:            app.data.title,
    shortDescription: app.data.shortDescription,
    slug:             app.data.slug,
    category:         app.data.category,
  }));

if (related.length === 0) {
  related = allApps
    .filter(app => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map(app => ({
      title:            app.data.title,
      shortDescription: app.data.shortDescription,
      slug:             app.data.slug,
      category:         app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
>
  <Fragment slot="app">
    <div class="calculator-container glass-surface">
      <div class="header">
        <h2 class="label-caps" style="color: var(--color-primary); font-size: var(--font-size-sm); margin-bottom: var(--space-2);">날짜와 시간</h2>
        <h3 style="font-size: var(--font-size-2xl); margin-bottom: var(--space-2); color: var(--color-on-surface);">타이머 및 스톱워치</h3>
        <p>간편하게 시간을 측정하고 관리해 보세요.</p>
      </div>

      <!-- Tab Navigation -->
      <div class="app-tab-nav">
        <button class="app-tab-btn active" data-target="countdown">카운트다운</button>
        <button class="app-tab-btn" data-target="stopwatch">스톱워치</button>
      </div>

      <!-- Countdown View -->
      <div id="countdown-view" class="app-view">
        <div class="state-label" id="cd-state-label" style="visibility: hidden;">남은 시간</div>
        
        <div class="input-section glass-surface-card" id="cd-inputs">
          <div class="time-inputs">
            <div class="time-input-group">
              <input type="number" id="cd-h" placeholder="0" min="0" max="99">
              <span>시간</span>
            </div>
            <div class="colon">:</div>
            <div class="time-input-group">
              <input type="number" id="cd-m" placeholder="0" min="0" max="59">
              <span>분</span>
            </div>
            <div class="colon">:</div>
            <div class="time-input-group">
              <input type="number" id="cd-s" placeholder="0" min="0" max="59">
              <span>초</span>
            </div>
          </div>
        </div>

        <div class="controls">
          <button class="app-btn app-btn-secondary" id="cd-reset">초기화</button>
          <button class="app-btn app-btn-primary" id="cd-start">시작</button>
          <button class="app-btn app-btn-danger" id="cd-stop" style="display:none;">정지</button>
        </div>
      </div>

      <!-- Stopwatch View -->
      <div id="stopwatch-view" class="app-view" style="display:none;">
        <div class="state-label">진행 시간</div>
        <div class="time-display sw-text" id="sw-display">00:00:00.00</div>
        
        <div class="controls">
          <button class="app-btn app-btn-secondary" id="sw-reset">초기화</button>
          <button class="app-btn app-btn-secondary" id="sw-lap" style="display:none;">구간 기록</button>
          <button class="app-btn app-btn-primary" id="sw-start">시작</button>
          <button class="app-btn app-btn-danger" id="sw-stop" style="display:none;">정지</button>
        </div>

        <div class="lap-container glass-surface-card" id="lap-container" style="display:none;">
          <ul id="lap-list" class="lap-list"></ul>
        </div>
      </div>

      <!-- 공통 경고 모달 -->
      <div id="app-alert-modal" class="app-modal-overlay" hidden>
        <div class="app-modal">
          <div class="app-modal-icon">⚠️</div>
          <p class="app-modal-title" id="app-alert-title">알림</p>
          <p class="app-modal-body" id="app-alert-message"></p>
          <div class="app-modal-actions">
            <button id="app-alert-confirm-btn" class="app-btn app-btn-primary">확인</button>
          </div>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <div class="prose">
      <Content />
    </div>
    {related.length > 0 && <RelatedApps apps={related} />}
  </Fragment>
</AppLayout>

<style>
  .calculator-container {
    padding: var(--space-8);
    width: 100%;
    box-sizing: border-box;
    margin: var(--space-8) auto;
  }
  .header {
    text-align: center;
    border-bottom: 1px solid var(--glass-border-soft);
    padding-bottom: var(--space-5);
    margin-bottom: var(--space-6);
  }
  .header p {
    margin: 0;
    color: var(--color-on-surface-variant);
    font-size: var(--font-size-base);
  }

  .app-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: fadeIn var(--transition-base);
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .state-label {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface-variant);
    margin-bottom: -var(--space-4);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: var(--space-4);
  }

  .time-display {
    font-size: 64px;
    font-weight: var(--font-weight-bold);
    font-family: var(--font-family-base);
    margin: var(--space-6) 0;
    text-align: center;
    font-variant-numeric: tabular-nums;
    letter-spacing: 2px;
  }

  .cd-text {
    color: var(--color-primary);
  }

  .sw-text {
    color: var(--color-on-surface);
  }

  .glass-surface-card {
    background: var(--color-surface);
    border: 1px solid var(--glass-border-soft);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    width: 100%;
    box-sizing: border-box;
    margin-bottom: var(--space-6);
  }

  .time-inputs {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-3);
  }

  .time-input-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
  }

  .time-input-group input {
    width: 80px;
    height: 80px;
    font-size: 32px;
    text-align: center;
    border: 1px solid var(--glass-border-soft);
    background: var(--glass-bg-input);
    border-radius: var(--radius-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface);
    transition: var(--transition-fast);
  }

  .time-input-group input:focus {
    outline: none;
    border-color: var(--color-primary);
  }
  
  .time-input-group input:focus::placeholder {
    color: transparent;
  }

  .time-input-group input:disabled {
    background: transparent;
    color: var(--color-primary);
    border-color: transparent;
    -webkit-text-fill-color: var(--color-primary);
    opacity: 1;
    box-shadow: none;
  }
  
  .time-input-group span {
    font-size: var(--font-size-sm);
    color: var(--color-on-surface-variant);
    font-weight: var(--font-weight-bold);
  }

  .colon {
    font-size: 32px;
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface-variant);
    margin-bottom: 28px; /* align with input center */
  }

  .controls {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    margin-top: var(--space-2);
    width: 100%;
  }

  .btn {
    padding: 0 var(--space-6);
    height: 56px;
    border: none;
    border-radius: var(--radius-full);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-base);
    cursor: pointer;
    transition: var(--transition-fast);
    flex: 1;
    max-width: 200px;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-on-primary);
  }
  .btn-primary:hover {
    filter: brightness(0.9);
  }

  .btn-secondary {
    background: var(--glass-bg-input);
    color: var(--color-on-surface);
    border: 1px solid var(--glass-border-soft);
  }
  .btn-secondary:hover {
    background: var(--color-surface);
  }

  .btn-danger {
    background: #FF5252;
    color: white;
  }
  .btn-danger:hover {
    background: #FF1744;
  }

  .lap-container {
    margin-top: var(--space-6);
    max-height: 250px;
    overflow-y: auto;
    padding: var(--space-4) var(--space-6);
  }

  .lap-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  :global(.lap-item) {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--glass-border-soft);
    color: var(--color-on-surface);
    font-family: var(--font-family-base);
    font-variant-numeric: tabular-nums;
    width: 100%;
    font-size: var(--font-size-lg);
  }
  :global(.lap-item:last-child) {
    border-bottom: none;
  }

  /* Custom Scrollbar for lap container */
  .lap-container::-webkit-scrollbar {
    width: 8px;
  }
  .lap-container::-webkit-scrollbar-track {
    background: transparent;
  }
  .lap-container::-webkit-scrollbar-thumb {
    background: var(--glass-border-soft);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .calculator-container { padding: var(--space-5); }
    .time-display { font-size: 48px; }
    .time-input-group input { width: 60px; height: 60px; font-size: 24px; }
    .colon { font-size: 24px; margin-bottom: 24px; }
    .btn { height: 48px; }
    .controls { flex-wrap: wrap; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const appAlertModal = document.getElementById('app-alert-modal');
    const appAlertMessage = document.getElementById('app-alert-message');
    const appAlertConfirmBtn = document.getElementById('app-alert-confirm-btn');

    function showAlert(msg) {
      appAlertMessage.textContent = msg;
      appAlertModal.removeAttribute('hidden');
    }

    function hideAlert() {
      appAlertModal.setAttribute('hidden', '');
    }

    if (appAlertConfirmBtn) appAlertConfirmBtn.addEventListener('click', hideAlert);
    if (appAlertModal) appAlertModal.addEventListener('click', (e) => {
      if (e.target === appAlertModal) hideAlert();
    });

    let mode = 'countdown'; // 'countdown' or 'stopwatch'
    const tabBtns = document.querySelectorAll('.app-tab-btn');
    const cdView = document.getElementById('countdown-view');
    const swView = document.getElementById('stopwatch-view');

    // Countdown elements
    const cdStateLabel = document.getElementById('cd-state-label');
    const cdH = document.getElementById('cd-h');
    const cdM = document.getElementById('cd-m');
    const cdS = document.getElementById('cd-s');
    const cdStartBtn = document.getElementById('cd-start');
    const cdStopBtn = document.getElementById('cd-stop');
    const cdResetBtn = document.getElementById('cd-reset');

    // Stopwatch elements
    const swDisplay = document.getElementById('sw-display');
    const swStartBtn = document.getElementById('sw-start');
    const swStopBtn = document.getElementById('sw-stop');
    const swResetBtn = document.getElementById('sw-reset');
    const swLapBtn = document.getElementById('sw-lap');
    const lapContainer = document.getElementById('lap-container');
    const lapList = document.getElementById('lap-list');

    // State
    let cdTimer = null;
    let cdTotalSeconds = 0;
    let cdRemaining = 0;
    let cdIsRunning = false;

    let swTimer = null;
    let swStartTime = 0;
    let swElapsedTime = 0;
    let swIsRunning = false;
    let swLaps = [];

    // Audio for timer finish
    let alarmSound = null;
    try {
      alarmSound = new Audio('https://goolapp.com/wp-content/uploads/2023/12/alarm.mp3'); // Fallback or could use local asset
    } catch(e) {}

    function playAlarm() {
      if(alarmSound) {
        alarmSound.currentTime = 0;
        alarmSound.play().catch(() => console.log('Audio play blocked'));
      }
    }

    function formatStopwatchTime(ms) {
      const totalDeciSeconds = Math.floor(ms / 10);
      const h = Math.floor(totalDeciSeconds / 360000);
      const m = Math.floor((totalDeciSeconds % 360000) / 6000);
      const s = Math.floor((totalDeciSeconds % 6000) / 100);
      const ds = totalDeciSeconds % 100;

      if (h > 0) {
        return `${h.toString().padStart(2, '0')}:${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}.${ds.toString().padStart(2, '0')}`;
      }
      return `${m.toString().padStart(2, '0')}:${s.toString().padStart(2, '0')}.${ds.toString().padStart(2, '0')}`;
    }

    // Tab Switching
    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        tabBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        mode = btn.dataset.target;
        
        if (mode === 'countdown') {
          cdView.style.display = 'flex';
          swView.style.display = 'none';
        } else {
          cdView.style.display = 'none';
          swView.style.display = 'flex';
        }
      });
    });

    // === Countdown Logic ===
    function updateCdDisplay() {
      if (cdIsRunning || cdRemaining > 0) {
        const h = Math.floor(cdRemaining / 3600);
        const m = Math.floor((cdRemaining % 3600) / 60);
        const s = cdRemaining % 60;
        
        cdH.value = h > 0 ? h : '0';
        cdM.value = m > 0 || h > 0 ? m : '0';
        cdS.value = s;
      }
    }

    function parseCdInputs() {
      const h = parseInt(cdH.value) || 0;
      const m = parseInt(cdM.value) || 0;
      const s = parseInt(cdS.value) || 0;
      return h * 3600 + m * 60 + s;
    }

    cdStartBtn.addEventListener('click', () => {
      if (!cdIsRunning) {
        if (cdRemaining === 0) {
          cdTotalSeconds = parseCdInputs();
          cdRemaining = cdTotalSeconds;
        }
        
        if (cdRemaining > 0) {
          cdIsRunning = true;
          [cdH, cdM, cdS].forEach(el => el.disabled = true);
          cdStateLabel.style.visibility = 'visible';
          
          cdStartBtn.style.display = 'none';
          cdStopBtn.style.display = 'block';
          
          cdTimer = setInterval(() => {
            cdRemaining--;
            updateCdDisplay();
            
            if (cdRemaining <= 0) {
              clearInterval(cdTimer);
              cdIsRunning = false;
              cdStartBtn.style.display = 'block';
              cdStopBtn.style.display = 'none';
              playAlarm();
              showAlert("타이머가 종료되었습니다!");
            }
          }, 1000);
        }
      }
    });

    cdStopBtn.addEventListener('click', () => {
      if (cdIsRunning) {
        clearInterval(cdTimer);
        cdIsRunning = false;
        cdStartBtn.style.display = 'block';
        cdStartBtn.textContent = '계속';
        cdStopBtn.style.display = 'none';
      }
    });

    cdResetBtn.addEventListener('click', () => {
      clearInterval(cdTimer);
      cdIsRunning = false;
      cdRemaining = 0;
      cdTotalSeconds = 0;
      
      [cdH, cdM, cdS].forEach(el => el.disabled = false);
      cdStateLabel.style.visibility = 'hidden';
      
      cdStartBtn.style.display = 'block';
      cdStartBtn.textContent = '시작';
      cdStopBtn.style.display = 'none';
      
      cdH.value = '';
      cdM.value = '';
      cdS.value = '';
    });


    // === Stopwatch Logic ===
    function updateSwDisplay() {
      swDisplay.textContent = formatStopwatchTime(swElapsedTime);
    }

    function renderLaps() {
      lapList.innerHTML = '';
      if (swLaps.length > 0) {
        lapContainer.style.display = 'block';
        swLaps.slice().reverse().forEach((lap, idx) => {
          const originalIndex = swLaps.length - 1 - idx;

          const li = document.createElement('li');
          li.className = 'lap-item';
          li.textContent = `${originalIndex + 1} - ${formatStopwatchTime(lap)}`;
          lapList.appendChild(li);
        });
      } else {
        lapContainer.style.display = 'none';
      }
    }

    swStartBtn.addEventListener('click', () => {
      if (!swIsRunning) {
        swIsRunning = true;
        swStartTime = Date.now() - swElapsedTime;
        
        swStartBtn.style.display = 'none';
        swStopBtn.style.display = 'block';
        swResetBtn.style.display = 'none';
        swLapBtn.style.display = 'block';
        
        swTimer = setInterval(() => {
          swElapsedTime = Date.now() - swStartTime;
          updateSwDisplay();
        }, 10);
      }
    });

    swStopBtn.addEventListener('click', () => {
      if (swIsRunning) {
        swIsRunning = false;
        clearInterval(swTimer);
        
        swStartBtn.style.display = 'block';
        swStartBtn.textContent = '계속';
        swStopBtn.style.display = 'none';
        swResetBtn.style.display = 'block';
        swLapBtn.style.display = 'none';
      }
    });

    swLapBtn.addEventListener('click', () => {
      if (swIsRunning) {
        swLaps.push(swElapsedTime);
        renderLaps();
      }
    });

    swResetBtn.addEventListener('click', () => {
      swIsRunning = false;
      clearInterval(swTimer);
      swElapsedTime = 0;
      swLaps = [];
      updateSwDisplay();
      renderLaps();
      
      swStartBtn.style.display = 'block';
      swStartBtn.textContent = '시작';
      swStopBtn.style.display = 'none';
      swResetBtn.style.display = 'block';
      swLapBtn.style.display = 'none';
    });

    // Better input focus logic
    [cdH, cdM, cdS].forEach(input => {
      input.addEventListener('focus', function() {
        if (this.value === '0' || this.value === '00') {
          this.value = '';
        } else {
          this.select();
        }
      });
      input.addEventListener('blur', function() {
        if (this.value === '') {
          this.value = ''; // Leave it blank, placeholder '0' will show
        }
      });
    });

    // Initialization
    updateCdDisplay();
    updateSwDisplay();
  });
</script>
