  const screen1 = document.getElementById("screen1") as HTMLElement;
  const screen2 = document.getElementById("screen2") as HTMLElement;
  const screen3 = document.getElementById("screen3") as HTMLElement;
  const menuImage = document.getElementById("menuImage") as HTMLImageElement;
  const menuEmoji = document.getElementById("menuEmoji") as HTMLElement;
  const menuResult = document.getElementById("menuResult") as HTMLElement;
  const startBtn = document.getElementById("startBtn");
  const retryBtn = document.getElementById("retryBtn");
  const resetBtn = document.getElementById("resetBtn");

  let lastMenu = "";

  function showOnly(target: HTMLElement) {
    [screen1, screen2, screen3].forEach((s) => {
      if (s === target) s.removeAttribute("hidden");
      else s.setAttribute("hidden", "");
    });
  }

  function pickRandomMenu() {
    let candidate = menus[Math.floor(Math.random() * menus.length)];
    // 직전 메뉴와 중복 회피 (1회 재추첨)
    if (candidate === lastMenu && menus.length > 1) {
      candidate = menus[Math.floor(Math.random() * menus.length)];
    }
    lastMenu = candidate;
    menuResult.innerText = candidate;

    if (menuImage && menuEmoji) {
      menuImage.src = `/images/lunch-menu-picker/${candidate}.webp`;
      menuImage.hidden = false;
      menuEmoji.hidden = true;

      // 이미지 로드 실패시(혹시 파일이 누락된 경우) 이모지로 폴백
      menuImage.onerror = () => {
        menuImage.hidden = true;
        menuEmoji.hidden = false;
      };
    }

    showOnly(screen3);
  }

  function goToAnimation() {
    showOnly(screen2);
    setTimeout(pickRandomMenu, 1500);
  }

  function resetApp() {
    showOnly(screen1);
  }

  startBtn?.addEventListener("click", goToAnimation);
  retryBtn?.addEventListener("click", goToAnimation);
  resetBtn?.addEventListener("click", resetApp);
</script>
