---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "lunch-menu-picker");
if (!entry) throw new Error("lunch-menu-picker entry not found");
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));
if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="app-calc-layout" style="max-width: 560px; margin: 0 auto;">
      <!-- Screen 1: 초기화면 -->
      <section id="screen1" class="screen screen-initial">
        <div class="emoji" aria-hidden="true">🍱</div>
        <h2 class="screen-title">오늘 점심, 뭐 먹지?</h2>
        <p class="screen-desc">
          고민하지 말고 버튼을 눌러보세요.<br />200가지 메뉴 중 하나를
          골라드려요.
        </p>
        <button
          type="button"
          id="startBtn"
          class="app-btn app-btn-primary"
          style="width: 100%;">메뉴 정하기</button
        >
      </section>

      <!-- Screen 2: 스피너 -->
      <section id="screen2" class="screen screen-loading" hidden>
        <div class="spinner" aria-hidden="true"></div>
        <p class="loading-text">메뉴 고르는 중...</p>
      </section>

      <!-- Screen 3: 결과 -->
      <section id="screen3" class="screen screen-result" hidden>
        <p class="result-label">오늘의 추천 메뉴</p>
        <div class="result-box">
          <img
            id="menuImage"
            src=""
            alt="Menu Image"
            class="result-image"
            hidden
          />
          <span id="menuEmoji" class="result-emoji" aria-hidden="true">🍽️</span>
          <p id="menuResult" class="result-menu"></p>
        </div>
        <div class="result-actions">
          <button
            type="button"
            id="retryBtn"
            class="app-btn app-btn-primary"
            style="width: 100%;">메뉴 다시 정하기</button
          >
          <button
            type="button"
            id="resetBtn"
            class="app-btn app-btn-text"
            style="width: 100%;">처음으로</button
          >
        </div>
      </section>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  <style>
  /* lunch-menu-picker 특화 스타일 */
  .screen {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-outline-variant);
    box-shadow: var(--shadow-sm);
    min-height: 340px;
    font-family: var(--font-family-gothic);
  }

  .screen[hidden] {
    display: none;
  }

  .emoji {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .screen-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-on-surface);
    margin: 0 0 0.75rem;
  }

  .screen-desc {
    font-size: 1rem;
    color: var(--color-on-surface-variant);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  /* 스피너 */
  .spinner {
    width: 64px;
    height: 64px;
    border: 5px solid var(--color-outline-variant);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.9s linear infinite;
    margin-bottom: 1.5rem;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .loading-text {
    font-size: 1.05rem;
    color: var(--color-on-surface-variant);
    margin: 0;
    font-family: var(--font-family-gothic);
  }

  /* 결과 */
  .result-label {
    font-size: 0.95rem;
    color: var(--color-on-surface-variant);
    margin: 0 0 1rem;
    letter-spacing: 0.02em;
  }

  .result-box {
    width: 100%;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-primary) 8%, transparent),
      color-mix(in srgb, var(--color-primary) 2%, transparent)
    );
    border: 2px dashed var(--color-primary);
    border-radius: var(--radius-lg);
    padding: 2rem 1rem;
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .result-emoji {
    display: block;
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .result-emoji[hidden] {
    display: none;
  }

  .result-image {
    width: 140px;
    height: 140px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .result-image[hidden] {
    display: none;
  }

  .result-menu {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
    word-break: keep-all;
  }

  .result-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  @media (max-width: 480px) {
    .screen {
      padding: 2rem 1rem;
      min-height: 300px;
    }
    .screen-title {
      font-size: 1.3rem;
    }
    .result-menu {
      font-size: 1.5rem;
    }
    .emoji {
      font-size: 3.25rem;
    }
  }
</style>

