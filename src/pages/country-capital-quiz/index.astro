---
import { getEntry, render, getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

const entry = await getEntry('apps', 'country-capital-quiz');
if (!entry) throw new Error('country-capital-quiz entry not found');
const { Content } = await render(entry);

const allApps = await getCollection('apps');
let related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
if (related.length === 0) {
  related = allApps
    .filter(app => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="quiz-container">
      <!-- 시작 화면 -->
      <section id="start-screen" class="screen">
        <div class="intro">
          <div class="intro-icon" aria-hidden="true">🌍</div>
          <h2 class="intro-title">세계 수도 퀴즈</h2>
          <p class="intro-desc">전 세계 나라의 수도를 얼마나 알고 있나요?<br/>4지선다 퀴즈로 실력을 확인해보세요!</p>
        </div>
        <button id="start-btn" class="app-btn app-btn-primary app-btn-lg" type="button">시작하기</button>
      </section>

      <!-- 퀴즈 화면 -->
      <section id="quiz-screen" class="screen" hidden>
        <div class="progress-bar">
          <div class="progress-info">
            <span id="progress-text">문제 1</span>
            <span id="score-text">정답: 0</span>
          </div>
          <div class="progress-track">
            <div id="progress-fill" class="progress-fill"></div>
          </div>
        </div>

        <div class="question-card">
          <p class="question-label">다음 나라의 수도는?</p>
          <h3 id="question-text" class="question-text"></h3>
        </div>

        <div id="choices" class="choices"></div>

        <div id="feedback" class="app-feedback" hidden></div>

        <div class="quiz-actions">
          <button id="next-btn" class="app-btn app-btn-primary" type="button" hidden>다음 문제</button>
          <button id="quit-btn" class="app-btn app-btn-text" type="button">그만하기</button>
        </div>
      </section>

      <!-- 결과 화면 -->
      <section id="result-screen" class="screen" hidden>
        <div class="result">
          <div id="result-icon" class="result-icon" aria-hidden="true">🏆</div>
          <h2 class="result-title">퀴즈 결과</h2>
          <div class="result-score">
            <div class="score-percent"><span id="score-percent">0</span>%</div>
            <p class="score-detail">총 <span id="total-count">0</span>문제 중 <span id="correct-count">0</span>문제 정답</p>
          </div>
          <p id="result-comment" class="result-comment"></p>
          <button id="restart-btn" class="app-btn app-btn-primary app-btn-lg" type="button">처음으로</button>
        </div>
      </section>

      <!-- 로딩 -->
      <div id="loading" class="loading" hidden>
        <div class="spinner"></div>
        <p>퀴즈 데이터를 불러오는 중...</p>
      </div>

      <!-- 에러 -->
      <div id="error-box" class="error-box" hidden>
        <p>퀴즈 데이터를 불러올 수 없습니다. 다시 시도해 주세요.</p>
        <button id="retry-btn" class="app-btn app-btn-primary" type="button">다시 시도</button>
      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .quiz-container {
    width: 100%;
    max-width: 640px;
    margin: 0 auto;
  }

  .screen {
    display: block;
    animation: fadeIn 0.3s ease;
  }
  .screen[hidden] { display: none; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* 시작 화면 */
  .intro {
    text-align: center;
    padding: 2rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: 1.5rem;
  }
  .intro-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
  }
  .intro-title {
    font-size: 1.6rem;
    margin: 0 0 0.75rem;
    color: var(--color-text);
  }
  .intro-desc {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* 진행 상태 */
  .progress-bar {
    margin-bottom: 1.25rem;
  }
  .progress-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  .progress-track {
    height: 8px;
    background: var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--color-primary);
    width: 0%;
    transition: width 0.3s ease;
    border-radius: 999px;
  }

  /* 문제 카드 */
  .question-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 1.25rem;
    text-align: center;
    margin-bottom: 1.25rem;
  }
  .question-label {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
  }
  .question-text {
    font-size: 1.8rem;
    margin: 0;
    color: var(--color-text);
    font-weight: 700;
  }

  /* 선택지 */
  .choices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 480px) {
    .choices { grid-template-columns: 1fr; }
  }

  :global(.choice-btn) {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1rem;
    background: var(--color-surface);
    border: 2px solid #d1d5db;
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    text-align: left;
    transition: all 0.2s ease;
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }
  :global(.choice-btn:hover:not(:disabled)) {
    border-color: var(--color-primary);
    background: var(--color-surface);
    transform: translateY(-2px);
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }
  :global(.choice-btn:disabled) {
    cursor: not-allowed;
    opacity: 0.85;
  }
  :global(.choice-num) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: var(--color-border);
    color: var(--color-text);
    border-radius: 50%;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  :global(.choice-btn.correct) {
    border-color: #16a34a;
    background: #dcfce7;
    color: #14532d;
  }
  :global(.choice-btn.correct .choice-num) {
    background: #16a34a;
    color: #fff;
  }
  :global(.choice-btn.wrong) {
    border-color: #dc2626;
    background: #fee2e2;
    color: #7f1d1d;
  }
  :global(.choice-btn.wrong .choice-num) {
    background: #dc2626;
    color: #fff;
  }

  /* 피드백 */
  .feedback {
    padding: 0.9rem 1rem;
    border-radius: var(--radius-md);
    text-align: center;
    font-weight: 600;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }
  .feedback[hidden] { display: none; }
  .feedback.correct {
    background: #dcfce7;
    color: #14532d;
    border: 1px solid #16a34a;
  }
  .feedback.wrong {
    background: #fee2e2;
    color: #7f1d1d;
    border: 1px solid #dc2626;
  }

  /* 액션 버튼 */
  .quiz-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .quiz-actions .btn {
    width: 100%;
  }

  .btn {
    padding: 0.85rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.18s ease;
    font-family: inherit;
  }
  .btn[hidden] { display: none; }
  .btn-primary {
    background: var(--color-primary);
    color: #fff;
    border-color: var(--color-primary);
  }
  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
  .btn-outline {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .btn-outline:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
  .btn-text {
    background: transparent;
    color: var(--color-text-muted);
    border-color: transparent;
  }
  .btn-text:hover {
    color: var(--color-text);
    background: rgba(0, 0, 0, 0.05);
  }
  .btn-large {
    width: 100%;
    padding: 1rem 1.5rem;
    font-size: 1.1rem;
  }

  /* 결과 */
  .result {
    text-align: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.25rem;
  }
  .result-icon {
    font-size: 4.5rem;
    margin-bottom: 0.75rem;
  }
  .result-title {
    font-size: 1.5rem;
    margin: 0 0 1.5rem;
    color: var(--color-text);
  }
  .result-score {
    background: var(--color-bg, var(--color-surface));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem 1rem;
    margin-bottom: 1.25rem;
  }
  .score-percent {
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: 0.5rem;
  }
  .score-detail {
    color: var(--color-text-muted);
    margin: 0;
    font-size: 0.95rem;
  }
  .result-comment {
    font-size: 1.05rem;
    color: var(--color-text);
    margin: 0 0 1.5rem;
    font-weight: 500;
  }

  /* 로딩 */
  .loading {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-text-muted);
  }
  .loading[hidden] { display: none; }
  .spinner {
    width: 44px;
    height: 44px;
    margin: 0 auto 1rem;
    border: 4px solid var(--color-border);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* 에러 */
  .error-box {
    text-align: center;
    padding: 2rem 1rem;
    background: #fee2e2;
    border: 1px solid #dc2626;
    border-radius: var(--radius-md);
    color: #7f1d1d;
  }
  .error-box[hidden] { display: none; }
  .error-box p { margin: 0 0 1rem; }
</style>

<script>
  interface QuizItem {
    quiz: string;
    selection: string[];
    answer: number;
  }

  const JSON_URL = '/data/country_capital.json';

  let quizData: QuizItem[] = [];
  let questionOrder: number[] = [];
  let currentIndex = 0;
  let correctCount = 0;
  let answered = false;
  let isLastQuestion = false;

  const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

  const startScreen = $('start-screen');
  const quizScreen = $('quiz-screen');
  const resultScreen = $('result-screen');
  const loading = $('loading');
  const errorBox = $('error-box');

  const startBtn = $<HTMLButtonElement>('start-btn');
  const nextBtn = $<HTMLButtonElement>('next-btn');
  const quitBtn = $<HTMLButtonElement>('quit-btn');
  const restartBtn = $<HTMLButtonElement>('restart-btn');
  const retryBtn = $<HTMLButtonElement>('retry-btn');

  const questionText = $('question-text');
  const choicesEl = $('choices');
  const feedbackEl = $('feedback');
  const progressText = $('progress-text');
  const scoreText = $('score-text');
  const progressFill = $('progress-fill');

  function showScreen(name: 'start' | 'quiz' | 'result' | 'loading' | 'error') {
    startScreen.hidden = name !== 'start';
    quizScreen.hidden = name !== 'quiz';
    resultScreen.hidden = name !== 'result';
    loading.hidden = name !== 'loading';
    errorBox.hidden = name !== 'error';
  }

  function shuffle<T>(array: T[]): T[] {
    const arr = [...array];
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  async function startQuiz() {
    if (quizData.length === 0) {
      showScreen('loading');
      try {
        const res = await fetch(JSON_URL);
        if (!res.ok) throw new Error('fetch failed');
        quizData = await res.json();
      } catch (e) {
        showScreen('error');
        return;
      }
    }
    questionOrder = shuffle(quizData.map((_, i) => i));
    currentIndex = 0;
    correctCount = 0;
    answered = false;
    isLastQuestion = false;
    showScreen('quiz');
    loadQuestion();
  }

  function loadQuestion() {
    answered = false;
    isLastQuestion = currentIndex === questionOrder.length - 1;

    const q = quizData[questionOrder[currentIndex]];
    questionText.textContent = q.quiz;

    progressText.textContent = `문제 ${currentIndex + 1} / ${questionOrder.length}`;
    scoreText.textContent = `정답: ${correctCount}`;
    progressFill.style.width = `${((currentIndex) / questionOrder.length) * 100}%`;

    feedbackEl.hidden = true;
    feedbackEl.className = 'app-feedback';
    feedbackEl.textContent = '';
    nextBtn.hidden = true;

    choicesEl.innerHTML = '';
    q.selection.forEach((choice, i) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'app-choice-btn';
      btn.innerHTML = `<span class="choice-num">${i + 1}</span><span>${choice}</span>`;
      btn.addEventListener('click', () => checkAnswer(i + 1, q.answer, q.selection[q.answer - 1], btn));
      choicesEl.appendChild(btn);
    });
  }

  function checkAnswer(selected: number, correct: number, answerText: string, clickedBtn: HTMLButtonElement) {
    if (answered) return;
    answered = true;

    const allBtns = choicesEl.querySelectorAll<HTMLButtonElement>('.app-choice-btn');
    allBtns.forEach((b, idx) => {
      b.disabled = true;
      if (idx + 1 === correct) b.classList.add('correct');
    });

    if (selected === correct) {
      correctCount++;
      feedbackEl.textContent = '🎉 정답입니다!';
      feedbackEl.classList.add('correct');
    } else {
      clickedBtn.classList.add('wrong');
      feedbackEl.textContent = `❌ 오답입니다. 정답: ${answerText}`;
      feedbackEl.classList.add('wrong');
    }
    feedbackEl.hidden = false;

    scoreText.textContent = `정답: ${correctCount}`;
    progressFill.style.width = `${((currentIndex + 1) / questionOrder.length) * 100}%`;

    if (!isLastQuestion) {
      nextBtn.hidden = false;
      nextBtn.textContent = '다음 문제';
    } else {
      nextBtn.hidden = false;
      nextBtn.textContent = '결과 보기';
    }
  }

  function nextQuestion() {
    if (!answered) return;
    if (isLastQuestion) {
      showResult(questionOrder.length);
      return;
    }
    currentIndex++;
    loadQuestion();
  }

  function showResult(totalAnswered: number) {
    const score = totalAnswered > 0 ? Math.round((correctCount / totalAnswered) * 100) : 0;
    $('score-percent').textContent = String(score);
    $('total-count').textContent = String(totalAnswered);
    $('correct-count').textContent = String(correctCount);

    let comment = '';
    let icon = '🏆';
    if (score === 100) { comment = '완벽해요! 세계 수도 박사님이군요!'; icon = '🏆'; }
    else if (score >= 80) { comment = '훌륭해요! 정말 잘 아시네요.'; icon = '🥇'; }
    else if (score >= 60) { comment = '잘했어요! 조금만 더 공부해 봐요.'; icon = '🥈'; }
    else if (score >= 40) { comment = '괜찮아요. 다시 도전해 보세요!'; icon = '🥉'; }
    else { comment = '아쉬워요. 더 연습하면 잘할 수 있어요!'; icon = '📚'; }

    $('result-comment').textContent = comment;
    $('result-icon').textContent = icon;
    showScreen('result');
  }

  function quitQuiz() {
    const totalAnswered = answered ? currentIndex + 1 : currentIndex;
    if (totalAnswered === 0) {
      showScreen('start');
      return;
    }
    showResult(totalAnswered);
  }

  function restartQuiz() {
    currentIndex = 0;
    correctCount = 0;
    answered = false;
    showScreen('start');
  }

  startBtn.addEventListener('click', startQuiz);
  nextBtn.addEventListener('click', nextQuestion);
  quitBtn.addEventListener('click', quitQuiz);
  restartBtn.addEventListener('click', restartQuiz);
  retryBtn.addEventListener('click', startQuiz);
</script>