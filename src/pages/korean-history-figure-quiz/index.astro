---
import { getEntry, render, getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

const entry = await getEntry('apps', 'korean-history-figure-quiz');
if (!entry) throw new Error('korean-history-figure-quiz entry not found');
const { Content } = await render(entry);

const allApps = await getCollection('apps');
let related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
if (related.length === 0) {
  related = allApps
    .filter(app => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    {/*
      외부 리소스 안내:
      이 앱은 한국사 인물 퀴즈 데이터(JSON)를 사용합니다.
      원본: https://goolapp.com/wp-content/json/kr-history-people.json
      → 위 파일을 다운로드하여 `/public/data/kr-history-people.json` 경로에 배치해주세요.
      JSON 구조 예시: [{ "quiz": "문제", "selection": ["보기1","보기2","보기3","보기4"], "answer": 1 }, ...]
    */}
    <div class="quiz-wrapper">
      {/* 시작 화면 */}
      <section id="start-screen" class="screen">
        <div class="start-card">
          <div class="start-icon" aria-hidden="true">📜</div>
          <h2 class="start-title">한국사 인물 퀴즈</h2>
          <p class="start-desc">
            삼국시대부터 조선시대까지, 한국사를 빛낸 인물들에 관한 사지선다형 퀴즈입니다.
            <br />문제를 풀고 마지막에 점수를 확인해보세요!
          </p>
          <button type="button" id="start-btn" class="btn btn-primary">
            시작하기
          </button>
        </div>
      </section>

      {/* 퀴즈 화면 */}
      <section id="quiz-screen" class="screen" hidden>
        <div class="quiz-card">
          <div class="quiz-progress">
            <span id="progress-text">문제 1</span>
            <div class="progress-bar">
              <div id="progress-fill" class="progress-fill"></div>
            </div>
          </div>

          <h2 id="question-text" class="question-text"></h2>

          <div id="choices" class="choices"></div>

          <div id="feedback" class="feedback" hidden></div>

          <div class="quiz-actions">
            <button type="button" id="next-btn" class="btn btn-primary" hidden>
              다음 문제
            </button>
            <button type="button" id="quit-btn" class="btn-text">
              그만하기
            </button>
          </div>
        </div>
      </section>

      {/* 결과 화면 */}
      <section id="result-screen" class="screen" hidden>
        <div class="result-card">
          <div class="result-icon" aria-hidden="true">🏆</div>
          <h2 class="result-title">퀴즈 완료!</h2>
          <div class="result-stats">
            <div class="stat-item">
              <span class="stat-label">푼 문제</span>
              <span id="result-total" class="stat-value">0</span>
            </div>
            <div class="stat-item stat-correct">
              <span class="stat-label">정답</span>
              <span id="result-correct" class="stat-value">0</span>
            </div>
            <div class="stat-item stat-score">
              <span class="stat-label">점수</span>
              <span id="result-score" class="stat-value">0점</span>
            </div>
          </div>
          <p id="result-message" class="result-message"></p>
          <button type="button" id="restart-btn" class="btn btn-primary">
            처음으로
          </button>
        </div>
      </section>

      {/* 로딩/에러 */}
      <div id="loading" class="loading" hidden>문제를 불러오는 중...</div>
      <div id="error" class="error-box" hidden></div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .quiz-wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 1rem;
  }

  .screen {
    display: block;
    animation: fadeIn 0.3s ease;
  }
  .screen[hidden] {
    display: none;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* 카드 공통 */
  .start-card,
  .quiz-card,
  .result-card {
    background: var(--color-surface, #fff);
    border-radius: 16px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    padding: 2rem 1.5rem;
    border: 1px solid var(--color-border, #e5e7eb);
  }

  /* 시작 화면 */
  .start-card {
    text-align: center;
  }
  .start-icon {
    font-size: 3.5rem;
    margin-bottom: 0.75rem;
  }
  .start-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    margin: 0 0 0.75rem;
  }
  .start-desc {
    color: var(--color-text-secondary, #4b5563);
    line-height: 1.7;
    margin: 0 0 1.75rem;
    font-size: 1rem;
  }

  /* 퀴즈 진행 */
  .quiz-progress {
    margin-bottom: 1.5rem;
  }
  .quiz-progress #progress-text {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-secondary, #6b7280);
    margin-bottom: 0.5rem;
    font-weight: 600;
  }
  .progress-bar {
    width: 100%;
    height: 8px;
    background: var(--color-border, #e5e7eb);
    border-radius: 999px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--color-primary, #3b82f6);
    width: 0%;
    transition: width 0.3s ease;
    border-radius: 999px;
  }

  .question-text {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    word-break: keep-all;
  }

  .choices {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  /* 동적으로 생성되는 선택지 버튼 — :global() 필요 */
  .choices :global(.choice-btn) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    text-align: left;
    padding: 0.9rem 1rem;
    background: var(--color-surface, #fff);
    border: 2px solid #d1d5db;
    border-radius: 12px;
    font-size: 1rem;
    color: var(--color-text, #111827);
    cursor: pointer;
    transition: all 0.18s ease;
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    font-family: inherit;
    line-height: 1.5;
  }
  .choices :global(.choice-btn:hover:not(:disabled)) {
    transform: translateY(-2px);
    border-color: var(--color-primary, #3b82f6);
    box-shadow: 0 4px 10px rgba(59,130,246,0.15);
  }
  .choices :global(.choice-btn:disabled) {
    cursor: not-allowed;
    opacity: 0.85;
  }
  .choices :global(.choice-btn .choice-num) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-border, #e5e7eb);
    color: var(--color-text, #111827);
    font-weight: 700;
    font-size: 0.875rem;
    flex-shrink: 0;
  }
  .choices :global(.choice-btn.correct) {
    border-color: #10b981;
    background: #ecfdf5;
    color: #065f46;
  }
  .choices :global(.choice-btn.correct .choice-num) {
    background: #10b981;
    color: #fff;
  }
  .choices :global(.choice-btn.wrong) {
    border-color: #ef4444;
    background: #fef2f2;
    color: #991b1b;
  }
  .choices :global(.choice-btn.wrong .choice-num) {
    background: #ef4444;
    color: #fff;
  }

  .feedback {
    display: block;
    padding: 0.875rem 1rem;
    border-radius: 10px;
    font-weight: 600;
    margin-bottom: 1rem;
    line-height: 1.6;
    font-size: 0.95rem;
  }
  .feedback[hidden] {
    display: none;
  }
  .feedback.correct {
    background: #ecfdf5;
    color: #065f46;
    border: 1px solid #a7f3d0;
  }
  .feedback.wrong {
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
  }

  /* 액션 버튼 영역 — 세로 배치 */
  .quiz-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .btn {
    display: inline-block;
    width: 100%;
    padding: 0.875rem 1.25rem;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s ease;
    font-family: inherit;
  }
  .btn[hidden] {
    display: none;
  }
  .btn-primary {
    background: var(--color-primary, #3b82f6);
    color: #fff;
    box-shadow: 0 2px 6px rgba(59,130,246,0.25);
  }
  .btn-primary:hover {
    filter: brightness(1.05);
    transform: translateY(-1px);
  }
  .btn-primary:active {
    transform: translateY(0);
  }

  .btn-text {
    background: transparent;
    border: none;
    color: var(--color-text-secondary, #6b7280);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    padding: 0.625rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-family: inherit;
  }
  .btn-text:hover {
    color: var(--color-text, #111827);
  }

  /* 결과 화면 */
  .result-card {
    text-align: center;
  }
  .result-icon {
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
  }
  .result-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    margin: 0 0 1.5rem;
  }
  .result-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .stat-item {
    background: var(--color-bg, #f9fafb);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    padding: 1rem 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .stat-label {
    font-size: 0.8rem;
    color: var(--color-text-secondary, #6b7280);
    font-weight: 500;
  }
  .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text, #111827);
  }
  .stat-correct .stat-value {
    color: #10b981;
  }
  .stat-score .stat-value {
    color: var(--color-primary, #3b82f6);
  }
  .result-message {
    color: var(--color-text-secondary, #4b5563);
    font-size: 1rem;
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  /* 로딩 / 에러 */
  .loading {
    display: block;
    text-align: center;
    padding: 2rem;
    color: var(--color-text-secondary, #6b7280);
    font-size: 1rem;
  }
  .loading[hidden] {
    display: none;
  }
  .error-box {
    display: block;
    margin-top: 1rem;
    padding: 1rem;
    background: #fef2f2;
    color: #991b1b;
    border: 1px solid #fecaca;
    border-radius: 10px;
    text-align: center;
    font-size: 0.95rem;
  }
  .error-box[hidden] {
    display: none;
  }

  @media (max-width: 480px) {
    .start-card,
    .quiz-card,
    .result-card {
      padding: 1.5rem 1.1rem;
    }
    .question-text {
      font-size: 1.1rem;
    }
    .result-stats {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
    }
    .stat-value {
      font-size: 1.15rem;
    }
    .stat-label {
      font-size: 0.72rem;
    }
  }
</style>

<script>
  // 외부 리소스 안내:
  // /public/data/kr-history-people.json 파일이 존재해야 합니다.
  // (원본: https://goolapp.com/wp-content/json/kr-history-people.json)
  const JSON_URL = '/data/kr-history-people.json';

  type QuizItem = {
    quiz: string;
    selection: string[];
    answer: number; // 1-based
  };

  let quizData: QuizItem[] = [];
  let questionOrder: number[] = [];
  let currentIndex = 0;
  let correctCount = 0;
  let answered = false;

  const startScreen = document.getElementById('start-screen') as HTMLElement;
  const quizScreen = document.getElementById('quiz-screen') as HTMLElement;
  const resultScreen = document.getElementById('result-screen') as HTMLElement;
  const loadingEl = document.getElementById('loading') as HTMLElement;
  const errorEl = document.getElementById('error') as HTMLElement;

  const startBtn = document.getElementById('start-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const quitBtn = document.getElementById('quit-btn') as HTMLButtonElement;
  const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;

  const questionText = document.getElementById('question-text') as HTMLElement;
  const choicesEl = document.getElementById('choices') as HTMLElement;
  const feedbackEl = document.getElementById('feedback') as HTMLElement;
  const progressText = document.getElementById('progress-text') as HTMLElement;
  const progressFill = document.getElementById('progress-fill') as HTMLElement;

  const resultTotal = document.getElementById('result-total') as HTMLElement;
  const resultCorrect = document.getElementById('result-correct') as HTMLElement;
  const resultScore = document.getElementById('result-score') as HTMLElement;
  const resultMessage = document.getElementById('result-message') as HTMLElement;

  function showScreen(name: 'start' | 'quiz' | 'result') {
    startScreen.hidden = name !== 'start';
    quizScreen.hidden = name !== 'quiz';
    resultScreen.hidden = name !== 'result';
  }

  function shuffle<T>(arr: T[]): T[] {
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }
    return arr;
  }

  async function startQuiz() {
    errorEl.hidden = true;
    startBtn.disabled = true;
    loadingEl.hidden = false;

    try {
      if (quizData.length === 0) {
        const res = await fetch(JSON_URL);
        if (!res.ok) throw new Error('데이터를 불러올 수 없습니다.');
        quizData = await res.json();
      }

      if (!Array.isArray(quizData) || quizData.length === 0) {
        throw new Error('퀴즈 데이터가 비어 있습니다.');
      }

      questionOrder = shuffle(quizData.map((_, i) => i));
      currentIndex = 0;
      correctCount = 0;
      answered = false;

      loadingEl.hidden = true;
      startBtn.disabled = false;
      showScreen('quiz');
      loadQuestion();
    } catch (err: any) {
      loadingEl.hidden = true;
      startBtn.disabled = false;
      errorEl.hidden = false;
      errorEl.textContent = '❌ ' + (err?.message || '문제를 불러오는 중 오류가 발생했습니다.');
    }
  }

  function loadQuestion() {
    answered = false;
    feedbackEl.hidden = true;
    feedbackEl.textContent = '';
    feedbackEl.className = 'feedback';
    nextBtn.hidden = true;

    const q = quizData[questionOrder[currentIndex]];

    // 진행도
    progressText.textContent = `문제 ${currentIndex + 1} / ${quizData.length}`;
    const pct = ((currentIndex) / quizData.length) * 100;
    progressFill.style.width = pct + '%';

    // 문제 — XSS 방지를 위해 textContent 사용
    questionText.textContent = q.quiz;

    // 선택지
    choicesEl.innerHTML = '';
    q.selection.forEach((text, i) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'choice-btn';

      const num = document.createElement('span');
      num.className = 'choice-num';
      num.textContent = String(i + 1);

      const label = document.createElement('span');
      label.className = 'choice-label';
      label.textContent = text;

      btn.appendChild(num);
      btn.appendChild(label);

      btn.addEventListener('click', () => {
        checkAnswer(i + 1, q.answer, q.selection[q.answer - 1], btn);
      });

      choicesEl.appendChild(btn);
    });
  }

  function checkAnswer(selected: number, correct: number, answerText: string, clickedBtn: HTMLButtonElement) {
    if (answered) return;
    answered = true;

    const allBtns = choicesEl.querySelectorAll<HTMLButtonElement>('.choice-btn');
    allBtns.forEach((b, idx) => {
      b.disabled = true;
      if (idx + 1 === correct) {
        b.classList.add('correct');
      }
    });

    if (selected === correct) {
      correctCount++;
      feedbackEl.className = 'feedback correct';
      feedbackEl.textContent = '🎉 정답입니다!';
      feedbackEl.hidden = false;
    } else {
      clickedBtn.classList.add('wrong');
      feedbackEl.className = 'feedback wrong';
      feedbackEl.textContent = `아쉬워요! 정답은 "${answerText}" 입니다.`;
      feedbackEl.hidden = false;
    }

    // 진행도 갱신 (현재 문제 풀이 반영)
    const pct = ((currentIndex + 1) / quizData.length) * 100;
    progressFill.style.width = pct + '%';

    // 다음 문제 버튼: 마지막 문제일 때는 "결과 보기" 텍스트로
    if (currentIndex < quizData.length - 1) {
      nextBtn.textContent = '다음 문제';
    } else {
      nextBtn.textContent = '결과 보기';
    }
    nextBtn.hidden = false;
  }

  function nextQuestion() {
    if (!answered) return;
    currentIndex++;
    if (currentIndex < quizData.length) {
      loadQuestion();
    } else {
      showResult(false);
    }
  }

  function showResult(forced: boolean) {
    // forced: 그만하기로 들어온 경우
    let total = currentIndex;
    if (answered) total = currentIndex + 1; // 마지막 문제 답했으면 카운트

    if (total === 0) total = 0;

    const score = total > 0 ? Math.round((correctCount / total) * 100) : 0;

    resultTotal.textContent = String(total);
    resultCorrect.textContent = String(correctCount);
    resultScore.textContent = score + '점';

    let msg = '';
    if (total === 0) {
      msg = '아직 푼 문제가 없어요. 다시 도전해보세요!';
    } else if (score === 100) {
      msg = '완벽해요! 한국사 박사이신가요? 👏';
    } else if (score >= 80) {
      msg = '훌륭해요! 한국사에 정통하시네요.';
    } else if (score >= 60) {
      msg = '잘하셨어요! 조금만 더 공부하면 만점!';
    } else if (score >= 40) {
      msg = '아쉬워요. 다시 한 번 도전해보세요!';
    } else {
      msg = '한국사를 더 가까이! 다시 도전해볼까요?';
    }
    resultMessage.textContent = msg;

    showScreen('result');
  }

  function restartQuiz() {
    currentIndex = 0;
    correctCount = 0;
    answered = false;
    showScreen('start');
  }

  startBtn.addEventListener('click', startQuiz);
  nextBtn.addEventListener('click', nextQuestion);
  quitBtn.addEventListener('click', () => {
    if (confirm('정말 그만하시겠어요? 지금까지의 결과가 표시됩니다.')) {
      showResult(true);
    }
  });
  restartBtn.addEventListener('click', restartQuiz);
</script>