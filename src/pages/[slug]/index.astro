---
import { getCollection, render } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map(entry => ({
    params: { slug: entry.data.slug },
    props:  { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Related apps
const allApps = await getCollection('apps');
const related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({
    title:            app.data.title,
    shortDescription: app.data.shortDescription,
    slug:             app.data.slug,
    category:         app.data.category,
  }));
---

<AppLayout
  title={entry.data.title}
  description={entry.data.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.secondaryKeywords ?? []}
>
  <!-- App placeholder (will be replaced with real Vanilla JS widget per app) -->
  <Fragment slot="app">
    <div class="app-ui-placeholder">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="3"/>
        <path d="M9 9h6M9 12h6M9 15h4"/>
      </svg>
      <p>{entry.data.title} 앱 UI가 들어갈 자리입니다.</p>
    </div>
  </Fragment>

  <!-- Long-form + related -->
  <Fragment slot="longform">
    <div class="prose">
      <Content />
    </div>
    {related.length > 0 && <RelatedApps apps={related} />}
  </Fragment>
</AppLayout>

<style>
  .app-ui-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-16);
    text-align: center;
    color: var(--color-on-surface-variant);
    opacity: 0.6;
  }
  .app-ui-placeholder p { margin: 0; font-size: var(--font-size-base); }
  .prose { line-height: var(--line-height-base); }
  .prose :global(p) { margin-bottom: var(--space-4); }
</style>
