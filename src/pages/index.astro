---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import CategoryNav from '../components/CategoryNav.astro';
import SearchBar from '../components/SearchBar.astro';

const allApps = await getCollection('apps', ({ data }) => !data.draft);
const sortedApps = allApps.sort((a, b) =>
  a.data.title.localeCompare(b.data.title, 'ko-KR')
);
---

<BaseLayout
  title="GoolAPP - 일상의 편리함을 추구하는 유용한 도구들"
  description="계산기, 단위 변환기, 퀴즈 등 일상에서 바로 꺼내 쓸 수 있는 무료 앱 컬렉션입니다."
  ogImage="/og/default.webp"
  ogTitle="GoolAPP — 일상의 편리함을 추구하는 유용한 도구들"
  ogDescription="예적금 계산기, 출산예정일 계산기 등 일상에서 바로 꺼내 쓸 수 있는 무료 웹앱 컬렉션. 광고 없이 깔끔하게."
  keywords={['무료 계산기', '예적금 계산기', '출산예정일 계산기', '단위변환기', 'GoolAPP']}
>
  <!-- ── Hero ── -->
  <section class="hero-section">
    <div class="hero-container">
      <!-- 
        Heading: "일상의 편리함을 추구하는," is black (#1B1C1A)
        "작지만 유용한 도구들" uses primary color (#8B4F32) — two-tone heading
        All on one natural wrapping line per design
      -->
      <h1 class="hero-title">
        <span class="hero-title-black">일상의 편리함을 추구하는,<br /></span><span class="hero-title-primary">작지만 유용한 도구들</span>
      </h1>
      <p class="hero-subtitle">필요한 앱을 바로 꺼내 쓰세요. 모두 공짜랍니다.</p>

      <!-- Search bar -->
      <SearchBar />
    </div>
  </section>

  <!-- ── Apps section ── -->
  <section class="apps-section">
    <div class="container">
      <CategoryNav activeCategory="all" />

      <div class="app-grid">
        {sortedApps.map(app => (
          <AppCard
            title={app.data.title}
            shortDescription={app.data.shortDescription}
            slug={app.data.slug}
            category={app.data.category}
            contentSnippet={app.body}
          />
        ))}
      </div>

      <div id="favorites-empty-state" class="empty-state glass-surface" style="display: none;">
        <p>등록된 즐겨찾는 앱이 없습니다.</p>
      </div>

      <!-- "더 꺼내기" button — from design spec -->
      <div class="load-more-wrap" style="display: none;">
        <button class="load-more-btn">더 꺼내기</button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-section {
    text-align: center;
    padding: 80px 0 64px;
  }
  .hero-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Two-tone heading — 48px, letter-spacing -0.96px */
  .hero-title {
    font-family: var(--font-family-base);
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 0;
    max-width: 900px;
  }
  .hero-title-black   { color: #1b1c1a; }
  .hero-title-primary { color: var(--color-primary); }

  /* Subtitle: 18px, #53433D */
  .hero-subtitle {
    margin-top: 32px;
    margin-bottom: var(--space-8);
    font-size: 18px;
    font-weight: 400;
    line-height: 29px;
    color: #53433d;
  }



  /* ── Apps ── */
  .apps-section { padding-bottom: var(--space-16); }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 48px;
  }
  .empty-state {
    padding: var(--space-16);
    text-align: center;
    color: var(--color-on-surface-variant);
    margin-bottom: 48px;
    border-radius: var(--radius-2xl);
    background: rgba(251, 249, 245, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.1);
  }

  /* "더 꺼내기" button — Gothic font, 16px bold */
  .load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 8px;
  }
  .load-more-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 52px;
    background: rgba(251, 249, 245, 0.6);
    border: 1px solid var(--color-primary);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 9999px;
    font-family: var(--font-family-gothic);
    font-size: 16px;
    font-weight: 700;
    color: var(--color-primary);
    cursor: pointer;
    transition: all var(--transition-fast);
    box-shadow: 0px 0px 15px rgba(139, 79, 50, 0.15);
  }
  .load-more-btn:hover {
    background: rgba(139, 79, 50, 0.06);
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .app-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-section { padding: 60px 0 40px; }
    .hero-title {
      font-size: 1.75rem;
      line-height: 1.33;
    }
    .hero-subtitle { font-size: 16px; margin-top: 24px; }
    .app-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
