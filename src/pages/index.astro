---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCard from '../components/AppCard.astro';
import CategoryNav from '../components/CategoryNav.astro';

const allApps = await getCollection('apps', ({ data }) => !data.draft);
const sortedApps = allApps.sort((a, b) =>
  b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<BaseLayout
  title="GoolAPP - 일상의 편리함을 추구하는 유용한 도구들"
  description="계산기, 단위 변환기, 퀴즈 등 일상에서 바로 꺼내 쓸 수 있는 무료 앱 컬렉션입니다."
>
  <!-- ── Hero ── -->
  <section class="hero-section">
    <div class="container hero-container">
      <h1 class="hero-title">일상의 편리함을 추구하는,<br class="hero-br" />작지만 유용한 도구들</h1>
      <p class="hero-subtitle">필요한 앱을 바로 꺼내 쓰세요. 모두 공짜랍니다.</p>

      <!-- Search bar — from design spec -->
      <div class="search-bar" role="search">
        <div class="search-icon-wrap" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </div>
        <input
          type="search"
          id="app-search"
          class="search-input"
          placeholder="어떤 앱이 필요하세요?"
          aria-label="앱 검색"
          disabled
        />
        <button class="search-btn" disabled>찾기</button>
      </div>
    </div>
  </section>

  <!-- ── App list ── -->
  <section class="apps-section">
    <div class="container">
      <CategoryNav activeCategory="all" />
      <div class="app-grid">
        {sortedApps.map(app => (
          <AppCard
            title={app.data.title}
            shortDescription={app.data.shortDescription}
            slug={app.data.slug}
            category={app.data.category}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero-section {
    padding: var(--space-16) 0 var(--space-12);
    text-align: center;
  }
  .hero-title {
    /* from design: font-size 48px, letter-spacing -0.96px, line-height 53px */
    font-size: var(--font-size-3xl);
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: #1b1c1a;
    margin-bottom: 0;
  }
  .hero-subtitle {
    /* from design: 18px, color #53433D, margin-top ~31px */
    margin-top: 1.93rem;
    font-size: var(--font-size-lg);
    color: var(--color-on-surface-variant);
    display: inline-block;
    margin-bottom: var(--space-8);
  }

  /* Search bar — from goolapp-home-260507.md */
  .search-bar {
    display: flex;
    align-items: center;
    gap: 0;
    max-width: 672px;
    margin: 0 auto;
    padding: 8px;
    background: rgba(245, 243, 239, 0.5);
    border: 1px solid rgba(216, 194, 185, 0.5);
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-radius: var(--radius-full);
  }
  .search-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-family-base);
    font-size: var(--font-size-lg);
    color: rgba(83, 67, 61, 0.6);
    padding: 0 12px;
    min-width: 0;
  }
  .search-input::placeholder { color: rgba(83, 67, 61, 0.6); }
  .search-btn {
    flex-shrink: 0;
    padding: 12px 24px;
    height: 48px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    border: none;
    border-radius: var(--radius-full);
    font-family: var(--font-family-base);
    font-size: var(--font-size-base);
    cursor: pointer;
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
    transition: background var(--transition-fast);
  }
  .search-btn:hover { background: #713a1f; }

  /* ── App grid ── */
  .apps-section { padding-bottom: var(--space-20); }
  .app-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .app-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .hero-section {
      padding: var(--space-12) 0 var(--space-8);
    }
    .hero-title {
      /* mobile: 48px same size, 2-line */
      font-size: 2rem;
      line-height: 1.33;
    }
    .hero-br { display: none; }
    .hero-subtitle { font-size: var(--font-size-base); }
    .search-bar { max-width: 100%; }
    .app-grid { grid-template-columns: 1fr; }
  }
</style>
