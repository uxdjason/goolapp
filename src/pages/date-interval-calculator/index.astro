---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "date-interval-calculator");
if (!entry) throw new Error("date-interval-calculator entry not found");
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));
if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}

const currentYear = new Date().getFullYear();
const currentMonth = new Date().getMonth() + 1;
const currentDay = new Date().getDate();
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="app-calc-layout" style="max-width:560px">
      <!-- 입력 화면 -->
      <section id="screen-input">
        <h2 class="section-title">날짜 입력</h2>
        <p class="section-desc">
          두 날짜를 입력하면 그 사이의 기간(년/월/일)과 총 일수를 계산해
          드립니다.
        </p>

        <div class="app-form-group date-group">
          <label
            class="app-label"
            style="font-weight: 700; font-size: 1rem; color: var(--color-on-surface);"
            >시작 날짜</label
          >
          <div class="date-inputs">
            <div class="app-form-group">
              <label
                class="app-label"
                for="startYear"
                style="font-weight:normal; font-size: 0.85rem;">년</label
              >
              <input
                class="app-input"
                id="startYear"
                type="number"
                min="1"
                max="9999"
                value={currentYear}
              />
            </div>
            <div class="app-form-group">
              <label
                class="app-label"
                for="startMonth"
                style="font-weight:normal; font-size: 0.85rem;">월</label
              >
              <input
                class="app-input"
                id="startMonth"
                type="number"
                min="1"
                max="12"
                value="1"
              />
            </div>
            <div class="app-form-group">
              <label
                class="app-label"
                for="startDay"
                style="font-weight:normal; font-size: 0.85rem;">일</label
              >
              <input
                class="app-input"
                id="startDay"
                type="number"
                min="1"
                max="31"
                value="1"
              />
            </div>
          </div>
        </div>

        <div class="app-form-group date-group">
          <label
            class="app-label"
            style="font-weight: 700; font-size: 1rem; color: var(--color-on-surface);"
            >종료 날짜</label
          >
          <div class="date-inputs">
            <div class="app-form-group">
              <label
                class="app-label"
                for="endYear"
                style="font-weight:normal; font-size: 0.85rem;">년</label
              >
              <input
                class="app-input"
                id="endYear"
                type="number"
                min="1"
                max="9999"
                value={currentYear}
              />
            </div>
            <div class="app-form-group">
              <label
                class="app-label"
                for="endMonth"
                style="font-weight:normal; font-size: 0.85rem;">월</label
              >
              <input
                class="app-input"
                id="endMonth"
                type="number"
                min="1"
                max="12"
                value={currentMonth}
              />
            </div>
            <div class="app-form-group">
              <label
                class="app-label"
                for="endDay"
                style="font-weight:normal; font-size: 0.85rem;">일</label
              >
              <input
                class="app-input"
                id="endDay"
                type="number"
                min="1"
                max="31"
                value={currentDay}
              />
            </div>
          </div>
        </div>

        <p id="errorMsg" class="error-msg" hidden></p>

        <button
          id="calcBtn"
          class="app-btn app-btn-primary"
          type="button"
          >날짜 차이 계산</button
        >
      </section>

      <!-- 결과 화면 -->
      <section id="screen-result" hidden>
        <h2 class="section-title">계산 결과</h2>

        <div class="period-info" id="periodInfo"></div>

        <div class="result-card primary-result">
          <div class="result-label">년 · 개월 · 일</div>
          <div class="result-value" id="resultYMD">-</div>
        </div>

        <div class="result-grid">
          <div class="result-card">
            <div class="result-label">총 개월 + 일</div>
            <div class="result-value-sm" id="resultMD">-</div>
          </div>
          <div class="result-card">
            <div class="result-label">총 일수</div>
            <div class="result-value-sm" id="resultDays">-</div>
          </div>
        </div>

        <div class="action-buttons">
          <button id="copyBtn" class="app-btn app-btn-secondary" type="button"
            >📋 결과 복사</button
          >
          <button id="resetBtn" class="app-btn app-btn-primary" type="button"
            >다시 하기</button
          >
        </div>
      </section>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  #screen-input,
  #screen-result {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  #screen-input[hidden],
  #screen-result[hidden] {
    display: none;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: var(--color-on-surface);
    font-family: var(--font-family-gothic);
  }

  .section-desc {
    font-size: 0.95rem;
    color: var(--color-on-surface-variant);
    margin: 0;
    line-height: 1.5;
    font-family: var(--font-family-gothic);
  }

  .date-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .date-inputs {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 0.75rem;
  }

  .app-input::-webkit-outer-spin-button,
  .app-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .app-input[type="number"] {
    -moz-appearance: textfield;
  }

  .error-msg {
    margin-top: 1rem;
    padding: 0.875rem 1rem;
    background: rgba(239, 68, 68, 0.08);
    color: #b91c1c;
    border: 1px solid rgba(239, 68, 68, 0.25);
    border-radius: var(--radius-md);
    font-size: 0.9375rem;
    font-weight: 500;
    font-family: var(--font-family-gothic);
  }
  .error-msg[hidden] {
    display: none;
  }

  .result-card {
    padding: 1.25rem;
    background: var(--color-surface-container-low);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-md);
    text-align: center;
    font-family: var(--font-family-gothic);
  }

  .primary-result {
    background: var(--color-primary);
    color: var(--color-on-primary);
  }

  .primary-result .result-label {
    color: rgba(255, 255, 255, 0.85);
  }
  .primary-result .result-value {
    color: var(--color-on-primary);
  }

  .result-label {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-on-surface-variant);
    margin-bottom: 0.5rem;
  }

  .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-on-surface);
    word-break: keep-all;
  }

  .result-value-sm {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-on-surface);
    word-break: keep-all;
  }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.625rem;
  }

  .period-info {
    padding: 0.75rem 1rem;
    background: var(--color-surface-container-low);
    border: 1px dashed var(--color-outline-variant);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    color: var(--color-on-surface-variant);
    text-align: center;
    font-family: var(--font-family-gothic);
  }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (max-width: 380px) {
    .date-inputs {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0.5rem;
    }
  }
</style>

<script>
  function $(id: string) {
    return document.getElementById(id) as HTMLInputElement;
  }

  function getDailyEndOfMonth(year: number, month: number): number {
    // month: 1-12. Returns last day of that month.
    return new Date(year, month, 0).getDate();
  }

  function formatDate(y: number, m: number, d: number): string {
    return `${y}년 ${m}월 ${d}일`;
  }

  function calculate() {
    const errEl = document.getElementById("errorMsg")!;
    const screenInput = document.getElementById("screen-input")!;
    const screenResult = document.getElementById("screen-result")!;

    const sy = parseInt($("startYear").value, 10);
    const sm = parseInt($("startMonth").value, 10);
    const sd = parseInt($("startDay").value, 10);
    const ey = parseInt($("endYear").value, 10);
    const em = parseInt($("endMonth").value, 10);
    const ed = parseInt($("endDay").value, 10);

    const showError = (msg: string) => {
      errEl.textContent = msg;
      errEl.hidden = false;
      screenResult.hidden = true;
      screenInput.hidden = false;
    };

    errEl.hidden = true;

    if ([sy, sm, sd, ey, em, ed].some((v) => isNaN(v))) {
      showError("모든 날짜 필드를 입력해 주세요.");
      return;
    }

    if (sm < 1 || sm > 12 || em < 1 || em > 12) {
      showError("월은 1부터 12 사이의 값이어야 합니다.");
      return;
    }

    if (sd < 1 || sd > 31 || ed < 1 || ed > 31) {
      showError("일은 1부터 31 사이의 값이어야 합니다.");
      return;
    }

    // 실제 유효한 날짜인지 확인 (예: 2월 30일 방지)
    const startMaxDay = getDailyEndOfMonth(sy, sm);
    const endMaxDay = getDailyEndOfMonth(ey, em);
    if (sd > startMaxDay) {
      showError(`시작 날짜의 ${sy}년 ${sm}월은 ${startMaxDay}일까지 있습니다.`);
      return;
    }
    if (ed > endMaxDay) {
      showError(`종료 날짜의 ${ey}년 ${em}월은 ${endMaxDay}일까지 있습니다.`);
      return;
    }

    const start = new Date(sy, sm - 1, sd);
    const end = new Date(ey, em - 1, ed);

    if (end <= start) {
      showError("종료 날짜는 시작 날짜보다 이후여야 합니다.");
      return;
    }

    // 년/월/일 차이 계산
    let years = end.getFullYear() - start.getFullYear();
    let months = end.getMonth() - start.getMonth();
    let days = end.getDate() - start.getDate();

    if (days < 0) {
      months -= 1;
      // 전월의 말일 추가
      const prevMonthDate = new Date(end.getFullYear(), end.getMonth(), 0);
      days += prevMonthDate.getDate();
    }
    if (months < 0) {
      years -= 1;
      months += 12;
    }

    const totalMonths = years * 12 + months;
    const diffInDays = Math.ceil((end.getTime() - start.getTime()) / 86400000);

    // 결과 출력
    const ymdParts: string[] = [];
    if (years > 0) ymdParts.push(`${years}년`);
    if (months > 0) ymdParts.push(`${months}개월`);
    if (days > 0 || ymdParts.length === 0) ymdParts.push(`${days}일`);
    document.getElementById("resultYMD")!.textContent = ymdParts.join(" ");

    document.getElementById("resultMD")!.textContent =
      `${totalMonths.toLocaleString()}개월 ${days}일`;
    document.getElementById("resultDays")!.textContent =
      `${diffInDays.toLocaleString()}일`;

    document.getElementById("periodInfo")!.textContent =
      `${formatDate(sy, sm, sd)} → ${formatDate(ey, em, ed)}`;

    screenInput.hidden = true;
    screenResult.hidden = false;

    const targetEl = document.getElementById("screen-result");
    if (targetEl) {
      const y = targetEl.getBoundingClientRect().top + window.scrollY - 20;
      window.scrollTo({ top: Math.max(0, y), behavior: "smooth" });
    }
  }

  function resetApp() {
    const screenInput = document.getElementById("screen-input")!;
    const screenResult = document.getElementById("screen-result")!;

    screenInput.hidden = false;
    screenResult.hidden = true;

    const appContainer = document.querySelector(".app-calc-layout");
    if (appContainer) {
      const y = appContainer.getBoundingClientRect().top + window.scrollY - 80;
      window.scrollTo({ top: Math.max(0, y), behavior: "smooth" });
    } else {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  }

  async function copyResult() {
    const ymd = document.getElementById("resultYMD")!.textContent || "";
    const md = document.getElementById("resultMD")!.textContent || "";
    const days = document.getElementById("resultDays")!.textContent || "";
    const period = document.getElementById("periodInfo")!.textContent || "";

    const text = `[날짜 차이 계산 결과]\n${period}\n\n· ${ymd}\n· 총 ${md}\n· 총 ${days}`;

    const btn = document.getElementById("copyBtn")!;
    const originalText = btn.textContent;
    try {
      await navigator.clipboard.writeText(text);
      btn.textContent = "복사 완료 ✓";
    } catch (e) {
      // fallback
      const ta = document.createElement("textarea");
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try {
        document.execCommand("copy");
        btn.textContent = "복사 완료 ✓";
      } catch {
        btn.textContent = "복사 실패";
      }
      document.body.removeChild(ta);
    }
    setTimeout(() => {
      btn.textContent = originalText;
    }, 1600);
  }

  // 포커스 시 전체 선택 (UX 개선)
  function attachFocusSelect() {
    document.querySelectorAll<HTMLInputElement>(".app-input").forEach((inp) => {
      inp.addEventListener("focus", () => {
        inp.select();
      });
    });
  }

  document.getElementById("calcBtn")?.addEventListener("click", calculate);
  document.getElementById("resetBtn")?.addEventListener("click", resetApp);
  document.getElementById("copyBtn")?.addEventListener("click", copyResult);

  // 엔터키로도 계산 가능
  document.querySelectorAll<HTMLInputElement>(".app-input").forEach((inp) => {
    inp.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        e.preventDefault();
        calculate();
      }
    });
  });

  attachFocusSelect();
</script>
