      '물병자리': ['오프라 윈프리', '에디슨', '제니퍼 애니스턴', '강호동'],
      '물고기자리': ['스티브 잡스', '아인슈타인', '리한나', '박나래'],
      '양자리': ['빈센트 반 고흐', '레이디 가가', '조지프 퓰리처', '박보검'],
      '황소자리': ['셰익스피어', '데이비드 베컴', '아델', '아이브 안유진'],
      '쌍둥이자리': ['조니 뎁', '안젤리나 졸리', '메릴린 먼로', '유재석'],
      '게자리': ['톰 행크스', '엘론 머스크', '톰 크루즈', '아이유'],
      '사자자리': ['오바마', '마돈나', '제니퍼 로페즈', '공유'],
      '처녀자리': ['비욘세', '키아누 리브스', '마이클 잭슨', '이병헌'],
      '천칭자리': ['존 레논', '윌 스미스', '킴 카다시안', '현빈'],
      '전갈자리': ['빌 게이츠', '레오나르도 디카프리오', '케이티 페리', '송중기'],
