    const elDdi = document.getElementById('result-ddi')!;
    const elGanja = document.getElementById('result-ganja')!;
    const elHoro = document.getElementById('result-horoscope')!;
    const elFamous = document.getElementById('result-famous-horoscope')!;

    function getDayOfWeek(date: Date) {
      return DAYS[date.getDay()];
    }

    function getLunarDate(date: Date) {
      try {
        const fmt = new Intl.DateTimeFormat('ko-KR-u-ca-chinese', {
          year: 'numeric', month: 'long', day: 'numeric'
        });
        return fmt.format(date);
      } catch (e) {
        return '계산 불가';
      }
    }