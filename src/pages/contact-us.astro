---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="사용 문의 | GoolAPP"
  description="GoolAPP 사용 중 불편한 점이나 건의사항을 남겨주세요."
>
  <section class="page-section">
    <div class="container page-container">
      <h1 class="page-title">사용 문의</h1>
      <p class="page-desc">
        GoolAPP을 이용하시면서 궁금한 점이나 불편한 사항, 새로운 기능 제안 등
        자유롭게 메세지를 남겨주세요.
      </p>

      <div class="form-wrapper">
        <form
          action="https://formsubmit.co/b0ca5b100e1e3f9582ec236485cbd26f"
          method="POST"
          class="contact-form"
        >
          <!-- formsubmit settings -->
          <input
            type="hidden"
            name="_subject"
            value="[GoolAPP] 새로운 사용 문의가 접수되었습니다."
          />
          <input type="hidden" name="_template" value="table" />
          <div class="form-group">
            <label for="name">이름 (필수)</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="홍길동"
            />
          </div>

          <div class="form-group">
            <label for="email">이메일 (필수)</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="example@email.com"
            />
          </div>

          <div class="form-group">
            <label for="message">문의 내용 (필수)</label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder="문의하실 내용을 자세히 적어주세요."></textarea>
          </div>

          <button type="submit" class="submit-btn">문의 보내기</button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    padding: var(--space-16) 0;
  }
  .page-container {
    max-width: 680px;
    margin: 0 auto;
  }
  .page-title {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface);
    margin-bottom: var(--space-4);
    text-align: center;
  }
  .page-desc {
    font-size: var(--font-size-base);
    color: var(--color-on-surface-variant);
    text-align: center;
    margin-bottom: var(--space-12);
    line-height: 1.6;
  }

  .form-wrapper {
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(216, 194, 185, 0.5);
    border-radius: var(--radius-lg);
    padding: var(--space-10);
    backdrop-filter: blur(12px);
    box-shadow: 0px 4px 20px rgba(74, 68, 63, 0.05);
  }

  .form-group {
    margin-bottom: var(--space-6);
  }
  .form-group label {
    display: block;
    font-family: var(--font-family-gothic);
    font-weight: var(--font-weight-bold);
    margin-bottom: var(--space-2);
    color: var(--color-on-surface);
  }
  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    font-family: inherit;
    font-size: var(--font-size-base);
    color: var(--color-on-surface);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }
  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(139, 79, 50, 0.1);
  }
  .form-group textarea {
    resize: vertical;
  }
  .submit-btn {
    display: block;
    width: 100%;
    padding: var(--space-4);
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    cursor: pointer;
    transition: background var(--transition-fast);
  }
  .submit-btn:hover {
    background: #713a1f;
  }

  @media (max-width: 640px) {
    .form-wrapper {
      padding: var(--space-6);
    }
  }
</style>
