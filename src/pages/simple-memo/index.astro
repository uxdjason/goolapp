---
import { getEntry, render } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';

const entry = await getEntry('apps', 'simple-memo');
if (!entry) throw new Error('simple-memo entry not found');
const { Content } = await render(entry);
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <section class="memo-app" aria-label="보안 메모장">
      <div class="security-badge" role="status">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
        <span>모든 메모는 이 브라우저에만 안전하게 저장됩니다</span>
      </div>

      <div id="memo-main-view">
        <button class="memo-add-button" id="memo-add-button" type="button" aria-label="새 메모 추가">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
          </svg>
          <span>새 메모 작성</span>
        </button>

        <div id="memo-list" class="memo-list" aria-live="polite"></div>

        <div id="empty-state" class="empty-state" hidden>
          <div class="empty-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="9" y1="13" x2="15" y2="13"></line>
              <line x1="9" y1="17" x2="13" y2="17"></line>
            </svg>
          </div>
          <p class="empty-title">아직 작성된 메모가 없습니다</p>
          <p class="empty-desc">위 버튼을 눌러 첫 메모를 작성해 보세요</p>
        </div>
      </div>

      <div id="memo-editor" class="memo-editor" hidden>
        <div class="editor-header">
          <h2 id="editor-title" class="editor-title">새 메모</h2>
        </div>
        <textarea
          class="memo-textarea"
          id="memo-textarea"
          placeholder="메모 내용을 입력하세요..."
          rows="10"
          aria-label="메모 내용"
        ></textarea>
        <div class="char-count">
          <span id="char-count">0</span>자
        </div>
        <div class="editor-actions">
          <button type="button" class="btn btn-primary" id="btn-save">저장</button>
          <button type="button" class="btn btn-secondary" id="btn-cancel">취소</button>
          <button type="button" class="btn btn-secondary" id="btn-copy">클립보드 복사</button>
          <button type="button" class="btn btn-danger" id="btn-delete" hidden>삭제</button>
        </div>
      </div>

      <div id="dialog-container" class="dialog-container" hidden role="dialog" aria-modal="true" aria-labelledby="dialog-title">
        <div class="dialog-backdrop" id="dialog-backdrop"></div>
        <div class="dialog">
          <h3 id="dialog-title" class="dialog-title">메모를 삭제할까요?</h3>
          <p class="dialog-desc">삭제한 메모는 복구할 수 없습니다.</p>
          <div class="dialog-actions">
            <button type="button" class="btn btn-secondary" id="btn-cancel-delete">삭제 안함</button>
            <button type="button" class="btn btn-danger" id="btn-confirm-delete">삭제</button>
          </div>
        </div>
      </div>

      <div id="toast" class="toast" role="status" aria-live="polite" hidden></div>
    </section>
  </Fragment>

  <Fragment slot="longform">
    <Content />
  </Fragment>
</AppLayout>

<style>
  .memo-app {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  .security-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface-alt, #f5f7fa);
    border: 1px solid var(--color-border, #e5e7eb);
    border-left: 4px solid var(--color-primary);
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--color-text-secondary, #555);
  }

  .security-badge svg {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .memo-add-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 1rem 1.25rem;
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: filter 0.15s ease, transform 0.05s ease;
  }

  .memo-add-button:hover { filter: brightness(0.95); }
  .memo-add-button:active { transform: translateY(1px); }

  .memo-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .memo-list :global(.memo-bar) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.05s ease;
  }

  .memo-list :global(.memo-bar:hover) {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .memo-list :global(.memo-bar:active) {
    transform: translateY(1px);
  }

  .memo-list :global(.memo-content) {
    flex: 1;
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text, #222);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-weight: 500;
  }

  .memo-list :global(.memo-timestamp) {
    flex-shrink: 0;
    font-size: 0.78rem;
    color: var(--color-text-secondary, #777);
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1rem;
    color: var(--color-text-secondary, #888);
    text-align: center;
  }

  .empty-icon { color: var(--color-border, #ccc); margin-bottom: 0.75rem; }
  .empty-title { font-size: 1rem; font-weight: 600; margin: 0 0 0.25rem; color: var(--color-text, #444); }
  .empty-desc { font-size: 0.85rem; margin: 0; }

  .memo-editor {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
  }

  .editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .editor-title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text, #222);
  }

  .memo-textarea {
    width: 100%;
    min-height: 220px;
    padding: 0.85rem;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    line-height: 1.6;
    resize: vertical;
    box-sizing: border-box;
    background: var(--color-surface-alt, #fafbfc);
    color: var(--color-text, #222);
  }

  .memo-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(var(--color-primary-rgb, 79, 70, 229), 0.15);
    background: var(--color-surface, #fff);
  }

  .char-count {
    font-size: 0.8rem;
    color: var(--color-text-secondary, #777);
    text-align: right;
  }

  .editor-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .btn {
    padding: 0.65rem 1.1rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid transparent;
    transition: filter 0.15s ease, background 0.15s ease, transform 0.05s ease;
  }

  .btn:active { transform: translateY(1px); }

  .btn-primary {
    background: var(--color-primary);
    color: #fff;
  }
  .btn-primary:hover { filter: brightness(0.95); }

  .btn-secondary {
    background: var(--color-surface-alt, #f3f4f6);
    color: var(--color-text, #333);
    border-color: var(--color-border, #d1d5db);
  }
  .btn-secondary:hover { background: var(--color-border, #e5e7eb); }

  .btn-danger {
    background: #fff;
    color: #b3261e;
    border-color: #b3261e;
    margin-left: auto;
  }
  .btn-danger:hover { background: #fef2f2; }

  .dialog-container {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .dialog-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }

  .dialog {
    position: relative;
    width: 100%;
    max-width: 380px;
    padding: 1.5rem;
    background: var(--color-surface, #fff);
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
  }

  .dialog-title {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text, #222);
  }

  .dialog-desc {
    margin: 0 0 1.25rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary, #666);
  }

  .dialog-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .dialog-actions .btn-danger { margin-left: 0; }

  .toast {
    position: fixed;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1100;
    padding: 0.75rem 1.25rem;
    background: rgba(30, 30, 30, 0.92);
    color: #fff;
    border-radius: 8px;
    font-size: 0.9rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    animation: toast-in 0.2s ease;
  }

  @keyframes toast-in {
    from { opacity: 0; transform: translate(-50%, 10px); }
    to { opacity: 1; transform: translate(-50%, 0); }
  }

  @media (max-width: 480px) {
    .editor-actions { flex-direction: column; }
    .editor-actions .btn { width: 100%; }
    .btn-danger { margin-left: 0; }
  }
</style>

<script>
  (function () {
    if (typeof window === 'undefined') return;

    interface Memo {
      content: string;
      timestamp: string;
    }

    const STORAGE_KEY = 'memos';
    let memos: Memo[] = [];
    let currentMemoIndex = -1;

    const $ = <T extends HTMLElement = HTMLElement>(id: string) =>
      document.getElementById(id) as T | null;

    const memoMainView = $('memo-main-view');
    const memoList = $('memo-list');
    const emptyState = $('empty-state');
    const memoEditor = $('memo-editor');
    const memoTextarea = $<HTMLTextAreaElement>('memo-textarea');
    const editorTitle = $('editor-title');
    const btnDelete = $<HTMLButtonElement>('btn-delete');
    const charCount = $('char-count');
    const dialogContainer = $('dialog-container');
    const toastEl = $('toast');

    function loadMemos(): Memo[] {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        return Array.isArray(parsed) ? parsed : [];
      } catch {
        return [];
      }
    }

    function saveStorage() {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(memos));
      } catch {
        showToast('저장 공간이 부족합니다');
      }
    }

    function formatTimestamp(ts: string | Date): string {
      const d = new Date(ts);
      if (isNaN(d.getTime())) return '';
      const y = d.getFullYear();
      const mo = d.getMonth() + 1;
      const day = d.getDate();
      const h = d.getHours();
      const mi = String(d.getMinutes()).padStart(2, '0');
      return `${y}년 ${mo}월 ${day}일 ${h}시 ${mi}분`;
    }

    function showToast(msg: string) {
      if (!toastEl) return;
      toastEl.textContent = msg;
      toastEl.hidden = false;
      window.clearTimeout((toastEl as any)._t);
      (toastEl as any)._t = window.setTimeout(() => {
        toastEl.hidden = true;
      }, 2200);
    }

    function renderMemos() {
      if (!memoList || !emptyState) return;
      memoList.innerHTML = '';

      if (memos.length === 0) {
        emptyState.hidden = false;
        return;
      }
      emptyState.hidden = true;

      memos.forEach((memo, index) => {
        const firstLine = (memo.content || '').split('\n')[0].trim() || '(빈 메모)';

        const bar = document.createElement('div');
        bar.className = 'memo-bar';
        bar.setAttribute('role', 'button');
        bar.setAttribute('tabindex', '0');
        bar.setAttribute('aria-label', `${firstLine} 메모 열기`);

        const content = document.createElement('p');
        content.className = 'memo-content';
        content.textContent = firstLine;

        const time = document.createElement('div');
        time.className = 'memo-timestamp';
        time.textContent = formatTimestamp(memo.timestamp);

        bar.appendChild(content);
        bar.appendChild(time);

        bar.addEventListener('click', () => showEditor(index));
        bar.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            showEditor(index);
          }
        });

        memoList.appendChild(bar);
      });
    }

    function updateCharCount() {
      if (charCount && memoTextarea) {
        charCount.textContent = String(memoTextarea.value.length);
      }
    }

    function showEditor(index: number = -1) {
      currentMemoIndex = index;
      if (memoMainView) memoMainView.hidden = true;
      if (memoEditor) memoEditor.hidden = false;

      if (index >= 0) {
        if (editorTitle) editorTitle.textContent = '메모 편집';
        if (btnDelete) btnDelete.hidden = false;
        if (memoTextarea) memoTextarea.value = memos[index].content;
      } else {
        if (editorTitle) editorTitle.textContent = '새 메모';
        if (btnDelete) btnDelete.hidden = true;
        if (memoTextarea) memoTextarea.value = '';
      }

      updateCharCount();
      window.setTimeout(() => memoTextarea?.focus(), 50);
    }

    function cancelEdit() {
      if (memoEditor) memoEditor.hidden = true;
      if (memoTextarea) memoTextarea.value = '';
      currentMemoIndex = -1;
      if (memoMainView) memoMainView.hidden = false;
      updateCharCount();
    }

    function saveMemo() {
      const content = (memoTextarea?.value || '').trim();
      if (!content) {
        showToast('메모 내용을 입력해 주세요');
        memoTextarea?.focus();
        return;
      }
      if (currentMemoIndex >= 0) {
        memos.splice(currentMemoIndex, 1);
      }
      memos.unshift({ content, timestamp: new Date().toISOString() });
      saveStorage();
      renderMemos();
      cancelEdit();
      showToast('메모가 저장되었습니다');
    }

    async function copyToClipboard() {
      const text = (memoTextarea?.value || '').trim();
      if (!text) {
        showToast('복사할 내용이 없습니다');
        return;
      }
      try {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          await navigator.clipboard.writeText(text);
        } else {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        showToast('클립보드에 복사되었습니다');
      } catch {
        showToast('복사에 실패했습니다');
      }
    }

    function showDeleteDialog() {
      if (dialogContainer) dialogContainer.hidden = false;
    }
    function hideDeleteDialog() {
      if (dialogContainer) dialogContainer.hidden = true;
    }

    function deleteMemo() {
      if (currentMemoIndex < 0) {
        hideDeleteDialog();
        return;
      }
      memos.splice(currentMemoIndex, 1);
      saveStorage();
      hideDeleteDialog();
      cancelEdit();
      renderMemos();
      showToast('메모가 삭제되었습니다');
    }

    // 이벤트 바인딩
    $('memo-add-button')?.addEventListener('click', () => showEditor(-1));
    $('btn-save')?.addEventListener('click', saveMemo);
    $('btn-cancel')?.addEventListener('click', cancelEdit);
    $('btn-copy')?.addEventListener('click', copyToClipboard);
    $('btn-delete')?.addEventListener('click', showDeleteDialog);
    $('btn-cancel-delete')?.addEventListener('click', hideDeleteDialog);
    $('btn-confirm-delete')?.addEventListener('click', deleteMemo);
    $('dialog-backdrop')?.addEventListener('click', hideDeleteDialog);

    memoTextarea?.addEventListener('input', updateCharCount);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (dialogContainer && !dialogContainer.hidden) {
          hideDeleteDialog();
        } else if (memoEditor && !memoEditor.hidden) {
          cancelEdit();
        }
      }
    });

    // 초기화
    memos = loadMemos();
    renderMemos();
  })();
</script>