---
import { getEntry, render, getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

const entry = await getEntry('apps', 'english-antonym-quiz-high-school-level');
if (!entry) throw new Error('english-antonym-quiz-high-school-level entry not found');
const { Content } = await render(entry);

const allApps = await getCollection('apps');
let related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
if (related.length === 0) {
  related = allApps
    .filter(app => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    {/*
      외부 리소스 안내:
      이 앱은 원래 https://goolapp.com/wp-content/json/english_antonym_high_quiz_data.json 을 fetch했다.
      Astro 환경에서는 CORS 및 도메인 의존성 문제를 피하기 위해 해당 JSON 파일을
      /public/data/english_antonym_high_quiz_data.json 위치로 다운로드하여 배치해야 한다.
      배치 후 아래 JSON_URL('/data/english_antonym_high_quiz_data.json') 경로로 자동 로드된다.
    */}
    <div class="quiz-app">
      <!-- 시작 화면 -->
      <section id="start-screen" class="screen">
        <div class="card">
          <h2 class="screen-title">영단어 반의어 맞추기</h2>
          <p class="screen-desc">고등학교 수준 영어 단어의 반의어를 4개의 선택지 중에서 골라보세요. 정답을 맞추면 즉시 결과가 표시되고, 마지막에 점수를 확인할 수 있습니다.</p>
          <button class="btn btn-primary" id="start-btn">시작하기</button>
        </div>
      </section>

      <!-- 퀴즈 화면 -->
      <section id="quiz-screen" class="screen" hidden>
        <div class="card">
          <div class="progress-row">
            <span id="progress-text" class="progress-text">문제 1</span>
            <span id="score-text" class="score-text">정답 0</span>
          </div>

          <div class="question-box">
            <p class="question-label">다음 단어의 반의어는?</p>
            <h2 id="question-word" class="question-word">—</h2>
          </div>

          <div id="choices" class="choices"></div>

          <p id="feedback" class="feedback" hidden></p>

          <div class="quiz-actions">
            <button class="btn btn-primary" id="next-btn" hidden>다음 문제</button>
            <button class="btn btn-text" id="quit-btn">그만 하기</button>
          </div>
        </div>
      </section>

      <!-- 결과 화면 -->
      <section id="result-screen" class="screen" hidden>
        <div class="card">
          <h2 class="screen-title">퀴즈 결과</h2>
          <div class="result-summary">
            <div class="result-item">
              <span class="result-label">시도한 문제</span>
              <span class="result-value" id="result-total">0</span>
            </div>
            <div class="result-item">
              <span class="result-label">맞춘 문제</span>
              <span class="result-value" id="result-correct">0</span>
            </div>
            <div class="result-item highlight">
              <span class="result-label">점수</span>
              <span class="result-value" id="result-score">0%</span>
            </div>
          </div>
          <button class="btn btn-primary" id="restart-btn">처음으로</button>
        </div>
      </section>

      <!-- 로딩/에러 -->
      <section id="loading-screen" class="screen" hidden>
        <div class="card">
          <p class="screen-desc">문제를 불러오는 중...</p>
        </div>
      </section>
      <section id="error-screen" class="screen" hidden>
        <div class="card">
          <h2 class="screen-title">불러오기 실패</h2>
          <p class="screen-desc" id="error-message">문제 데이터를 불러오지 못했습니다.</p>
          <button class="btn btn-primary" id="retry-btn">다시 시도</button>
        </div>
      </section>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .quiz-app {
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
  }

  .screen {
    display: block;
  }
  .screen[hidden] {
    display: none;
  }

  .card {
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    padding: 1.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .screen-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text, #111827);
    margin: 0 0 0.75rem 0;
  }

  .screen-desc {
    color: var(--color-text-muted, #6b7280);
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
  }

  .progress-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
    color: var(--color-text-muted, #6b7280);
  }

  .progress-text {
    font-weight: 600;
    color: var(--color-primary, #2563eb);
  }

  .score-text {
    font-weight: 600;
  }

  .question-box {
    text-align: center;
    padding: 1.5rem 1rem;
    background: var(--color-background-alt, #f9fafb);
    border-radius: 10px;
    margin-bottom: 1.5rem;
  }

  .question-label {
    color: var(--color-text-muted, #6b7280);
    font-size: 0.95rem;
    margin: 0 0 0.5rem 0;
  }

  .question-word {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text, #111827);
    margin: 0;
    letter-spacing: 0.05em;
  }

  .choices {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  @media (min-width: 480px) {
    .choices {
      grid-template-columns: 1fr 1fr;
    }
  }

  :global(.choice-btn) {
    width: 100%;
    padding: 0.95rem 1rem;
    background: #fff;
    border: 2px solid #d1d5db;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text, #111827);
    cursor: pointer;
    transition: transform 0.12s ease, border-color 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
    text-align: center;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  :global(.choice-btn:hover:not(:disabled)) {
    transform: translateY(-2px);
    border-color: var(--color-primary, #2563eb);
    box-shadow: 0 4px 10px rgba(37, 99, 235, 0.12);
  }

  :global(.choice-btn:disabled) {
    cursor: not-allowed;
    opacity: 0.75;
  }

  :global(.choice-btn.correct) {
    background: #ecfdf5;
    border-color: #10b981;
    color: #065f46;
  }

  :global(.choice-btn.wrong) {
    background: #fef2f2;
    border-color: #ef4444;
    color: #991b1b;
  }

  .feedback {
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    font-weight: 600;
    margin: 0 0 1.25rem 0;
  }
  .feedback[hidden] {
    display: none;
  }
  .feedback.correct {
    background: #ecfdf5;
    color: #065f46;
  }
  .feedback.wrong {
    background: #fef2f2;
    color: #991b1b;
  }

  .quiz-actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .btn {
    width: 100%;
    padding: 0.85rem 1.25rem;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: background 0.15s ease, transform 0.12s ease, opacity 0.12s ease;
  }
  .btn[hidden] {
    display: none;
  }

  .btn-primary {
    background: var(--color-primary, #2563eb);
    color: #fff;
  }
  .btn-primary:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  .btn-text {
    background: transparent;
    color: var(--color-text-muted, #6b7280);
    text-decoration: underline;
    font-weight: 500;
    padding: 0.6rem 1rem;
  }
  .btn-text:hover {
    color: var(--color-text, #111827);
  }

  .result-summary {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 1rem 0 1.5rem 0;
  }

  .result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1rem;
    background: var(--color-background-alt, #f9fafb);
    border-radius: 8px;
  }

  .result-item.highlight {
    background: var(--color-primary, #2563eb);
    color: #fff;
  }

  .result-label {
    font-size: 0.95rem;
  }

  .result-value {
    font-size: 1.15rem;
    font-weight: 700;
  }
</style>

<script>
  const JSON_URL = '/data/english_antonym_high_quiz_data.json';

  type QuizItem = {
    quiz: string;
    selection: string[];
    answer: number; // 1-based
  };

  let quizData: QuizItem[] = [];
  let questionOrder: number[] = [];
  let currentIndex = 0;
  let correctCount = 0;
  let answered = false;

  const startScreen = document.getElementById('start-screen') as HTMLElement;
  const quizScreen = document.getElementById('quiz-screen') as HTMLElement;
  const resultScreen = document.getElementById('result-screen') as HTMLElement;
  const loadingScreen = document.getElementById('loading-screen') as HTMLElement;
  const errorScreen = document.getElementById('error-screen') as HTMLElement;

  const startBtn = document.getElementById('start-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const quitBtn = document.getElementById('quit-btn') as HTMLButtonElement;
  const restartBtn = document.getElementById('restart-btn') as HTMLButtonElement;
  const retryBtn = document.getElementById('retry-btn') as HTMLButtonElement;

  const questionWordEl = document.getElementById('question-word') as HTMLElement;
  const choicesEl = document.getElementById('choices') as HTMLElement;
  const feedbackEl = document.getElementById('feedback') as HTMLElement;
  const progressEl = document.getElementById('progress-text') as HTMLElement;
  const scoreEl = document.getElementById('score-text') as HTMLElement;
  const errorMessageEl = document.getElementById('error-message') as HTMLElement;

  const resultTotalEl = document.getElementById('result-total') as HTMLElement;
  const resultCorrectEl = document.getElementById('result-correct') as HTMLElement;
  const resultScoreEl = document.getElementById('result-score') as HTMLElement;

  function showScreen(name: 'start' | 'quiz' | 'result' | 'loading' | 'error') {
    startScreen.hidden = name !== 'start';
    quizScreen.hidden = name !== 'quiz';
    resultScreen.hidden = name !== 'result';
    loadingScreen.hidden = name !== 'loading';
    errorScreen.hidden = name !== 'error';
  }

  function shuffle<T>(arr: T[]): T[] {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  async function startQuiz() {
    showScreen('loading');
    try {
      const res = await fetch(JSON_URL);
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      if (!Array.isArray(data) || data.length === 0) {
        throw new Error('데이터 형식이 올바르지 않습니다.');
      }
      quizData = data as QuizItem[];
      questionOrder = shuffle(Array.from({ length: quizData.length }, (_, i) => i));
      currentIndex = 0;
      correctCount = 0;
      answered = false;
      showScreen('quiz');
      loadQuestion();
    } catch (err: any) {
      errorMessageEl.textContent = '문제 데이터를 불러오지 못했습니다. (' + (err?.message || '오류') + ')';
      showScreen('error');
    }
  }

  function loadQuestion() {
    answered = false;
    const realIdx = questionOrder[currentIndex];
    const q = quizData[realIdx];

    questionWordEl.textContent = (q.quiz || '').toUpperCase();
    progressEl.textContent = `문제 ${currentIndex + 1} / ${quizData.length}`;
    scoreEl.textContent = `정답 ${correctCount}`;

    feedbackEl.hidden = true;
    feedbackEl.textContent = '';
    feedbackEl.classList.remove('correct', 'wrong');

    nextBtn.hidden = true;

    choicesEl.innerHTML = '';
    q.selection.forEach((choice, i) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'choice-btn';
      btn.textContent = choice;
      btn.addEventListener('click', () => {
        checkAnswer(i + 1, q.answer, q.selection[q.answer - 1], btn);
      });
      choicesEl.appendChild(btn);
    });
  }

  function checkAnswer(selected: number, correct: number, correctWord: string, clickedBtn: HTMLButtonElement) {
    if (answered) return;
    answered = true;

    const allBtns = choicesEl.querySelectorAll('button');
    allBtns.forEach((b, idx) => {
      (b as HTMLButtonElement).disabled = true;
      if (idx + 1 === correct) {
        b.classList.add('correct');
      }
    });

    if (selected === correct) {
      correctCount++;
      feedbackEl.textContent = '정답입니다! 🎉';
      feedbackEl.classList.add('correct');
    } else {
      clickedBtn.classList.add('wrong');
      feedbackEl.textContent = `오답입니다. 정답은 "${correctWord}" 입니다.`;
      feedbackEl.classList.add('wrong');
    }
    feedbackEl.hidden = false;
    scoreEl.textContent = `정답 ${correctCount}`;

    const isLast = currentIndex >= quizData.length - 1;
    if (isLast) {
      setTimeout(showResult, 1500);
    } else {
      nextBtn.hidden = false;
    }
  }

  function nextQuestion() {
    if (currentIndex < quizData.length - 1) {
      currentIndex++;
      loadQuestion();
    } else {
      showResult();
    }
  }

  function showResult() {
    const totalAttempted = answered ? currentIndex + 1 : currentIndex;
    const safeTotal = Math.max(totalAttempted, 1);
    const score = Math.round((correctCount / safeTotal) * 100);

    resultTotalEl.textContent = String(totalAttempted);
    resultCorrectEl.textContent = String(correctCount);
    resultScoreEl.textContent = `${isFinite(score) ? score : 0}%`;

    showScreen('result');
  }

  function restartQuiz() {
    currentIndex = 0;
    correctCount = 0;
    answered = false;
    showScreen('start');
  }

  startBtn.addEventListener('click', startQuiz);
  nextBtn.addEventListener('click', nextQuestion);
  quitBtn.addEventListener('click', showResult);
  restartBtn.addEventListener('click', restartQuiz);
  retryBtn.addEventListener('click', startQuiz);
</script>