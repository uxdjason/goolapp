---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "loan-interest-calculator");
if (!entry) throw new Error("loan-interest-calculator entry not found");
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));
if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="app-calc-layout">
      <section class="app-screen" id="inputScreen">
        <div class="app-form-group">
          <label class="app-label" for="principal">대출 원금 (원)</label>
          <input
            class="app-input"
            type="number"
            id="principal"
            min="0"
            placeholder="예: 100000000"
          />
        </div>

        <div class="app-form-group">
          <label class="app-label" for="years">대출 기간 (년)</label>
          <input
            class="app-input"
            type="number"
            id="years"
            min="0"
            step="0.1"
            placeholder="예: 10"
          />
        </div>

        <div class="app-form-group">
          <label class="app-label" for="rate">대출 금리 (%)</label>
          <input
            class="app-input"
            type="number"
            id="rate"
            min="0"
            step="0.01"
            placeholder="예: 4.5"
          />
        </div>

        <div class="app-form-group">
          <label class="app-label group-label">상환 방식</label>
          <div class="radio-group">
            <label class="radio-item">
              <div class="radio-title-row">
                <input
                  type="radio"
                  name="repayMethod"
                  value="annuity"
                  checked
                />
                <strong>원리금 균등분할상환</strong>
              </div>
              <span class="radio-desc"
                >매월 같은 금액으로 원금과 이자를 함께 상환 (일반적)</span
              >
            </label>
            <label class="radio-item">
              <div class="radio-title-row">
                <input type="radio" name="repayMethod" value="principal" />
                <strong>원금 균등분할상환</strong>
              </div>
              <span class="radio-desc"
                >매월 같은 원금 상환, 이자는 남은 원금에 따라 감소</span
              >
            </label>
          </div>
        </div>

        <button class="app-btn app-btn-primary" id="calculateBtn" style="width: 100%; margin-top: 1rem;">이자 계산하기</button>
      </section>

      <section class="app-screen" id="resultScreen" hidden>
        <div class="input-summary" id="inputSummary"></div>

        <div class="result-summary" id="resultText"></div>

        <div class="schedule-wrapper">
          <button class="app-btn app-btn-secondary" id="toggleScheduleBtn" style="width: 100%;">상환 스케줄 보기</button>
          <div class="schedule-table-wrapper" id="scheduleTableWrapper" hidden>
          </div>
        </div>

        <button class="app-btn app-btn-text" id="resetBtn" style="width: 100%; margin-top: 0.5rem;">처음으로</button>
      </section>

      <!-- 공통 경고 모달 -->
      <div id="app-alert-modal" class="app-modal-overlay" hidden>
        <div class="app-modal">
          <div class="app-modal-icon">⚠️</div>
          <p class="app-modal-title" id="app-alert-title">알림</p>
          <p class="app-modal-body" id="app-alert-message"></p>
          <div class="app-modal-actions">
            <button id="app-alert-confirm-btn" class="app-btn app-btn-primary">확인</button>
          </div>
        </div>
      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  /* loan-interest-calculator 특화 스타일 */
  .group-label {
    margin-bottom: 0.75rem !important;
  }

  .radio-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .radio-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem;
    border: 2px solid var(--color-outline-variant);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .radio-item:hover {
    border-color: var(--color-primary);
  }

  .radio-item:has(input[type="radio"]:checked) {
    border-color: var(--color-primary);
    background: var(--color-surface-container-low);
  }

  .radio-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .radio-title-row input[type="radio"] {
    flex-shrink: 0;
    accent-color: var(--color-primary);
    width: 1.1rem;
    height: 1.1rem;
    cursor: pointer;
  }

  .radio-title-row strong {
    font-size: 1rem;
    color: var(--color-on-surface);
    font-family: var(--font-family-gothic);
  }

  .radio-desc {
    font-size: 0.85rem;
    color: var(--color-on-surface-variant);
    padding-left: 1.7rem;
    font-family: var(--font-family-gothic);
  }

  .app-screen[hidden],
  .schedule-table-wrapper[hidden] {
    display: none !important;
  }

  .input-summary {
    background: var(--color-surface-container-low);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .input-summary :global(.summary-section-label) {
    display: block;
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-outline-variant);
    margin-bottom: 0;
    font-family: var(--font-family-gothic);
  }

  .input-summary :global(.summary-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .input-summary :global(.summary-row:last-child) {
    border-bottom: none;
  }

  .input-summary :global(.summary-label) {
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
    font-family: var(--font-family-gothic);
  }

  .input-summary :global(.summary-value) {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-on-surface);
    font-family: var(--font-family-gothic);
  }

  .result-summary {
    background: var(--color-surface-container-low);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .result-summary :global(.summary-row) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .result-summary :global(.summary-row:last-child) {
    border-bottom: none;
  }

  .result-summary :global(.summary-label) {
    color: var(--color-on-surface-variant);
    font-size: 0.95rem;
    font-family: var(--font-family-gothic);
  }

  .result-summary :global(.summary-value) {
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-on-surface);
    font-family: var(--font-family-gothic);
  }

  .result-summary :global(.summary-value.highlight) {
    color: var(--color-primary);
    font-size: 1.25rem;
  }

  .schedule-wrapper {
    margin-bottom: 1rem;
  }

  .schedule-table-wrapper {
    margin-top: 1rem;
    overflow-x: auto;
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius-md);
  }

  .schedule-table-wrapper :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    min-width: 560px;
    font-family: var(--font-family-gothic);
  }

  .schedule-table-wrapper :global(th),
  .schedule-table-wrapper :global(td) {
    padding: 0.625rem 0.75rem;
    text-align: right;
    border-bottom: 1px solid var(--color-outline-variant);
    color: var(--color-on-surface);
  }

  .schedule-table-wrapper :global(th:first-child),
  .schedule-table-wrapper :global(td:first-child) {
    text-align: center;
  }

  .schedule-table-wrapper :global(thead th) {
    background: var(--color-surface-container-low);
    font-weight: 600;
    position: sticky;
    top: 0;
  }

  .schedule-table-wrapper :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .notice {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    background: var(--color-surface-container-low);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    color: var(--color-on-surface-variant);
    font-family: var(--font-family-gothic);
  }
</style>

<script>
  function formatNumber(num: number): string {
    return Math.round(num).toLocaleString("ko-KR");
  }

  let currentSchedule: Array<{
    month: number;
    principalPay: number;
    interest: number;
    remaining: number;
  }> = [];

  const appAlertModal = document.getElementById('app-alert-modal') as HTMLElement;
  const appAlertMessage = document.getElementById('app-alert-message') as HTMLElement;
  const appAlertConfirmBtn = document.getElementById('app-alert-confirm-btn') as HTMLButtonElement;

  function showAlert(msg: string) {
    appAlertMessage.textContent = msg;
    appAlertModal.removeAttribute('hidden');
  }

  function hideAlert() {
    appAlertModal.setAttribute('hidden', '');
  }

  appAlertConfirmBtn?.addEventListener('click', hideAlert);
  appAlertModal?.addEventListener('click', (e) => {
    if (e.target === appAlertModal) hideAlert();
  });

  function calculate() {
    const principal = parseFloat(
      (document.getElementById("principal") as HTMLInputElement).value,
    );
    const years = parseFloat(
      (document.getElementById("years") as HTMLInputElement).value,
    );
    const rate = parseFloat(
      (document.getElementById("rate") as HTMLInputElement).value,
    );
    const repayMethodEl = document.querySelector(
      'input[name="repayMethod"]:checked',
    ) as HTMLInputElement | null;
    const repayMethod = repayMethodEl ? repayMethodEl.value : "annuity";

    if (!principal || principal <= 0 || isNaN(principal)) {
      showAlert("대출 원금을 올바르게 입력해주세요.");
      return;
    }
    if (!years || years <= 0 || isNaN(years)) {
      showAlert("대출 기간을 올바르게 입력해주세요.");
      return;
    }
    if (rate === null || isNaN(rate) || rate < 0) {
      showAlert("대출 금리를 올바르게 입력해주세요.");
      return;
    }

    const months = Math.round(years * 12);
    const monthlyRate = rate / 100 / 12;
    let remaining = principal;
    let totalInterest = 0;
    let monthlyPayment = 0;
    const schedule: typeof currentSchedule = [];

    if (repayMethod === "annuity") {
      if (monthlyRate === 0) {
        monthlyPayment = principal / months;
      } else {
        monthlyPayment =
          (principal * monthlyRate) / (1 - Math.pow(1 + monthlyRate, -months));
      }
      for (let m = 1; m <= months; m++) {
        const interest = remaining * monthlyRate;
        let principalPay = monthlyPayment - interest;
        remaining -= principalPay;
        if (remaining < 0) {
          principalPay += remaining;
          remaining = 0;
        }
        totalInterest += interest;
        schedule.push({
          month: m,
          principalPay,
          interest,
          remaining,
        });
      }
    } else {
      const principalPay = principal / months;
      for (let m = 1; m <= months; m++) {
        const interest = remaining * monthlyRate;
        remaining -= principalPay;
        if (remaining < 0) remaining = 0;
        totalInterest += interest;
        schedule.push({
          month: m,
          principalPay,
          interest,
          remaining,
        });
      }
      monthlyPayment = principalPay + principal * monthlyRate; // 첫 달 기준
    }

    const totalPayment = principal + totalInterest;
    currentSchedule = schedule;

    const methodLabel =
      repayMethod === "annuity" ? "원리금 균등분할상환" : "원금 균등분할상환";
    const firstMonthLabel =
      repayMethod === "annuity" ? "월 상환 금액" : "첫 달 상환 금액";

    // 입력값 요약 렌더링
    const inputSummaryEl = document.getElementById(
      "inputSummary",
    ) as HTMLElement;
    inputSummaryEl.innerHTML = `
      <div class="summary-row">
        <span class="summary-label">대출 원금</span>
        <span class="summary-value">${formatNumber(principal)}원</span>
      </div>
      <div class="summary-row">
        <span class="summary-label">대출 기간</span>
        <span class="summary-value">${years}년 (${months}개월)</span>
      </div>
      <div class="summary-row">
        <span class="summary-label">연 금리</span>
        <span class="summary-value">${rate}%</span>
      </div>
      <div class="summary-row">
        <span class="summary-label">상환 방식</span>
        <span class="summary-value">${methodLabel}</span>
      </div>
    `;

    const resultText = document.getElementById("resultText") as HTMLElement;
    resultText.innerHTML = `
      <div class="summary-row">
        <span class="summary-label">${firstMonthLabel}</span>
        <span class="summary-value highlight">${formatNumber(monthlyPayment)}원</span>
      </div>
      <div class="summary-row">
        <span class="summary-label">총 대출 이자</span>
        <span class="summary-value">${formatNumber(totalInterest)}원</span>
      </div>
      <div class="summary-row">
        <span class="summary-label">총 상환 금액</span>
        <span class="summary-value">${formatNumber(totalPayment)}원</span>
      </div>
      <div class="notice">실제 금융기관의 특약·우대금리 등으로 인해 결과와 차이가 발생할 수 있습니다. 참고용으로 활용해주세요.</div>
    `;

    (document.getElementById("inputScreen") as HTMLElement).hidden = true;
    (document.getElementById("resultScreen") as HTMLElement).hidden = false;

    // 스케줄 테이블은 일단 숨김 상태로 초기화
    const tableWrapper = document.getElementById(
      "scheduleTableWrapper",
    ) as HTMLElement;
    tableWrapper.hidden = true;
    tableWrapper.innerHTML = "";
    (document.getElementById("toggleScheduleBtn") as HTMLElement).textContent =
      "상환 스케줄 보기";
  }

  function toggleSchedule() {
    const tableWrapper = document.getElementById(
      "scheduleTableWrapper",
    ) as HTMLElement;
    const toggleBtn = document.getElementById(
      "toggleScheduleBtn",
    ) as HTMLElement;

    if (tableWrapper.hidden) {
      let html = "<table><thead><tr>";
      html +=
        "<th>회차</th><th>원금</th><th>이자</th><th>월 상환액</th><th>남은 원금</th>";
      html += "</tr></thead><tbody>";
      currentSchedule.forEach((row) => {
        const total = row.principalPay + row.interest;
        html += `<tr>
          <td>${row.month}</td>
          <td>${formatNumber(row.principalPay)}</td>
          <td>${formatNumber(row.interest)}</td>
          <td>${formatNumber(total)}</td>
          <td>${formatNumber(row.remaining)}</td>
        </tr>`;
      });
      html += "</tbody></table>";
      tableWrapper.innerHTML = html;
      tableWrapper.hidden = false;
      toggleBtn.textContent = "상환 스케줄 숨기기";
    } else {
      tableWrapper.hidden = true;
      toggleBtn.textContent = "상환 스케줄 보기";
    }
  }

  function resetForm() {
    (document.getElementById("inputScreen") as HTMLElement).hidden = false;
    (document.getElementById("resultScreen") as HTMLElement).hidden = true;
    const tableWrapper = document.getElementById(
      "scheduleTableWrapper",
    ) as HTMLElement;
    tableWrapper.hidden = true;
    tableWrapper.innerHTML = "";

    const appContainer = document.querySelector(".app-calc-layout");
    if (appContainer) {
      const y = appContainer.getBoundingClientRect().top + window.scrollY - 80;
      window.scrollTo({ top: Math.max(0, y), behavior: "smooth" });
    } else {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  }

  document.getElementById("calculateBtn")?.addEventListener("click", calculate);
  document
    .getElementById("toggleScheduleBtn")
    ?.addEventListener("click", toggleSchedule);
  document.getElementById("resetBtn")?.addEventListener("click", resetForm);

  // 포커스 시 기본값 클리어 UX (placeholder가 보이도록)
  ["principal", "years", "rate"].forEach((id) => {
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (!el) return;
    el.addEventListener("focus", () => {
      if (el.value === "0") el.value = "";
    });
  });
</script>
