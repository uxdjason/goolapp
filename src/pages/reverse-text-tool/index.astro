---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "reverse-text-tool");
if (!entry) throw new Error("reverse-text-tool entry not found");
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));
if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="reverse-app">
      <!-- 단일 패널 (입력 및 결과) -->
      <section class="panel" id="mainSection">
        <label for="inputText" class="field-label"
          >텍스트 입력 및 결과 확인</label
        >
        <textarea
          id="inputText"
          class="text-area"
          placeholder="여기에 텍스트를 입력하거나 붙여넣기 하세요."
          rows="8"></textarea>

        <div class="action-group">
          <div class="action-row">
            <button type="button" class="app-btn app-btn-primary" id="charBtn">
              글자 뒤집기
            </button>
            <button type="button" class="app-btn app-btn-primary" id="wordBtn">
              단어 뒤집기
            </button>
          </div>
          <div class="action-row">
            <button type="button" class="app-btn app-btn-outline" id="copyBtn">
              클립보드저장
            </button>
            <button type="button" class="app-btn app-btn-outline" id="resetBtn">
              지우기
            </button>
          </div>
        </div>

        <p class="hint">
          예) "안녕하세요" → 글자 뒤집기: "요세하녕안" / 단어 뒤집기: 공백 기준
          단어 순서를 뒤집습니다.
        </p>
      </section>

      <!-- 토스트 알림 -->
      <div class="toast" id="toast" hidden></div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .reverse-app {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .panel {
    background: none;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .field-label {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text, #111827);
  }

  .text-area {
    width: 100%;
    min-height: 140px;
    padding: 0.875rem 1rem;
    font-size: 1rem;
    line-height: 1.5;
    color: var(--color-text, #111827);
    background: var(--color-background, #ffffff);
    border: 2px solid var(--color-border, #d1d5db);
    border-radius: var(--radius-md, 8px);
    resize: vertical;
    font-family: inherit;
    transition:
      border-color 0.15s ease,
      box-shadow 0.15s ease;
    box-sizing: border-box;
  }

  .text-area:focus {
    outline: none;
    border-color: var(--color-primary, #2563eb);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }

  .action-group {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .action-row {
    display: flex;
    gap: 0.625rem;
    width: 100%;
  }

  .action-row > .app-btn {
    flex: 1;
  }

  .hint {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted, #6b7280);
    line-height: 1.5;
  }

  .toast {
    position: fixed;
    left: 50%;
    bottom: 24px;
    transform: translateX(-50%);
    background: var(--color-text, #111827);
    color: #ffffff;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md, 8px);
    font-size: 0.95rem;
    font-weight: 500;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(-4px);
  }

  .toast[hidden] {
    display: none;
  }
</style>

<script>
  (function () {
    const inputText = document.getElementById(
      "inputText",
    ) as HTMLTextAreaElement | null;
    const charBtn = document.getElementById("charBtn");
    const wordBtn = document.getElementById("wordBtn");
    const copyBtn = document.getElementById("copyBtn");
    const resetBtn = document.getElementById("resetBtn");
    const toast = document.getElementById("toast");

    if (!inputText || !charBtn || !wordBtn || !copyBtn || !resetBtn || !toast) {
      return;
    }

    let toastTimer: number | undefined;
    function showToast(message: string) {
      if (!toast) return;
      toast.textContent = message;
      toast.hidden = false;
      // 다음 프레임에서 show 클래스 부여 (transition 트리거)
      requestAnimationFrame(() => {
        toast.classList.add("show");
      });
      if (toastTimer) window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => {
        toast.classList.remove("show");
        window.setTimeout(() => {
          toast.hidden = true;
        }, 220);
      }, 1800);
    }

    // 유니코드 안전 글자 뒤집기 (서로게이트 페어 처리)
    function reverseChars(str: string): string {
      return Array.from(str).reverse().join("");
    }

    function reverseWords(str: string): string {
      return str.split(/\s+/).reverse().join(" ");
    }

    function doReverse(mode: "char" | "word") {
      const text = (inputText!.value || "").trim();
      if (!text) {
        showToast("텍스트를 입력해 주세요.");
        inputText!.focus();
        return;
      }
      const result = mode === "char" ? reverseChars(text) : reverseWords(text);
      inputText!.value = result;
    }

    charBtn.addEventListener("click", () => doReverse("char"));
    wordBtn.addEventListener("click", () => doReverse("word"));

    copyBtn.addEventListener("click", async () => {
      const value = inputText!.value;
      if (!value) {
        showToast("복사할 텍스트가 없습니다.");
        return;
      }
      try {
        await navigator.clipboard.writeText(value);
        showToast("클립보드에 저장되었습니다.");
      } catch (err) {
        console.error(err);
        showToast("복사에 실패했습니다.");
      }
    });

    resetBtn.addEventListener("click", () => {
      inputText!.value = "";
      inputText!.focus();
    });
  })();
</script>
