    function getChineseZodiac(year) {
      const animals = [
        "원숭이",
        "닭",
        "개",
        "돼지",
        "쥐",
        "소",
        "호랑이",
        "토끼",
        "용",
        "뱀",
        "말",
        "양",
      ];
      return animals[(year - 4) % 12] + "띠";
    }

    function calculateAndDisplay() {
      if (!lmpDateInput || !cycleLengthInput || !resultsSection) return;

      const lmpStr = lmpDateInput.value;
      if (!lmpStr) {
        resultsSection.style.display = "none";
        return;
      }
      const lmp = new Date(lmpStr);
      lmp.setHours(0, 0, 0, 0);
      const cycleLength = parseInt(cycleLengthInput.value) || 28;

      const dueDate = new Date(lmp);
      const cycleAdjustment = cycleLength - 28;
      dueDate.setDate(dueDate.getDate() + 280 + cycleAdjustment);
      estDueDateEl.textContent = formatDate(dueDate);

      const today = new Date();
      today.setHours(0, 0, 0, 0);

      if (lmp > today) {
        resultsSection.style.display = "none";
        return;
      }

      const gestationInMs = today.getTime() - lmp.getTime();
      const gestationInDays = Math.floor(gestationInMs / (1000 * 60 * 60 * 24));

      const weeks = Math.floor(gestationInDays / 7);
      const days = gestationInDays % 7;
      currentGestationEl.textContent = `현재 ${weeks}주 ${days}일째`;

      const countdownInMs = dueDate.getTime() - today.getTime();
      const daysLeft = Math.ceil(countdownInMs / (1000 * 60 * 60 * 24));
      daysCountdownEl.textContent =
        daysLeft >= 0 ? `예정일까지 ${daysLeft}일` : `예정일이 지났습니다.`;

      const progressPercentage = Math.min((gestationInDays / 280) * 100, 100);
      progressBar.style.width = `${progressPercentage}%`;
      // Update label color based on width
      if (progressPercentage > 55) {
        progressLabel.style.color = "var(--color-on-primary)";
      } else {
        progressLabel.style.color = "var(--color-on-surface-variant)";
      }
      progressLabel.textContent = `${weeks}주 / 40주`;

      const conceptionDate = new Date(lmp);
      conceptionDate.setDate(lmp.getDate() + 14 + cycleAdjustment);
      estConceptionDateEl.textContent = formatDate(
        conceptionDate,
        false,
      ).substring(5);

      const firstTrimesterEnd = new Date(lmp);
      firstTrimesterEnd.setDate(firstTrimesterEnd.getDate() + 13 * 7 + 6);
      firstTrimesterEndEl.textContent = formatDate(
        firstTrimesterEnd,
        false,
      ).substring(5);

      const secondTrimesterEnd = new Date(lmp);
      secondTrimesterEnd.setDate(secondTrimesterEnd.getDate() + 27 * 7 + 6);
      secondTrimesterEndEl.textContent = formatDate(
        secondTrimesterEnd,
        false,
      ).substring(5);

      let currentWeekInfo = weeklyInfo.find((info) => info.week === weeks);
      if (weeks >= 41) currentWeekInfo = weeklyInfo[weeklyInfo.length - 1];

      if (weeks < 4) {
        babySizeEmojiEl.textContent = "❓";
        babySizeTextEl.textContent = "아직은 아주 작은 세포예요.";
        babyWeekDescEl.textContent =
          "곧 놀라운 여정이 시작될 거예요. 몸을 편안하게 해주세요.";
      } else if (currentWeekInfo) {
        babySizeEmojiEl.textContent = currentWeekInfo.emoji;
        babySizeTextEl.textContent = currentWeekInfo.size;
        babyWeekDescEl.textContent = currentWeekInfo.desc;
      }

      babyZodiacEl.textContent = getZodiacSign(dueDate);
      babyChineseZodiacEl.textContent = getChineseZodiac(dueDate.getFullYear());

      resultsSection.style.display = "block";
    }

    calculateAndDisplay();
