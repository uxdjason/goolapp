    function formatDate(date, withDay = true) {
      const year = date.getFullYear();
      const month = date.getMonth() + 1;
      const day = date.getDate();
      if (withDay) {
        const dayOfWeek = ["일", "월", "화", "수", "목", "금", "토"][
          date.getDay()
