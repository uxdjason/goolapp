---
import { getEntry, render, getCollection } from "astro:content";
import AppLayout from "../../layouts/AppLayout.astro";
import RelatedApps from "../../components/RelatedApps.astro";

const entry = await getEntry("apps", "due-date-calculator");
if (!entry) {
  throw new Error("due-date-calculator app entry not found");
}
const { Content } = await render(entry);

const allApps = await getCollection("apps");
let related = allApps
  .filter((app) => entry.data.relatedSlugs?.includes(app.data.slug))
  .map((app) => ({
    title: app.data.title,
    shortDescription: app.data.shortDescription,
    slug: app.data.slug,
    category: app.data.category,
  }));

if (related.length === 0) {
  related = allApps
    .filter((app) => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map((app) => ({
      title: app.data.title,
      shortDescription: app.data.shortDescription,
      slug: app.data.slug,
      category: app.data.category,
    }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
  updatedAt={entry.data.updatedAt}
>
  <Fragment slot="app">
    <div class="dd-calculator-container glass-surface">
      <div class="input-section">
        <div class="form-group">
          <label for="lmp-date">마지막 생리 시작일</label>
          <input type="date" id="lmp-date" />
        </div>
        <div class="form-group">
          <label for="cycle-length">평균 생리 주기</label>
          <input type="number" id="cycle-length" value="28" />
          <small>보통 21~35일 사이입니다.</small>
        </div>
      </div>

      <div class="results-section" id="results-section">
        <div class="results-hero">
          <p class="congrats-msg">
            축하드려요! 🎉 소중한 아기를 기다리고 계시는군요.
          </p>
          <p class="due-date-label label-caps">예상 출산 예정일</p>
          <div class="due-date-value" id="est-due-date"></div>
          <div class="hero-sub-info">
            <span id="current-gestation" class="chip-primary chip"></span>
            <span id="days-countdown" class="chip-secondary chip"></span>
          </div>
          <div class="progress-bar-container">
            <div class="progress-bar" id="progress-bar"></div>
            <div class="progress-label" id="progress-label"></div>
          </div>
        </div>

        <div class="results-details">
          <div class="info-card glass-surface-card">
            <h4>나의 임신 타임라인 🗓️</h4>
            <ul>
              <li>
                <span>예상 수정일</span>
                <strong id="est-conception-date"></strong>
              </li>
              <li>
                <span>1분기 종료</span>
                <strong id="first-trimester-end"></strong>
              </li>
              <li>
                <span>2분기 종료</span>
                <strong id="second-trimester-end"></strong>
              </li>
            </ul>
          </div>
          <div class="info-card glass-surface-card" id="baby-week-info-card">
            <h4>이번 주 우리 아기는? 👶</h4>
            <div class="baby-size-container">
              <span id="baby-size-emoji"></span>
              <p id="baby-size-text"></p>
            </div>
            <p id="baby-week-desc"></p>
          </div>
          <div class="info-card glass-surface-card">
            <h4>재미로 알아보는 정보 ✨</h4>
            <ul>
              <li>
                <span>예상 별자리</span>
                <strong id="baby-zodiac"></strong>
              </li>
              <li>
                <span>예상 띠</span>
                <strong id="baby-chinese-zodiac"></strong>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <p class="disclaimer">
        본 계산 결과는 의학적 진단이 아니며, 참고용으로만 활용해 주세요. 정확한
        정보는 병원에 방문하여 의사와 상담하시는 것이 가장 좋습니다.
      </p>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <div class="prose">
      <Content />
    </div>
    {related.length > 0 && <RelatedApps apps={related} />}
  </Fragment>
</AppLayout>

<style>
  .dd-calculator-container {
    padding: var(--space-8);
    width: 100%;
    box-sizing: border-box;
    margin: var(--space-8) auto;
  }

  .header {
