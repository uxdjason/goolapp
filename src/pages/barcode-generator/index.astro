---
import { getEntry, render, getCollection } from 'astro:content';
import AppLayout from '../../layouts/AppLayout.astro';
import RelatedApps from '../../components/RelatedApps.astro';

const entry = await getEntry('apps', 'barcode-generator');
if (!entry) throw new Error('barcode-generator entry not found');
const { Content } = await render(entry);

const allApps = await getCollection('apps');
let related = allApps
  .filter(app => entry.data.relatedSlugs?.includes(app.data.slug))
  .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
if (related.length === 0) {
  related = allApps
    .filter(app => app.data.slug !== entry.data.slug)
    .slice(0, 3)
    .map(app => ({ title: app.data.title, shortDescription: app.data.shortDescription, slug: app.data.slug, category: app.data.category }));
}
---

<AppLayout
  title={entry.data.title}
  description={entry.data.seo.description}
  shortDescription={entry.data.shortDescription}
  category={entry.data.category}
  keywords={entry.data.seo.secondaryKeywords}
  ogImage={entry.data.seo.ogImage}
  ogTitle={entry.data.seo.ogTitle}
  ogDescription={entry.data.seo.ogDescription}
  canonicalUrl={`https://goolapp.com${entry.data.seo.canonicalPath}`}
  publishedAt={entry.data.publishedAt}
>
  <Fragment slot="app">
    <div class="barcode-app">
      <div class="form-section">
        <label class="field-label" for="textInput">
          바코드 데이터 <span class="required">*</span>
        </label>
        <input
          id="textInput"
          type="text"
          class="text-input"
          placeholder="영문·숫자·특수문자 1~30자"
          maxlength="30"
          autocomplete="off"
        />
        <p class="hint">ASCII 출력 가능 문자(영문, 숫자, 공백, 특수문자)만 입력할 수 있습니다.</p>

        <label class="field-label" for="labelInput">
          바코드 레이블 <span class="optional">(선택)</span>
        </label>
        <input
          id="labelInput"
          type="text"
          class="text-input"
          placeholder="바코드 아래에 표시할 텍스트"
          autocomplete="off"
        />

        <div class="actions">
          <button id="generateBtn" type="button" class="btn btn-primary">
            바코드 생성
          </button>
          <button id="saveBtn" type="button" class="btn btn-secondary" hidden>
            바코드 저장 (PNG)
          </button>
        </div>

        <p id="errorMsg" class="error-msg" hidden></p>
      </div>

      <div class="result-section" id="resultSection" hidden>
        <h3 class="result-title">생성된 바코드</h3>
        <div id="barcodeContainer" class="barcode-container"></div>
      </div>

      <div class="empty-state" id="emptyState">
        <div class="empty-icon">▭▭▭</div>
        <p>위에 바코드로 만들 데이터를 입력한 후<br/>"바코드 생성" 버튼을 눌러주세요.</p>
      </div>
    </div>
  </Fragment>

  <Fragment slot="longform">
    <Content />
    <RelatedApps apps={related} />
  </Fragment>
</AppLayout>

<style>
  .barcode-app {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-section {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--color-surface);
    padding: 1.5rem;
    border-radius: var(--radius-md, 12px);
    border: 1px solid var(--color-border);
  }

  .field-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-top: 0.5rem;
  }

  .required {
    color: var(--color-danger, #e53935);
    font-weight: 700;
  }

  .optional {
    color: var(--color-text-muted, #888);
    font-weight: 400;
    font-size: 0.85rem;
  }

  .text-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 2px solid var(--color-border, #d1d5db);
    border-radius: var(--radius-sm, 8px);
    background: var(--color-background);
    color: var(--color-text);
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .text-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-soft, rgba(59, 130, 246, 0.15));
  }

  .hint {
    font-size: 0.8rem;
    color: var(--color-text-muted, #6b7280);
    margin: 0;
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .btn {
    width: 100%;
    padding: 0.85rem 1.25rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: var(--radius-sm, 8px);
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background-color 0.15s;
    border: 2px solid transparent;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-on-primary, #fff);
  }

  .btn-primary:hover {
    box-shadow: 0 4px 12px var(--color-primary-soft, rgba(59, 130, 246, 0.3));
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .btn-secondary:hover {
    background: var(--color-primary-soft, rgba(59, 130, 246, 0.08));
  }

  .btn[hidden] {
    display: none;
  }

  .error-msg {
    color: var(--color-danger, #e53935);
    background: var(--color-danger-soft, rgba(229, 57, 53, 0.08));
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm, 8px);
    margin: 0;
    font-size: 0.9rem;
  }

  .error-msg[hidden] {
    display: none;
  }

  .result-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    background: var(--color-surface);
    padding: 1.5rem;
    border-radius: var(--radius-md, 12px);
    border: 1px solid var(--color-border);
  }

  .result-section[hidden] {
    display: none;
  }

  .result-title {
    margin: 0;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .barcode-container {
    display: flex;
    justify-content: center;
    align-items: center;
    background: #ffffff;
    padding: 1rem;
    border-radius: var(--radius-sm, 8px);
    border: 1px solid var(--color-border);
    max-width: 100%;
    overflow-x: auto;
  }

  .barcode-container :global(canvas) {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1rem;
    color: var(--color-text-muted, #888);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-md, 12px);
    background: var(--color-surface);
  }

  .empty-state[hidden] {
    display: none;
  }

  .empty-icon {
    font-size: 2rem;
    letter-spacing: 0.2em;
    color: var(--color-border);
    margin-bottom: 0.75rem;
  }

  .empty-state p {
    margin: 0;
    line-height: 1.6;
  }
</style>

<script>
  // JsBarcode 라이브러리 CDN 로드 (CODE128 바코드 렌더링용)
  // 추후 npm 패키지화 가능: npm install jsbarcode
  const JSBARCODE_CDN = 'https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js';

  function loadJsBarcode(): Promise<any> {
    return new Promise((resolve, reject) => {
      if ((window as any).JsBarcode) {
        resolve((window as any).JsBarcode);
        return;
      }
      const existing = document.querySelector(`script[src="${JSBARCODE_CDN}"]`);
      if (existing) {
        existing.addEventListener('load', () => resolve((window as any).JsBarcode));
        existing.addEventListener('error', reject);
        return;
      }
      const script = document.createElement('script');
      script.src = JSBARCODE_CDN;
      script.async = true;
      script.onload = () => resolve((window as any).JsBarcode);
      script.onerror = () => reject(new Error('JsBarcode 로드 실패'));
      document.head.appendChild(script);
    });
  }

  const textInput = document.getElementById('textInput') as HTMLInputElement;
  const labelInput = document.getElementById('labelInput') as HTMLInputElement;
  const generateBtn = document.getElementById('generateBtn') as HTMLButtonElement;
  const saveBtn = document.getElementById('saveBtn') as HTMLButtonElement;
  const errorMsg = document.getElementById('errorMsg') as HTMLParagraphElement;
  const resultSection = document.getElementById('resultSection') as HTMLDivElement;
  const emptyState = document.getElementById('emptyState') as HTMLDivElement;
  const barcodeContainer = document.getElementById('barcodeContainer') as HTMLDivElement;

  const ASCII_RE = /^[\x20-\x7E]{1,30}$/;

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.hidden = false;
  }

  function clearError() {
    errorMsg.textContent = '';
    errorMsg.hidden = true;
  }

  async function generateBarcode() {
    clearError();
    const text = textInput.value.trim();
    const label = labelInput.value.trim();

    if (!text) {
      showError('바코드 데이터를 입력해주세요.');
      return;
    }
    if (!ASCII_RE.test(text)) {
      showError('영문·숫자·특수문자(ASCII) 1~30자만 입력 가능합니다. 한글은 지원되지 않습니다.');
      return;
    }

    let JsBarcode: any;
    try {
      JsBarcode = await loadJsBarcode();
    } catch (e) {
      showError('바코드 라이브러리를 불러오지 못했습니다. 네트워크를 확인해 주세요.');
      return;
    }

    try {
      // 임시 캔버스에 바코드 그리기
      const tempCanvas = document.createElement('canvas');
      JsBarcode(tempCanvas, text, {
        format: 'CODE128',
        width: 2,
        height: 100,
        displayValue: false,
        margin: 10,
        background: '#ffffff',
      });

      // 최종 캔버스에 바코드 + 텍스트 + 레이블 합성
      const finalCanvas = document.createElement('canvas');
      finalCanvas.width = tempCanvas.width;
      finalCanvas.height = tempCanvas.height + 50;
      const ctx = finalCanvas.getContext('2d')!;
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, finalCanvas.width, finalCanvas.height);
      ctx.drawImage(tempCanvas, 0, 0);

      const centerX = finalCanvas.width / 2;
      ctx.textAlign = 'center';
      ctx.fillStyle = '#000000';
      ctx.font = 'bold 16px sans-serif';
      ctx.fillText(text, centerX, tempCanvas.height + 20);

      if (label !== '') {
        ctx.fillStyle = '#555555';
        ctx.font = '14px sans-serif';
        ctx.fillText(label, centerX, tempCanvas.height + 40);
      }

      barcodeContainer.innerHTML = '';
      barcodeContainer.appendChild(finalCanvas);

      emptyState.hidden = true;
      resultSection.hidden = false;

      setTimeout(() => {
        saveBtn.hidden = false;
      }, 200);
    } catch (e) {
      console.error(e);
      showError('바코드 생성 중 오류가 발생했습니다. 입력값을 확인해주세요.');
    }
  }

  function saveBarcode() {
    const canvas = barcodeContainer.querySelector('canvas') as HTMLCanvasElement | null;
    if (!canvas) {
      showError('저장할 바코드가 없습니다. 먼저 바코드를 생성해주세요.');
      return;
    }
    try {
      const dataURL = canvas.toDataURL('image/png');
      const a = document.createElement('a');
      a.href = dataURL;
      a.download = 'barcode.png';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    } catch (e) {
      showError('이미지 저장 중 오류가 발생했습니다.');
    }
  }

  generateBtn.addEventListener('click', generateBarcode);
  saveBtn.addEventListener('click', saveBarcode);

  textInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      generateBarcode();
    }
  });
  labelInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      e.preventDefault();
      generateBarcode();
    }
  });
</script>