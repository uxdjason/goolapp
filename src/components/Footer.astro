---
const currentYear = new Date().getFullYear();
---

<!-- Footer: from goolapp-home-260507.md Footer Component spec -->
<footer class="global-footer">
  <div class="footer-inner">
    <!-- Left: logo icon + "GoolAPP" text -->
    <a href="/" class="logo-link" aria-label="GoolAPP 홈으로">
      <img
        src="/logo.png"
        alt=""
        class="logo-icon"
        width="40"
        height="40"
        aria-hidden="true"
      />
      <span class="logo-text">GoolAPP</span>
    </a>

    <!-- Center: copyright -->
    <p class="footer-copyright">
      © 2025-{currentYear} GoolAPP 굴랩. All rights reserved.
    </p>

    <!-- Right: nav links -->
    <nav class="footer-nav" aria-label="하단 링크">
      <ul>
        <li><a href="/contact-us/">사용 문의</a></li>
        <li><a href="/privacy-policy/">개인정보 처리방침</a></li>
      </ul>
    </nav>
  </div>
</footer>

<style>
  /* Footer: background #F5F3EF, border-top 1px solid rgba(216,194,185,0.3) */
  .global-footer {
    background: #f5f3ef;
    border-top: 1px solid rgba(216, 194, 185, 0.3);
    padding: 0;
  }
  .footer-inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 40px 48px;
    gap: 16px;
    min-height: 120px;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
  }
  .logo-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
  .logo-text {
    /* from design: 24px bold, color #350F00 */
    font-family: var(--font-family-base);
    font-weight: 700;
    font-size: 24px;
    line-height: 31px;
    letter-spacing: -0.6px;
    color: #350f00;
  }

  .footer-copyright {
    /* from design: 16px regular, color #53433D */
    margin: 0;
    font-family: var(--font-family-base);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #53433d;
    text-align: center;
  }

  /* Nav: gap 32px, 16px regular, #53433D */
  .footer-nav ul {
    display: flex;
    flex-direction: column; /* Desktop is column as per design */
    align-items: flex-start;
    gap: 16px; /* Stacked links gap */
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .footer-nav a {
    font-family: var(--font-family-base);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #53433d;
    text-decoration: none;
    opacity: 0.8;
    transition: color var(--transition-fast);
  }
  .footer-nav a:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
      padding: 32px 16px;
    }
    .logo-link {
      order: 1;
      margin-bottom: 24px;
      justify-content: center;
    }
    .footer-nav {
      order: 2;
      margin-bottom: 24px;
    }
    .footer-nav ul {
      flex-direction: row; /* Mobile is horizontal */
      flex-wrap: wrap;
      justify-content: center;
      gap: 32px;
    }
    .footer-copyright {
      order: 3;
      text-align: center;
    }
  }
</style>
