---
const currentYear = new Date().getFullYear();
---
<!-- Footer: from goolapp-home-260507.md Footer Component spec -->
<footer class="global-footer">
  <div class="footer-inner">
    <!-- Left: logo icon + "GoolAPP" text + copyright -->
    <div class="footer-brand">
      <div class="footer-logo-row">
        <img src="/logo.png" alt="" class="footer-logo-icon" width="40" height="40" aria-hidden="true" />
        <span class="footer-logo-text">GoolAPP</span>
      </div>
      <p class="footer-copyright">© {currentYear}-{currentYear + 1} GoolAPP 굴랩. All rights reserved.</p>
    </div>

    <!-- Right: nav links -->
    <nav class="footer-nav" aria-label="하단 링크">
      <ul>
        <li><a href="#">사용 문의</a></li>
        <li><a href="/privacy">개인정보 처리방침</a></li>
      </ul>
    </nav>
  </div>
</footer>

<style>
  /* Footer: background #F5F3EF, border-top 1px solid rgba(216,194,185,0.3) */
  .global-footer {
    background: #f5f3ef;
    border-top: 1px solid rgba(216, 194, 185, 0.3);
    padding: 0;
  }
  .footer-inner {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 40px 48px;
    gap: 0;
    min-height: 120px;
  }

  /* Brand: logo + text side by side, copyright below */
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-logo-row {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .footer-logo-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
  }
  .footer-logo-text {
    /* from design: 24px bold, color #350F00 */
    font-family: var(--font-family-base);
    font-weight: 700;
    font-size: 24px;
    line-height: 31px;
    color: #350f00;
  }
  .footer-copyright {
    /* from design: 16px regular, color #53433D */
    margin: 0;
    font-family: var(--font-family-base);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #53433d;
  }

  /* Nav: gap 32px, 16px regular, #53433D */
  .footer-nav ul {
    display: flex;
    flex-direction: row;
    gap: 32px;
    list-style: none;
    margin: 0; padding: 0;
  }
  .footer-nav a {
    font-family: var(--font-family-base);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #53433d;
    text-decoration: none;
    opacity: 0.8;
    transition: color var(--transition-fast);
  }
  .footer-nav a:hover { color: var(--color-primary); opacity: 1; }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0;
      padding: 32px 16px;
    }
    .footer-brand {
      display: contents;
    }
    .footer-logo-row {
      order: 1;
      margin-bottom: 24px;
      justify-content: center;
    }
    .footer-nav {
      order: 2;
      margin-bottom: 24px;
    }
    .footer-nav ul { 
      flex-wrap: wrap; 
      justify-content: center;
      gap: 32px; 
    }
    .footer-copyright {
      order: 3;
    }
  }
</style>
