---
interface Props {
  placeholder?: string;
  categorySlug?: string;
}
const { placeholder = "어떤 앱이 필요하세요?", categorySlug } = Astro.props;
---
<div class="search-container">
  <form action="/search" method="get" class="search-form" id="search-form">
    <div class="search-bar" role="search">
      {categorySlug && <input type="hidden" name="c" value={categorySlug} />}
      <div class="search-icon-wrap" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8B4F32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </div>
      <input
        type="search"
        name="q"
        id="app-search"
        class="search-input"
        placeholder={placeholder}
        aria-label="앱 검색"
        autocomplete="off"
        required
      />
      <button type="submit" class="search-btn">찾기</button>
    </div>
  </form>
  <div class="recent-searches" id="recent-searches" style="display: none;">
    <div class="recent-header">
      <span>최근 검색어</span>
      <button type="button" class="clear-recent" id="clear-recent">모두 지우기</button>
    </div>
    <ul class="recent-list" id="recent-list"></ul>
  </div>
</div>

<style>
  .search-container {
    position: relative;
    width: 100%;
    max-width: 672px;
    margin: 0 auto;
  }
  .search-bar {
    display: flex;
    align-items: center;
    width: 100%;
    height: 72px;
    padding: 8px;
    background: rgba(245, 243, 239, 0.5);
    border: 1px solid rgba(216, 194, 185, 0.5);
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-radius: 9999px;
    box-sizing: border-box;
  }
  .search-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex-shrink: 0;
  }
  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--font-family-gothic);
    font-size: 18px;
    font-weight: 400;
    color: rgba(83, 67, 61, 0.8);
    padding: 0 12px;
    min-width: 0;
  }
  .search-input::placeholder { color: rgba(83, 67, 61, 0.6); }
  .search-btn {
    flex-shrink: 0;
    padding: 12px 24px;
    height: 48px;
    background: var(--color-primary);
    color: #ffffff;
    border: none;
    border-radius: 9999px;
    font-family: var(--font-family-gothic);
    font-size: 16px;
    font-weight: 700;
    line-height: 24px;
    cursor: pointer;
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
    transition: background var(--transition-fast);
    white-space: nowrap;
  }
  .search-btn:hover:not(:disabled) { background: #713a1f; }

  /* Recent searches dropdown */
  .recent-searches {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: rgba(251, 249, 245, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(216, 194, 185, 0.5);
    border-radius: 16px;
    box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.1);
    z-index: 10;
    padding: 16px;
    text-align: left;
  }
  .recent-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-family-gothic);
    font-size: 14px;
    color: #53433d;
    margin-bottom: 12px;
    font-weight: 700;
  }
  .clear-recent {
    background: none;
    border: none;
    color: #8b4f32;
    font-size: 13px;
    cursor: pointer;
    padding: 0;
  }
  .clear-recent:hover { text-decoration: underline; }
  .recent-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .recent-list li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-radius: 8px;
    cursor: pointer;
    transition: background var(--transition-fast);
    font-family: var(--font-family-gothic);
    font-size: 16px;
    color: #350f00;
  }
  .recent-list li:hover {
    background: rgba(139, 79, 50, 0.06);
  }
  .recent-list li a {
    text-decoration: none;
    color: inherit;
    flex: 1;
    display: block;
  }

  @media (max-width: 768px) {
    .search-bar { height: auto; }
  }
</style>

<script>
  const SEARCH_KEY = 'goolapp_recent_searches';
  
  function getRecentSearches() {
    try {
      return JSON.parse(localStorage.getItem(SEARCH_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function addRecentSearch(query: string) {
    let searches = getRecentSearches();
    searches = searches.filter((q: string) => q !== query);
    searches.unshift(query);
    if (searches.length > 10) searches = searches.slice(0, 10);
    localStorage.setItem(SEARCH_KEY, JSON.stringify(searches));
  }

  function renderRecentSearches() {
    const searches = getRecentSearches();
    const list = document.getElementById('recent-list');
    const container = document.getElementById('recent-searches');
    if (!list || !container) return;

    if (searches.length === 0) {
      container.style.display = 'none';
      return;
    }

    list.innerHTML = '';
    searches.forEach((query: string) => {
      const li = document.createElement('li');
      
      const a = document.createElement('a');
      a.href = `/search?q=${encodeURIComponent(query)}`;
      a.textContent = query;
      
      li.appendChild(a);
      list.appendChild(li);
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const searchForm = document.getElementById('search-form');
    const searchInput = document.getElementById('app-search');
    const recentContainer = document.getElementById('recent-searches');
    const clearBtn = document.getElementById('clear-recent');

    // On submit, save the query
    if (searchForm && searchInput) {
      searchForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const query = (searchInput as HTMLInputElement).value.trim();
        const urlParams = new URLSearchParams(window.location.search);
        const currentCategory = urlParams.get('c');
        const formCategoryInput = searchForm.querySelector('input[name="c"]') as HTMLInputElement;
        const formCategory = formCategoryInput ? formCategoryInput.value : currentCategory;

        if (query) {
          addRecentSearch(query);
          let url = `/search?q=${encodeURIComponent(query)}`;
          if (formCategory) url += `&c=${encodeURIComponent(formCategory)}`;
          window.location.href = url;
        } else {
          // If query is empty, go back to category or home
          if (formCategory) {
            window.location.href = `/category/${formCategory}`;
          } else {
            window.location.href = '/';
          }
        }
      });
      
      // Auto-fill input if we are on /search page
      const urlParams = new URLSearchParams(window.location.search);
      const q = urlParams.get('q');
      if (q) {
        (searchInput as HTMLInputElement).value = q;
      }
    }

    // Show recent searches on focus
    if (searchInput && recentContainer) {
      searchInput.addEventListener('focus', () => {
        renderRecentSearches();
        const searches = getRecentSearches();
        if (searches.length > 0) {
          recentContainer.style.display = 'block';
        }
      });

      // Hide recent searches when clicking outside
      document.addEventListener('click', (e) => {
        if (!searchInput.contains(e.target as Node) && !recentContainer.contains(e.target as Node)) {
          recentContainer.style.display = 'none';
        }
      });
    }

    // Clear recent searches
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        localStorage.removeItem(SEARCH_KEY);
        if (recentContainer) recentContainer.style.display = 'none';
      });
    }
  });
</script>
