---
---
<header class="global-header" id="global-header">
  <div class="container header-inner">
    <!-- Logo: icon + "GoolAPP" text side by side (from design spec) -->
    <a href="/" class="logo-link" aria-label="GoolAPP 홈으로">
      <img src="/logo.png" alt="" class="logo-icon" width="40" height="40" aria-hidden="true" />
      <span class="logo-text">GoolAPP</span>
    </a>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="mobile-menu-btn" aria-label="모바일 메뉴 열기" aria-expanded="false">
      <!-- Hamburger Icon -->
      <svg class="icon-hamburger" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 12H21" stroke="#8B4F32" stroke-width="2" stroke-linecap="round"/>
        <path d="M3 6H21" stroke="#8B4F32" stroke-width="2" stroke-linecap="round"/>
        <path d="M3 18H21" stroke="#8B4F32" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <!-- Close Icon -->
      <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 6L6 18" stroke="#8B4F32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M6 6L18 18" stroke="#8B4F32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <!-- Nav items: from goolapp-home-260507.md nav section -->
    <nav class="main-nav" aria-label="주요 메뉴">
      <ul>
        <li><a href="/category/calculator">각종 계산기</a></li>
        <li><a href="/category/datetime">날짜와 시간</a></li>
        <li><a href="/category/finance">금융 재테크</a></li>
        <li><a href="/category/tool">편리한 도구들</a></li>
        <li><a href="/category/quiz">학습 및 퀴즈</a></li>
        <li><a href="/category/fun">심심풀이 Fun</a></li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.querySelector('.main-nav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!isExpanded));
      nav.classList.toggle('is-active');
    });
  }
</script>

<style>
  .global-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 80px;
    /* from design spec: TopNavBar */
    background: rgba(251, 249, 245, 0.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.05);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    padding: 0 48px;
    max-width: var(--container-max);
    margin: 0 auto;
  }

  /* Logo container: icon + text (gap: 16px from spec) */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .logo-text {
    /* from design: 24px bold, letter-spacing -0.6px, color #350F00 */
    font-family: var(--font-family-base);
    font-weight: 700;
    font-size: 24px;
    line-height: 31px;
    letter-spacing: -0.6px;
    color: #350f00;
    white-space: nowrap;
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }
  .icon-close { display: none; }
  .mobile-menu-btn[aria-expanded="true"] .icon-hamburger { display: none; }
  .mobile-menu-btn[aria-expanded="true"] .icon-close { display: block; }

  /* Nav: gap 32px, each link 16px, color #53433D */
  .main-nav ul {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0; padding: 0;
  }
  .main-nav a {
    display: flex;
    align-items: center;
    padding: 4px 8px;
    border-radius: 4px;
    font-family: var(--font-family-base);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #53433d;
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--transition-fast), background var(--transition-fast);
  }
  .main-nav a:hover {
    color: var(--color-primary);
    background: rgba(139, 79, 50, 0.06);
  }

  /* Mobile */
  @media (max-width: 900px) {
    .global-header { height: 60px; }
    .header-inner { height: 60px; padding: 0 var(--gutter-mobile); }
    .logo-icon { width: 32px; height: 32px; }
    .logo-text { font-size: 20px; }
    
    .mobile-menu-btn {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .main-nav { 
      display: none; 
    }
    .main-nav.is-active {
      display: block;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: rgba(251, 249, 245, 0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(216, 194, 185, 0.3);
      padding: 16px var(--gutter-mobile);
      box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.05);
    }
    .main-nav.is-active ul {
      flex-direction: column;
      gap: 8px;
    }
    .main-nav.is-active a {
      font-size: 16px;
      padding: 12px 8px;
    }
  }
</style>
