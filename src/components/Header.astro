---
---
<header class="global-header" id="global-header">
  <div class="container header-inner">
    <a href="/" class="logo-link" aria-label="GoolAPP 홈으로">
      <img src="/logo.png" alt="GoolAPP" class="logo-img" width="120" height="32" />
    </a>
    <nav class="main-nav" aria-label="주요 메뉴">
      <ul>
        <li><a href="/category/calculator">계산기</a></li>
        <li><a href="/category/tool">유틸리티</a></li>
        <li><a href="/category/quiz">퀴즈</a></li>
        <li><a href="/category/converter">변환기</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .global-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 72px;
    /* Glassmorphism nav — from design spec */
    background: rgba(251, 249, 245, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(216, 194, 185, 0.5);
    box-shadow: 0px 1px 2px rgba(0, 0, 0, 0.05);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .logo-img {
    height: 32px;
    width: auto;
    object-fit: contain;
  }
  .main-nav ul {
    display: flex;
    gap: var(--space-8);
    list-style: none;
    margin: 0; padding: 0;
  }
  .main-nav a {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color var(--transition-fast);
  }
  .main-nav a:hover {
    color: var(--color-primary);
  }

  /* Mobile: hide nav links, show hamburger placeholder */
  @media (max-width: 768px) {
    .main-nav {
      display: none;
    }
    .global-header {
      height: 60px;
    }
    .header-inner {
      height: 60px;
    }
    .logo-img {
      height: 26px;
    }
  }
</style>
