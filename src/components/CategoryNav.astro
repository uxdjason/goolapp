---
interface Props {
  activeCategory?: string;
}
const { activeCategory = 'all' } = Astro.props;

const categories = [
  { id: 'all',        label: '모든 앱',    href: '/',                    star: false },
  { id: 'favorites',  label: '즐겨찾는 앱', href: '/#favorites',          star: true  },
  { id: 'calculator', label: '계산기',     href: '/category/calculator', star: false },
  { id: 'datetime',   label: '날짜/시간',  href: '/category/datetime',   star: false },
  { id: 'finance',    label: '금융 재테크', href: '/category/finance',  star: false },
  { id: 'tool',       label: '유틸리티',   href: '/category/tool',       star: false },
  { id: 'quiz',       label: '퀴즈',       href: '/category/quiz',       star: false },
  { id: 'fun',        label: 'FUN',        href: '/category/fun',        star: false },
];
---
<nav class="category-nav" aria-label="카테고리 필터">
  <ul class="category-list">
    {categories.map(cat => (
      <li>
        <a
          href={cat.href}
          class={`cat-btn ${cat.star ? 'cat-btn--star' : ''} ${activeCategory === cat.id ? 'active' : ''}`}
          aria-current={activeCategory === cat.id ? 'page' : undefined}
        >
          {cat.star && (
            <span class="star-mark" aria-hidden="true">
              <img src="/img/star-btn-1.png" alt="" width="16" height="16" style="display: block;" />
            </span>
          )}
          {cat.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .category-nav {
    margin-bottom: var(--space-10);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .category-nav::-webkit-scrollbar { display: none; }
  .category-list {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    list-style: none;
    padding: 2px 0 4px;
    min-width: auto;
    margin: 0 auto;
  }

  /* 고딕 폰트, 14px bold — 기존 12px보다 살짝 크게 */
  .cat-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 20px;
    height: 32px;
    background: rgba(251, 249, 245, 0.6);
    border: 1px solid rgba(216, 194, 185, 0.5);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 9999px;
    font-family: var(--font-family-gothic);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #53433d;
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition-fast);
    box-sizing: border-box;
    cursor: pointer;
  }
  .cat-btn:hover {
    border-color: rgba(139, 79, 50, 0.5);
    color: var(--color-primary);
  }
  .cat-btn.active {
    border: 1px solid var(--color-primary);
    box-shadow: 0px 0px 15px rgba(139, 79, 50, 0.15);
    color: var(--color-primary);
  }

  /* Star icon — visible, 16px */
  .star-mark {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    line-height: 1;
  }


</style>
