---
interface Props {
  activeCategory?: string;
}
const { activeCategory = 'all' } = Astro.props;

const categories = [
  { id: 'all',        label: '모든 앱',   href: '/'                    },
  { id: 'calculator', label: '계산기',    href: '/category/calculator' },
  { id: 'converter',  label: '변환기',    href: '/category/converter'  },
  { id: 'quiz',       label: '퀴즈',      href: '/category/quiz'       },
  { id: 'tool',       label: '유틸리티',  href: '/category/tool'       },
  { id: 'misc',       label: '기타',      href: '/category/misc'       },
];
---
<nav class="category-nav" aria-label="카테고리 필터">
  <ul class="category-list">
    {categories.map(cat => (
      <li>
        <a
          href={cat.href}
          class={`cat-btn ${activeCategory === cat.id ? 'active' : ''}`}
          aria-current={activeCategory === cat.id ? 'page' : undefined}
        >
          {cat.id === 'all' && <span class="star-icon" aria-hidden="true">★</span>}
          {cat.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .category-nav {
    margin-bottom: var(--space-10);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .category-nav::-webkit-scrollbar { display: none; }

  .category-list {
    display: flex;
    gap: 12px;
    list-style: none;
    padding: 2px 0 4px;
    min-width: max-content;
  }

  /* Default (inactive) button — from design spec */
  .cat-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 24px;
    height: 30px;
    background: rgba(251, 249, 245, 0.6);
    border: 1px solid rgba(216, 194, 185, 0.5);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: var(--radius-full);
    font-family: var(--font-family-base);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    color: var(--color-on-surface);
    text-decoration: none;
    white-space: nowrap;
    transition: all var(--transition-fast);
    cursor: pointer;
  }
  .cat-btn:hover {
    border-color: rgba(139, 79, 50, 0.4);
    color: var(--color-primary);
  }

  /* Active button — from design spec: primary border + glow */
  .cat-btn.active {
    background: rgba(251, 249, 245, 0.6);
    border: 1px solid var(--color-primary);
    box-shadow: 0px 0px 15px rgba(139, 79, 50, 0.15);
    color: var(--color-primary);
  }

  .star-icon {
    font-size: 10px;
    line-height: 1;
    color: inherit;
  }

  @media (max-width: 768px) {
    .category-list { gap: 8px; }
    .cat-btn { padding: 8px 16px; }
  }
</style>
