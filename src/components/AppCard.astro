---
interface Props {
  title: string;
  shortDescription: string;
  slug: string;
  category: string[];
  contentSnippet?: string;
}
const { title, shortDescription, slug, category, contentSnippet = '' } = Astro.props;

const categoryLabels: Record<string, string> = {
  calculator: '각종 계산기',
  datetime:   '날짜와 시간',
  tool:       '편리한 도구들',
  quiz:       '학습 및 퀴즈',
  fun:        '심심풀이 Fun',
  finance:    '금융 재테크',
};
const catLabel = category.map(c => categoryLabels[c] ?? c).join(', ');
const categorySlugs = category.join(',');
---
<article class="app-card" data-slug={slug} data-title={title} data-desc={shortDescription} data-content={contentSnippet} data-category-slugs={categorySlugs}>
  <!-- Top row: category chip + favourite star -->
  <div class="card-top">
    <span class="cat-chip">
      {catLabel}
    </span>
    <button class="fav-btn" data-app-slug={slug} aria-label="즐겨찾기" title="즐겨찾기">
      <img src="/img/star-btn-0.png" class="fav-icon" alt="즐겨찾기" width="24" height="24" />
    </button>
  </div>

  <!-- Card title + description -->
  <h3 class="card-title">
    <a href={`/${slug}`} class="app-link">{title}</a>
  </h3>
  <p class="card-desc">{shortDescription}</p>
</article>

<style>
  .app-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(216, 194, 185, 0.3);
    box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.03);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 12px;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    height: 100%;
  }
  .app-card:hover {
    transform: translateY(-4px);
    box-shadow: 0px 30px 60px rgba(139, 79, 50, 0.10);
  }

  .card-top {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  /* Category chip: Gothic font, 13px, No bullet */
  .cat-chip {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    border-radius: 9999px;
    background: rgba(243, 166, 131, 0.4);
    font-family: var(--font-family-gothic);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-primary);
  }

  .fav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    transition: transform var(--transition-fast);
  }
  .fav-btn:hover { transform: scale(1.1); }
  
  .fav-icon {
    width: 100%;
    height: auto;
  }

  .card-title {
    font-family: var(--font-family-base);
    font-size: 24px;
    font-weight: 700;
    line-height: 31px;
    margin-bottom: 8px;
    margin-top: 0;
  }
  .app-link {
    color: #350f00;
    text-decoration: none;
  }
  .app-link:hover {
    text-decoration: underline;
  }

  .card-desc {
    font-family: var(--font-family-base);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #53433d;
    margin: 0;
  }

  @media (max-width: 768px) {
    .card-title { font-size: 20px; }
    .card-desc  { font-size: 14px; }
  }
</style>
