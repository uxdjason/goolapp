---
interface Props {
  title: string;
  shortDescription: string;
  slug: string;
  category: string;
}
const { title, shortDescription, slug, category } = Astro.props;

const categoryLabels: Record<string, string> = {
  calculator: '계산기',
  quiz:       '퀴즈',
  converter:  '변환기',
  tool:       '유틸리티',
  misc:       '기타',
};
const catLabel = categoryLabels[category] ?? category;
---
<a href={`/${slug}`} class="app-card" aria-label={`${title} 앱 열기`}>
  <!-- Card header: category chip + favourite star -->
  <div class="card-top">
    <span class="cat-chip label-caps chip-primary">
      <span class="chip-dot" aria-hidden="true">●</span>
      {catLabel}
    </span>
    <button class="fav-btn" aria-label="즐겨찾기" title="즐겨찾기">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    </button>
  </div>

  <!-- Card body -->
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{shortDescription}</p>
  </div>
</a>

<style>
  /* Card — from goolapp-home-260507.md + goolapp-home-mobile-260508.md */
  .app-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: 24px;
    text-decoration: none;
    color: inherit;

    /* Glass card surface */
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(216, 194, 185, 0.3);
    box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.03);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 12px;

    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .app-card:hover {
    transform: translateY(-4px);
    box-shadow: 0px 30px 60px rgba(139, 79, 50, 0.1);
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-2);
  }

  /* Category chip — from design spec */
  .cat-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 16px;
    border-radius: var(--radius-full);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
  }
  .chip-dot {
    font-size: 8px;
    line-height: 1;
  }

  /* Favourite star button */
  .fav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: none;
    border: 1px solid rgba(139, 79, 50, 0.5);
    border-radius: 2px;
    color: var(--color-outline-variant);
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
    flex-shrink: 0;
  }
  .fav-btn:hover {
    color: #fff809;
    border-color: var(--color-primary);
  }

  .card-title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-on-surface);
    margin-bottom: var(--space-2);
    letter-spacing: -0.02em;
  }
  .card-desc {
    font-size: var(--font-size-sm);
    color: var(--color-on-surface-variant);
    line-height: 1.55;
    margin: 0;
  }

  @media (max-width: 768px) {
    .app-card { padding: 24px; border-radius: 12px; }
    .card-title { font-size: var(--font-size-base); }
  }
</style>
