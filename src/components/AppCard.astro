---
interface Props {
  title: string;
  shortDescription: string;
  slug: string;
  category: string;
}
const { title, shortDescription, slug, category } = Astro.props;

const categoryLabels: Record<string, string> = {
  calculator: '계산기', quiz: '퀴즈', converter: '변환기', tool: '유틸리티', misc: '기타',
};
const catLabel = categoryLabels[category] ?? category;
---
<a href={`/${slug}`} class="app-card" aria-label={`${title} 열기`}>
  <!-- Top row: category chip + favourite star -->
  <div class="card-top">
    <span class="cat-chip">
      {catLabel}
    </span>
    <button class="fav-btn" aria-label="즐겨찾기" title="즐겨찾기" tabindex="-1">
      <!-- Star icon: Larger and clearer -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    </button>
  </div>

  <!-- Card title + description -->
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{shortDescription}</p>
</a>

<style>
  .app-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(216, 194, 185, 0.3);
    box-shadow: 0px 20px 40px rgba(74, 68, 63, 0.03);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: 12px;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    height: 100%;
  }
  .app-card:hover {
    transform: translateY(-4px);
    box-shadow: 0px 30px 60px rgba(139, 79, 50, 0.10);
  }

  .card-top {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }

  /* Category chip: Gothic font, 13px, No bullet */
  .cat-chip {
    display: inline-flex;
    align-items: center;
    padding: 6px 16px;
    border-radius: 9999px;
    background: rgba(243, 166, 131, 0.4);
    font-family: var(--font-family-gothic);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-primary);
  }

  .fav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    color: var(--color-outline-variant);
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    transition: color var(--transition-fast);
  }
  .fav-btn:hover { color: #ffd700; } /* Gold color on hover for star */

  .card-title {
    font-family: var(--font-family-base);
    font-size: 24px;
    font-weight: 700;
    line-height: 31px;
    color: #350f00;
    margin-bottom: 8px;
    margin-top: 0;
  }

  .card-desc {
    font-family: var(--font-family-base);
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: #53433d;
    margin: 0;
  }

  @media (max-width: 768px) {
    .card-title { font-size: 20px; }
    .card-desc  { font-size: 14px; }
  }
</style>
