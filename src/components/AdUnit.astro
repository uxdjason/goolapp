---
interface Props {
  position: 'top' | 'middle' | 'bottom';
}
const { position } = Astro.props;
const showAdsense = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const clientId    = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
---
<div class={`ad-unit ad-${position}`} role="complementary" aria-label={`광고 (${position})`}>
  {showAdsense ? (
    <>
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client={clientId}
           data-ad-slot="1234567890"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
      <script is:inline>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </>
  ) : (
    <div class="ad-placeholder">
      <span class="ad-label">AD</span>
      <span class="ad-pos">({position})</span>
    </div>
  )}
</div>

<style>
  .ad-unit {
    width: 100%;
    margin: var(--space-8) 0;
  }
  .ad-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    width: 100%;
    min-height: 90px;
    background: rgba(245, 243, 239, 0.7);
    border: 1px dashed var(--color-outline-variant);
    border-radius: var(--radius-lg);
    color: var(--color-on-surface-variant);
    font-size: var(--font-size-xs);
    letter-spacing: 0.08em;
  }
  .ad-label {
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    opacity: 0.5;
  }
  .ad-pos { opacity: 0.4; }
</style>
