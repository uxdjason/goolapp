---
interface Props {
  position: 'top' | 'middle' | 'bottom';
}
const { position } = Astro.props;
const showAdsense = import.meta.env.PUBLIC_ADSENSE_ENABLED === 'true';
const clientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;
---
<div class={`ad-container ad-${position}`}>
  {showAdsense ? (
    <>
      <ins class="adsbygoogle"
           style="display:block"
           data-ad-client={clientId}
           data-ad-slot="1234567890"
           data-ad-format="auto"
           data-full-width-responsive="true"></ins>
      <script is:inline>
           (adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </>
  ) : (
    <div class="ad-placeholder">
      <p>Advertisement ({position})</p>
    </div>
  )}
</div>

<style>
  .ad-container {
    margin: var(--ad-spacing) 0;
    min-height: var(--ad-min-height);
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .ad-placeholder {
    width: 100%;
    height: 100%;
    min-height: 100px;
    background: var(--color-surface-variant);
    border: 1px dashed var(--color-outline);
    display: flex;
    justify-content: center;
    align-items: center;
    color: var(--color-on-surface-variant);
    font-size: var(--font-size-sm);
    border-radius: var(--radius-md);
  }
</style>
