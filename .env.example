# Anthropic Claude API (앱/콘텐츠 생성 주력)
ANTHROPIC_API_KEY=

# Gemini API (Claude 사용 불가 시 fallback용)
GEMINI_API_KEY=

# 네이버 DataLab / 검색 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# AdSense
PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# AdSense 스크립트 출력 여부 (production + 정식 도메인에서만 true)
# - 기본 .env: false (preview/dev 안전 기본값)
# - production 빌드 환경(Cloudflare Pages production branch)에서만 true 주입
PUBLIC_ADSENSE_ENABLED=false
